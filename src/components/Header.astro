---
import { perfil, navegacion } from "../data/site";
import { withBase } from "../lib/utils";

// Las iniciales para el logo
const iniciales = perfil.nombre
  .split(" ")
  .slice(0, 2)
  .map((p) => p[0])
  .join("");
---

<header class="site-header">
  <div class="container header-inner">
    <a href={withBase("/")} class="logo" aria-label="Inicio">
      <span class="logo-mark">{iniciales}</span>
      <span class="logo-text">{perfil.nombre}</span>
    </a>

    <nav class="nav" aria-label="Navegación principal">
      {
        navegacion.map((item) => (
          <a
            href={item.href.startsWith("#") ? item.href : withBase(item.href)}
            class="nav-link"
          >
            {item.texto}
          </a>
        ))
      }
    </nav>

    <div class="header-actions">
      <button
        id="toggle-tema"
        class="icon-btn"
        type="button"
        aria-label="Cambiar tema claro u oscuro"
        title="Cambiar tema"
      >
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>

      <button
        id="toggle-menu"
        class="icon-btn menu-btn"
        type="button"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Menú móvil -->
  <nav id="nav-movil" class="nav-movil" aria-label="Navegación móvil" hidden>
    {
      navegacion.map((item) => (
        <a
          href={item.href.startsWith("#") ? item.href : withBase(item.href)}
          class="nav-link"
        >
          {item.texto}
        </a>
      ))
    }
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    backdrop-filter: saturate(1.4) blur(10px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 68px;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-weight: 640;
    letter-spacing: -0.01em;
  }

  .logo-mark {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--accent);
    color: var(--accent-contrast);
    font-size: 0.85rem;
    font-weight: 680;
    letter-spacing: 0;
  }

  .logo-text {
    font-size: var(--text-sm);
  }

  .nav {
    display: flex;
    gap: 0.35rem;
    margin-inline: auto;
  }

  .nav-link {
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--muted);
    font-weight: 500;
    transition: color var(--dur) var(--ease), background var(--dur) var(--ease);
  }

  .nav-link:hover {
    color: var(--text);
    background: var(--bg-soft);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .icon-btn {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }

  .icon-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Mostrar el icono correcto según el tema */
  .icon-moon {
    display: none;
  }
  :global([data-theme="dark"]) .icon-sun {
    display: none;
  }
  :global([data-theme="dark"]) .icon-moon {
    display: block;
  }

  .menu-btn {
    display: none;
  }

  .nav-movil {
    display: none;
    flex-direction: column;
    padding: 0.5rem clamp(1.25rem, 4vw, 2.5rem) 1rem;
    border-top: 1px solid var(--border);
    gap: 0.15rem;
  }

  .nav-movil .nav-link {
    padding: 0.7rem 0.85rem;
  }

  @media (max-width: 760px) {
    .nav {
      display: none;
    }
    .menu-btn {
      display: grid;
    }
    .nav-movil[data-abierto="true"] {
      display: flex;
    }
  }
</style>

<script>
  // Alternar tema claro/oscuro
  const btn = document.getElementById("toggle-tema");
  btn?.addEventListener("click", () => {
    const root = document.documentElement;
    const actual = root.getAttribute("data-theme") === "dark" ? "dark" : "light";
    const nuevo = actual === "dark" ? "light" : "dark";
    root.setAttribute("data-theme", nuevo);
    try {
      localStorage.setItem("tema", nuevo);
    } catch (e) {}
  });

  // Menú móvil
  const menuBtn = document.getElementById("toggle-menu");
  const navMovil = document.getElementById("nav-movil");
  menuBtn?.addEventListener("click", () => {
    const abierto = navMovil?.getAttribute("data-abierto") === "true";
    navMovil?.setAttribute("data-abierto", String(!abierto));
    if (navMovil) navMovil.hidden = abierto;
    menuBtn.setAttribute("aria-expanded", String(!abierto));
  });
  // Cerrar el menú al pulsar un enlace
  navMovil?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      navMovil.setAttribute("data-abierto", "false");
      navMovil.hidden = true;
      menuBtn?.setAttribute("aria-expanded", "false");
    })
  );
</script>
