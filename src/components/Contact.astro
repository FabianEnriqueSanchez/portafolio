---
import { perfil } from "../data/site";
---

<section id="contacto" class="section">
  <div class="container contacto reveal">
    <p class="eyebrow">Contacto</p>
    <h2 class="section-title">¿Trabajamos juntos?</h2>
    <p class="section-intro">
      Estoy abierto a oportunidades y colaboraciones. Escríbeme y te respondo lo
      antes posible.
    </p>

    <div class="contacto-acciones">
      <a href={`mailto:${perfil.email}`} class="btn btn-primary">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
          ><rect x="2" y="4" width="20" height="16" rx="2"></rect><path
            d="m2 7 10 6 10-6"></path></svg
        >
        {perfil.email}
      </a>
      {
        perfil.social.linkedin && (
          <a
            href={perfil.social.linkedin}
            class="btn btn-ghost"
            target="_blank"
            rel="noopener"
          >
            LinkedIn
          </a>
        )
      }
      {
        perfil.social.github && (
          <a
            href={perfil.social.github}
            class="btn btn-ghost"
            target="_blank"
            rel="noopener"
          >
            GitHub
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  .contacto {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .contacto .section-title,
  .contacto .section-intro {
    max-width: 30ch;
  }

  .contacto-acciones {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }
</style>
