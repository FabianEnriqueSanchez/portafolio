---
import { sobreMi, idiomas } from "../data/site";
---

<section id="sobre-mi" class="section">
  <div class="container about-grid">
    <div class="about-text reveal">
      <p class="eyebrow">Sobre mí</p>
      <h2 class="section-title">Un poco de contexto sobre lo que hago</h2>
      {sobreMi.parrafos.map((p) => <p class="about-p">{p}</p>)}
    </div>

    <aside class="about-stack reveal">
      <h3 class="stack-title">Stack y herramientas</h3>
      <ul class="stack-list">
        {sobreMi.stack.map((t) => <li class="stack-tag">{t}</li>)}
      </ul>

      <h3 class="stack-title stack-title-sep">Idiomas</h3>
      <ul class="idiomas-list">
        {
          idiomas.map((i) => (
            <li class="idioma">
              <span class="idioma-nombre">{i.idioma}</span>
              <span class="idioma-nivel">{i.nivel}</span>
            </li>
          ))
        }
      </ul>
    </aside>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .about-p {
    color: var(--muted);
    margin-top: 1.1rem;
    max-width: 56ch;
  }

  .about-stack {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.6rem;
    background: var(--surface);
  }

  .stack-title {
    font-size: var(--text-base);
    margin-bottom: 1.1rem;
  }

  .stack-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .stack-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    color: var(--muted);
    background: var(--bg-soft);
  }

  .stack-title-sep {
    margin-top: 1.6rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--border);
  }

  .idiomas-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }

  .idioma {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .idioma-nombre {
    font-weight: 540;
    font-size: var(--text-sm);
  }

  .idioma-nivel {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
  }

  @media (max-width: 760px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
