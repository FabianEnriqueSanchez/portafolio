---
import { experiencia, educacion, certificaciones } from "../data/site";
---

<section id="experiencia" class="section section-alt">
  <div class="container">
    <header class="exp-head reveal">
      <p class="eyebrow">Trayectoria</p>
      <h2 class="section-title">Experiencia y formación</h2>
    </header>

    <div class="exp-grid">
      <!-- Columna principal: experiencia laboral -->
      <div class="exp-main">
        <h3 class="col-title">Experiencia laboral</h3>
        <ol class="timeline">
          {
            experiencia.map((e) => (
              <li class="timeline-item reveal">
                <div class="timeline-marker" aria-hidden="true" />
                <div class="timeline-content">
                  <span class="timeline-period">{e.periodo}</span>
                  <h4 class="timeline-role">{e.puesto}</h4>
                  <p class="timeline-company">{e.empresa}</p>
                  <ul class="timeline-points">
                    {e.puntos.map((p) => (
                      <li>{p}</li>
                    ))}
                  </ul>
                </div>
              </li>
            ))
          }
        </ol>
      </div>

      <!-- Columna lateral: formación + certificaciones -->
      <aside class="exp-side">
        <div class="exp-card reveal">
          <h3 class="col-title">Formación</h3>
          {
            educacion.map((ed) => (
              <div class="mini-item">
                <p class="mini-title">{ed.titulo}</p>
                <p class="mini-meta">
                  {ed.institucion} · {ed.periodo}
                </p>
              </div>
            ))
          }
        </div>

        <div class="exp-card reveal">
          <h3 class="col-title">Certificaciones</h3>
          {
            certificaciones.map((c) => (
              <div class="mini-item">
                <p class="mini-title">{c.nombre}</p>
                <p class="mini-meta">
                  {c.entidad} · {c.año}
                </p>
              </div>
            ))
          }
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .exp-head {
    margin-bottom: 2.75rem;
  }

  .exp-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: start;
  }

  .col-title {
    font-size: var(--text-base);
    color: var(--faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-family: var(--font-mono);
    font-weight: 500;
    margin-bottom: 1.6rem;
  }

  /* Timeline */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline-item {
    position: relative;
    padding-left: 1.8rem;
    padding-bottom: 2.2rem;
    border-left: 2px solid var(--border);
  }

  .timeline-item:last-child {
    padding-bottom: 0;
    border-left-color: transparent;
  }

  .timeline-marker {
    position: absolute;
    left: -7px;
    top: 4px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--bg-soft);
  }

  .timeline-period {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
  }

  .timeline-role {
    font-size: var(--text-lg);
    margin-top: 0.35rem;
  }

  .timeline-company {
    color: var(--muted);
    font-weight: 500;
    margin-top: 0.1rem;
  }

  .timeline-points {
    margin: 0.9rem 0 0;
    padding-left: 1.1rem;
    color: var(--muted);
    font-size: var(--text-sm);
  }

  .timeline-points li {
    margin-block: 0.4rem;
  }

  /* Tarjetas laterales */
  .exp-side {
    display: grid;
    gap: 1.25rem;
  }

  .exp-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  .mini-item + .mini-item {
    margin-top: 1.1rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--border);
  }

  .mini-title {
    font-weight: 580;
    font-size: var(--text-sm);
  }

  .mini-meta {
    color: var(--faint);
    font-size: var(--text-xs);
    margin-top: 0.25rem;
  }

  @media (max-width: 760px) {
    .exp-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
