---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { withBase } from "../../../lib/utils";

const titulo = "Flujo de automatización — simulación";
const descripcion =
  "Demo interactiva que simula, directamente en el navegador, un flujo de aprobación con el patrón de Power Automate y Power Apps: formulario, nodos en secuencia y lista de seguimiento.";
---

<BaseLayout titulo={`${titulo} — Demo interactiva`} descripcion={descripcion}>
  <Header />
  <main id="contenido" class="demo" tabindex="-1">
    <p class="visualmente-oculto" aria-live="polite" data-anuncios></p>

    <!-- ================= HERO ================= -->
    <section class="hero">
      <div class="container reveal">
        <p class="eyebrow">Demo interactiva</p>
        <h1 class="hero-titulo">Flujo de automatización — simulación</h1>
        <p class="hero-contexto">
          Replica, 100&nbsp;% en tu navegador, el patrón de los flujos reales
          construidos con Power Automate y Power Apps: un formulario captura la
          solicitud, un flujo la procesa nodo a nodo y una lista registra el
          resultado. Tú tomas la decisión, como si fueras la persona
          responsable.
        </p>
        <p class="aviso" role="note">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 16v-4M12 8h.01"></path>
          </svg>
          Simulación: no se envía nada real.
        </p>
        <noscript>
          <p class="aviso">
            Esta demo necesita JavaScript para ejecutar la simulación.
          </p>
        </noscript>
        <div class="hero-acciones">
          <a class="btn btn-ghost" href={`${withBase("/")}#proyectos`}>
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <path d="M19 12H5M11 18l-6-6 6-6"></path>
            </svg>
            Volver a proyectos
          </a>
          <a
            class="btn btn-ghost"
            href={withBase("docs/automatizacion-procesos/")}>Documentación</a
          >
        </div>
      </div>
    </section>

    <!-- ================= PASO 1 Y PASO 2 ================= -->
    <section class="section cuerpo-demo">
      <div class="container tablero">
        <!-- PASO 1 — Formulario -->
        <section class="reveal" aria-labelledby="titulo-formulario">
          <div class="paso-cabecera">
            <span class="paso-numero">Paso 1</span>
            <h2 class="paso-titulo" id="titulo-formulario">
              Nueva solicitud de soporte
            </h2>
          </div>
          <p class="paso-descripcion">
            Formulario al estilo Power Apps. Completa los campos y envíalo para
            iniciar el flujo.
          </p>

          <form id="form-solicitud" class="tarjeta-formulario" novalidate>
            <fieldset class="campos" data-campos>
              <legend class="visualmente-oculto">Datos de la solicitud</legend>

              <div class="campo">
                <label for="campo-solicitante">Solicitante</label>
                <input
                  type="text"
                  id="campo-solicitante"
                  name="solicitante"
                  autocomplete="name"
                  placeholder="Nombre y apellido"
                  aria-describedby="error-solicitante"
                />
                <p class="error" id="error-solicitante" hidden></p>
              </div>

              <div class="campo">
                <label for="campo-categoria">Categoría</label>
                <select
                  id="campo-categoria"
                  name="categoria"
                  aria-describedby="error-categoria"
                >
                  <option value="" selected>Selecciona una categoría</option>
                  <option value="Hardware">Hardware</option>
                  <option value="Software">Software</option>
                  <option value="Accesos">Accesos</option>
                  <option value="Otro">Otro</option>
                </select>
                <p class="error" id="error-categoria" hidden></p>
              </div>

              <fieldset
                class="grupo-radios"
                id="grupo-prioridad"
                aria-describedby="ayuda-prioridad error-prioridad"
              >
                <legend>Prioridad</legend>
                <div class="radios">
                  <label class="radio-chip"
                    ><input type="radio" name="prioridad" value="Baja" /> Baja</label
                  >
                  <label class="radio-chip"
                    ><input type="radio" name="prioridad" value="Media" /> Media</label
                  >
                  <label class="radio-chip"
                    ><input type="radio" name="prioridad" value="Alta" /> Alta</label
                  >
                </div>
                <p class="ayuda" id="ayuda-prioridad">
                  La prioridad alta notifica al jefe de área de inmediato.
                </p>
                <p class="error" id="error-prioridad" hidden></p>
              </fieldset>

              <div class="campo">
                <label for="campo-descripcion">Descripción</label>
                <textarea
                  id="campo-descripcion"
                  name="descripcion"
                  rows="4"
                  placeholder="¿Qué ocurre y desde cuándo?"
                  aria-describedby="ayuda-descripcion error-descripcion"
                ></textarea>
                <p class="ayuda" id="ayuda-descripcion">
                  Mínimo 10 caracteres.
                </p>
                <p class="error" id="error-descripcion" hidden></p>
              </div>

              <button type="submit" class="btn btn-primary btn-enviar">
                Enviar solicitud
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path>
                </svg>
              </button>
            </fieldset>
          </form>
        </section>

        <!-- PASO 2 — Flujo -->
        <section class="reveal" aria-labelledby="titulo-flujo">
          <div class="paso-cabecera">
            <span class="paso-numero">Paso 2</span>
            <h2 class="paso-titulo" id="titulo-flujo">Recorrido del flujo</h2>
          </div>
          <p class="paso-descripcion">
            Cada nodo replica una acción de Power Automate: se activa en
            secuencia y muestra su salida.
          </p>

          <div
            class="flujo"
            id="panel-flujo"
            role="group"
            tabindex="-1"
            aria-label="Diagrama del flujo de aprobación"
            data-fase="reposo"
          >
            <p class="flujo-estado">
              <span class="fase-punto" aria-hidden="true"></span>
              <span data-texto-fase>En espera de una solicitud</span>
            </p>

            <ol class="nodos">
              <!-- 1. Desencadenador -->
              <li class="nodo" data-nodo="recepcion" data-estado="pendiente">
                <article class="nodo-tarjeta">
                  <div class="nodo-cabecera">
                    <span class="nodo-icono" aria-hidden="true">
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
                      </svg>
                    </span>
                    <div class="nodo-titulos">
                      <span class="nodo-tipo">Desencadenador</span>
                      <h3 class="nodo-nombre" data-nombre>
                        Solicitud recibida
                      </h3>
                    </div>
                    <div class="nodo-meta">
                      <span class="estado-chip"
                        ><span class="estado-icono" aria-hidden="true"
                        ></span><span data-estado-texto>Pendiente</span></span
                      >
                      <span class="nodo-hora" data-hora hidden></span>
                    </div>
                  </div>
                  <div class="nodo-salida" data-salida hidden>
                    <span class="salida-etiqueta">Salida</span>
                    <dl class="salida-datos" data-salida-datos></dl>
                  </div>
                </article>
              </li>

              <!-- 2. Condición -->
              <li class="nodo" data-nodo="condicion" data-estado="pendiente">
                <article class="nodo-tarjeta">
                  <div class="nodo-cabecera">
                    <span class="nodo-icono" aria-hidden="true">
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M6 3v12"></path>
                        <circle cx="18" cy="6" r="3"></circle>
                        <circle cx="6" cy="18" r="3"></circle>
                        <path d="M18 9a9 9 0 0 1-9 9"></path>
                      </svg>
                    </span>
                    <div class="nodo-titulos">
                      <span class="nodo-tipo">Condición</span>
                      <h3 class="nodo-nombre" data-nombre>¿Prioridad alta?</h3>
                    </div>
                    <div class="nodo-meta">
                      <span class="estado-chip"
                        ><span class="estado-icono" aria-hidden="true"
                        ></span><span data-estado-texto>Pendiente</span></span
                      >
                      <span class="nodo-hora" data-hora hidden></span>
                    </div>
                  </div>
                  <div class="condicion-ramas" aria-hidden="true">
                    <span class="rama" data-rama="si">SÍ</span>
                    <span class="rama" data-rama="no">NO</span>
                  </div>
                  <div class="nodo-salida" data-salida hidden>
                    <span class="salida-etiqueta">Salida</span>
                    <dl class="salida-datos" data-salida-datos></dl>
                  </div>
                </article>
              </li>

              <!-- 3. Rama SÍ: notificar al jefe -->
              <li
                class="nodo nodo-rama"
                data-nodo="notificar-jefe"
                data-estado="pendiente"
              >
                <article class="nodo-tarjeta">
                  <div class="nodo-cabecera">
                    <span class="nodo-icono" aria-hidden="true">
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"
                        ></path>
                        <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                      </svg>
                    </span>
                    <div class="nodo-titulos">
                      <span class="nodo-tipo">Acción · Rama SÍ</span>
                      <h3 class="nodo-nombre" data-nombre>
                        Notificar al jefe de área de inmediato
                      </h3>
                    </div>
                    <div class="nodo-meta">
                      <span class="estado-chip"
                        ><span class="estado-icono" aria-hidden="true"
                        ></span><span data-estado-texto>Pendiente</span></span
                      >
                      <span class="nodo-hora" data-hora hidden></span>
                    </div>
                  </div>
                  <div class="nodo-salida" data-salida hidden>
                    <span class="salida-etiqueta">Salida</span>
                    <dl class="salida-datos" data-salida-datos></dl>
                  </div>
                </article>
              </li>

              <!-- 4. Asignar responsable -->
              <li class="nodo" data-nodo="asignar" data-estado="pendiente">
                <article class="nodo-tarjeta">
                  <div class="nodo-cabecera">
                    <span class="nodo-icono" aria-hidden="true">
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
                        ></path>
                        <circle cx="8.5" cy="7" r="4"></circle>
                        <path d="M17 11l2 2 4-4"></path>
                      </svg>
                    </span>
                    <div class="nodo-titulos">
                      <span class="nodo-tipo">Acción</span>
                      <h3 class="nodo-nombre" data-nombre>
                        Asignar responsable según categoría
                      </h3>
                    </div>
                    <div class="nodo-meta">
                      <span class="estado-chip"
                        ><span class="estado-icono" aria-hidden="true"
                        ></span><span data-estado-texto>Pendiente</span></span
                      >
                      <span class="nodo-hora" data-hora hidden></span>
                    </div>
                  </div>
                  <ul class="mapa-asignacion" data-mapa>
                    <li data-categoria="Hardware">
                      <span>Hardware</span><span
                        class="mapa-flecha"
                        aria-hidden="true">→</span
                      ><span>Soporte técnico</span>
                    </li>
                    <li data-categoria="Software">
                      <span>Software</span><span
                        class="mapa-flecha"
                        aria-hidden="true">→</span
                      ><span>Desarrollo</span>
                    </li>
                    <li data-categoria="Accesos">
                      <span>Accesos</span><span
                        class="mapa-flecha"
                        aria-hidden="true">→</span
                      ><span>Infraestructura</span>
                    </li>
                    <li data-categoria="Otro">
                      <span>Otro</span><span
                        class="mapa-flecha"
                        aria-hidden="true">→</span
                      ><span>Mesa de ayuda</span>
                    </li>
                  </ul>
                  <div class="nodo-salida" data-salida hidden>
                    <span class="salida-etiqueta">Salida</span>
                    <dl class="salida-datos" data-salida-datos></dl>
                  </div>
                </article>
              </li>

              <!-- 5. Aprobación interactiva -->
              <li class="nodo" data-nodo="aprobacion" data-estado="pendiente">
                <article class="nodo-tarjeta">
                  <div class="nodo-cabecera">
                    <span class="nodo-icono" aria-hidden="true">
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M9 11l3 3L22 4"></path>
                        <path
                          d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
                        ></path>
                      </svg>
                    </span>
                    <div class="nodo-titulos">
                      <span class="nodo-tipo">Aprobación</span>
                      <h3 class="nodo-nombre" data-nombre>
                        Esperando aprobación del responsable
                      </h3>
                    </div>
                    <div class="nodo-meta">
                      <span class="estado-chip"
                        ><span class="estado-icono" aria-hidden="true"
                        ></span><span data-estado-texto>Pendiente</span></span
                      >
                      <span class="nodo-hora" data-hora hidden></span>
                    </div>
                  </div>
                  <div class="zona-aprobacion" data-zona-aprobacion hidden>
                    <p class="aprobacion-guia">
                      Ahora decides tú, como si fueras la persona responsable.
                    </p>
                    <div class="campo campo-comentario">
                      <label for="campo-comentario">Comentario (opcional)</label
                      >
                      <input
                        type="text"
                        id="campo-comentario"
                        maxlength="140"
                        autocomplete="off"
                        placeholder="p. ej.: validado con el inventario"
                      />
                    </div>
                    <div class="acciones-aprobacion">
                      <button type="button" class="btn btn-primary" data-aprobar
                        >Aprobar</button
                      >
                      <button
                        type="button"
                        class="btn btn-peligro"
                        data-rechazar>Rechazar</button
                      >
                    </div>
                  </div>
                  <div class="nodo-salida" data-salida hidden>
                    <span class="salida-etiqueta">Salida</span>
                    <dl class="salida-datos" data-salida-datos></dl>
                  </div>
                </article>
              </li>

              <!-- 6. Notificación -->
              <li class="nodo" data-nodo="correo" data-estado="pendiente">
                <article class="nodo-tarjeta">
                  <div class="nodo-cabecera">
                    <span class="nodo-icono" aria-hidden="true">
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path
                          d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                        ></path>
                        <path d="M22 6l-10 7L2 6"></path>
                      </svg>
                    </span>
                    <div class="nodo-titulos">
                      <span class="nodo-tipo">Notificación</span>
                      <h3 class="nodo-nombre" data-nombre>
                        Correo enviado al solicitante
                      </h3>
                    </div>
                    <div class="nodo-meta">
                      <span class="estado-chip"
                        ><span class="estado-icono" aria-hidden="true"
                        ></span><span data-estado-texto>Pendiente</span></span
                      >
                      <span class="nodo-hora" data-hora hidden></span>
                    </div>
                  </div>
                  <div class="nodo-salida" data-salida hidden>
                    <span class="salida-etiqueta">Salida</span>
                    <dl class="salida-datos" data-salida-datos></dl>
                  </div>
                </article>
              </li>

              <!-- 7. Registro -->
              <li class="nodo" data-nodo="registro" data-estado="pendiente">
                <article class="nodo-tarjeta">
                  <div class="nodo-cabecera">
                    <span class="nodo-icono" aria-hidden="true">
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
                        <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
                        <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
                      </svg>
                    </span>
                    <div class="nodo-titulos">
                      <span class="nodo-tipo">Registro</span>
                      <h3 class="nodo-nombre" data-nombre>
                        Guardado en la lista de seguimiento
                      </h3>
                    </div>
                    <div class="nodo-meta">
                      <span class="estado-chip"
                        ><span class="estado-icono" aria-hidden="true"
                        ></span><span data-estado-texto>Pendiente</span></span
                      >
                      <span class="nodo-hora" data-hora hidden></span>
                    </div>
                  </div>
                  <div class="nodo-salida" data-salida hidden>
                    <span class="salida-etiqueta">Salida</span>
                    <dl class="salida-datos" data-salida-datos></dl>
                  </div>
                </article>
              </li>
            </ol>

            <div class="flujo-fin" data-fin hidden>
              <p>
                Solicitud registrada. El flujo quedó listo para una nueva
                ejecución.
              </p>
              <button type="button" class="btn btn-primary js-nueva-solicitud"
                >Nueva solicitud</button
              >
            </div>
          </div>
        </section>
      </div>
    </section>

    <!-- ================= PASO 3 — SEGUIMIENTO ================= -->
    <section
      class="section section-alt seguimiento"
      aria-labelledby="titulo-seguimiento"
    >
      <div class="container reveal">
        <div class="seguimiento-cabecera">
          <div>
            <div class="paso-cabecera">
              <span class="paso-numero">Paso 3</span>
              <h2 class="paso-titulo" id="titulo-seguimiento">
                Lista de seguimiento
              </h2>
            </div>
            <p class="paso-descripcion">
              Las solicitudes procesadas en esta sesión, tal como quedarían en
              la lista de seguimiento.
            </p>
          </div>
          <button type="button" class="btn btn-ghost js-nueva-solicitud"
            >Nueva solicitud</button
          >
        </div>

        <div class="metricas">
          <div class="metrica">
            <p class="metrica-valor" data-metrica="total">0</p>
            <p class="metrica-nombre">Solicitudes procesadas</p>
          </div>
          <div class="metrica">
            <p class="metrica-valor" data-metrica="aprobadas">—</p>
            <p class="metrica-nombre">Aprobadas</p>
          </div>
          <div class="metrica">
            <p class="metrica-valor" data-metrica="tiempo">—</p>
            <p class="metrica-nombre">Tiempo medio del flujo</p>
          </div>
        </div>

        <div
          class="tabla-envoltura"
          role="region"
          aria-label="Lista de seguimiento"
          tabindex="0"
        >
          <table>
            <caption class="visualmente-oculto"
              >Solicitudes procesadas en esta sesión</caption
            >
            <thead>
              <tr>
                <th scope="col">Id</th>
                <th scope="col">Solicitante</th>
                <th scope="col">Categoría</th>
                <th scope="col">Prioridad</th>
                <th scope="col">Responsable</th>
                <th scope="col">Estado</th>
                <th scope="col">Duración</th>
              </tr>
            </thead>
            <tbody id="cuerpo-seguimiento">
              <tr id="fila-vacia" class="fila-vacia">
                <td colspan="7"
                  >Aún no hay solicitudes. Envía la primera desde el formulario.</td
                >
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* Colores puntuales (rechazo) con soporte de ambos temas */
  .demo {
    --peligro: #b42318;
    --peligro-suave: #fbe4e1;
  }
  :global(html[data-theme="dark"]) .demo {
    --peligro: #f87171;
    --peligro-suave: #3c1f1b;
  }

  [hidden] {
    display: none !important;
  }

  .visualmente-oculto {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  /* ---------- Hero ---------- */
  .hero {
    padding-block: clamp(3rem, 7vw, 4.5rem) clamp(1.5rem, 3vw, 2rem);
  }

  .hero-titulo {
    font-size: clamp(1.9rem, 5vw, var(--text-3xl));
    margin-top: 0.6rem;
    max-width: 24ch;
  }

  .hero-contexto {
    color: var(--muted);
    max-width: 62ch;
    margin-top: 1rem;
    font-size: var(--text-lg);
  }

  .aviso {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.2rem;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent-hover);
    border: 1px solid var(--border);
    font-size: var(--text-sm);
    font-weight: 560;
  }

  .aviso svg {
    flex: none;
  }

  .hero-acciones {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.6rem;
  }

  /* ---------- Estructura de pasos ---------- */
  .cuerpo-demo {
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .tablero {
    display: grid;
    gap: 2.5rem;
    align-items: start;
  }

  @media (min-width: 940px) {
    .tablero {
      grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    }
  }

  .paso-cabecera {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .paso-numero {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-hover);
    background: var(--accent-soft);
    border-radius: 999px;
    padding: 0.15rem 0.65rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .paso-titulo {
    font-size: var(--text-xl);
  }

  .paso-descripcion {
    color: var(--muted);
    font-size: var(--text-sm);
    margin-top: 0.5rem;
    margin-bottom: 1.3rem;
    max-width: 52ch;
  }

  /* ---------- Paso 1: formulario ---------- */
  .tarjeta-formulario {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: clamp(1.25rem, 3vw, 1.75rem);
    box-shadow: var(--shadow);
  }

  .campos {
    border: none;
    padding: 0;
    margin: 0;
    transition: opacity var(--dur) var(--ease);
  }

  .campos:disabled {
    opacity: 0.6;
  }

  .campo {
    margin-bottom: 1.15rem;
  }

  .campo label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 560;
    margin-bottom: 0.4rem;
  }

  .campo input,
  .campo select,
  .campo textarea {
    width: 100%;
    font: inherit;
    font-size: 1rem;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
