    min-height: 44px;
    transition: border-color var(--dur) var(--ease);
  }

  .campo textarea {
    resize: vertical;
    min-height: 100px;
  }

  .campo input::placeholder,
  .campo textarea::placeholder {
    color: var(--faint);
  }

  .campo :is(input, select, textarea)[aria-invalid="true"] {
    border-color: var(--peligro);
  }

  .ayuda {
    color: var(--faint);
    font-size: var(--text-xs);
    margin-top: 0.35rem;
  }

  .error {
    color: var(--peligro);
    font-size: var(--text-xs);
    font-weight: 560;
    margin-top: 0.35rem;
  }

  /* Radios como fichas accesibles */
  .grupo-radios {
    border: none;
    padding: 0;
    margin: 0 0 1.15rem;
  }

  .grupo-radios legend {
    font-size: var(--text-sm);
    font-weight: 560;
    margin-bottom: 0.45rem;
    padding: 0;
  }

  .radios {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .radio-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 40px;
    padding: 0.45rem 0.95rem;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: var(--bg);
    font-size: var(--text-sm);
    cursor: pointer;
    transition:
      border-color var(--dur) var(--ease),
      background var(--dur) var(--ease);
  }

  .radio-chip input {
    accent-color: var(--accent);
    margin: 0;
    width: 1rem;
    height: 1rem;
  }

  .radio-chip input:focus-visible {
    outline: none;
  }

  .radio-chip:has(input:focus-visible) {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .radio-chip:has(input:checked) {
    border-color: var(--accent);
    background: var(--accent-soft);
  }

  .grupo-radios[data-invalido="true"] .radio-chip {
    border-color: var(--peligro);
  }

  .btn-enviar {
    width: 100%;
    justify-content: center;
    margin-top: 0.4rem;
  }

  .btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  /* ---------- Paso 2: diagrama del flujo ---------- */
  .flujo {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: clamp(0.9rem, 2.5vw, 1.5rem);
    background-color: var(--bg);
    background-image: radial-gradient(var(--border) 1px, transparent 1px);
    background-size: 16px 16px;
  }

  .flujo-estado {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    padding: 0.35rem 0.6rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    width: fit-content;
  }

  .fase-punto {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--faint);
    flex: none;
    transition: background var(--dur) var(--ease);
  }

  .flujo[data-fase="ejecutando"] .fase-punto,
  .flujo[data-fase="esperando"] .fase-punto,
  .flujo[data-fase="completado"] .fase-punto {
    background: var(--accent);
  }

  .nodos {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
  }

  /* Conector vertical entre nodos */
  .nodo:not(:last-child)::after {
    content: "";
    display: block;
    width: 2px;
    height: 26px;
    margin: 0 auto;
    background: var(--border-strong);
    transition: background var(--dur) var(--ease);
  }

  .nodo[data-estado="completado"]:not(:last-child)::after {
    background: var(--accent);
  }

  .nodo-tarjeta {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.9rem 1rem;
    box-shadow: var(--shadow);
    transition:
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease),
      background-color 0.3s var(--ease);
  }

  /* Estados atenuados solo con decoración (fondo, borde, sombra):
     el texto conserva el color pleno de los tokens para no perder AA */
  .nodo[data-estado="pendiente"] .nodo-tarjeta {
    background: var(--bg-soft);
    box-shadow: none;
  }

  .nodo[data-estado="en-curso"] .nodo-tarjeta {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  .nodo[data-estado="omitido"] .nodo-tarjeta {
    background: var(--bg-soft);
    border-style: dashed;
    box-shadow: none;
  }

  /* Rama de la condición */
  .nodo-rama .nodo-tarjeta {
    margin-left: clamp(1.25rem, 5vw, 2.5rem);
    border-left: 3px solid var(--accent);
  }

  .nodo-rama[data-estado="pendiente"] .nodo-tarjeta,
  .nodo-rama[data-estado="omitido"] .nodo-tarjeta {
    border-left-color: var(--border-strong);
  }

  .nodo-cabecera {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .nodo-icono {
    flex: none;
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: var(--accent-soft);
    color: var(--accent);
    transition:
      background var(--dur) var(--ease),
      color var(--dur) var(--ease);
  }

  .nodo[data-estado="pendiente"] .nodo-icono,
  .nodo[data-estado="omitido"] .nodo-icono {
    background: var(--bg);
    color: var(--faint);
  }

  .nodo-titulos {
    flex: 1;
    min-width: 0;
  }

  .nodo-tipo {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .nodo-nombre {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.4;
    margin-top: 0.1rem;
  }

  .nodo-meta {
    margin-left: auto;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
  }

  .estado-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--faint);
    white-space: nowrap;
  }

  .nodo[data-estado="en-curso"] .estado-chip {
    color: var(--accent);
  }

  .nodo[data-estado="completado"] .estado-chip {
    color: var(--muted);
  }

  .estado-icono {
    flex: none;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    border: 2px solid var(--border-strong);
  }

  .nodo[data-estado="en-curso"] .estado-icono {
    border-color: var(--accent-soft);
    border-top-color: var(--accent);
    border-right-color: var(--accent);
    animation: girar 1s linear infinite;
  }

  .nodo[data-estado="completado"] .estado-icono {
    border-color: var(--accent);
    background: var(--accent);
  }

  .nodo[data-estado="omitido"] .estado-icono {
    border-style: dashed;
  }

  @keyframes girar {
    to {
      transform: rotate(360deg);
    }
  }

  .nodo-hora {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--faint);
  }

  /* Ramas SÍ/NO de la condición */
  .condicion-ramas {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.7rem;
  }

  .rama {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--faint);
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
    transition:
      border-color var(--dur) var(--ease),
      background var(--dur) var(--ease),
      color var(--dur) var(--ease);
  }

  .rama[data-activa="true"] {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--accent-hover);
    font-weight: 600;
  }

  /* Mapa de asignación */
  .mapa-asignacion {
    list-style: none;
    margin: 0.75rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.15rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--faint);
  }

  .mapa-asignacion li {
    display: flex;
    gap: 0.5rem;
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    transition:
      background var(--dur) var(--ease),
      color var(--dur) var(--ease);
  }

  .mapa-asignacion li[data-activa="true"] {
    background: var(--accent-soft);
    color: var(--accent-hover);
    font-weight: 600;
  }

  .mapa-flecha {
    flex: none;
  }

  /* Zona de aprobación interactiva */
  .zona-aprobacion {
    margin-top: 0.9rem;
    border-top: 1px dashed var(--border);
    padding-top: 0.9rem;
    display: grid;
    gap: 0.75rem;
  }

  .aprobacion-guia {
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .campo-comentario {
    margin-bottom: 0;
  }

  .acciones-aprobacion {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .btn-peligro {
    background: transparent;
    color: var(--peligro);
    border-color: var(--peligro);
  }

  .btn-peligro:hover {
    background: var(--peligro-suave);
  }

  /* Salida del nodo (estilo "output" de Power Automate) */
  .nodo-salida {
    margin-top: 0.8rem;
    border-top: 1px dashed var(--border);
    padding-top: 0.7rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    .nodo-salida {
      animation: aparecer 0.45s var(--ease);
    }
  }

  @keyframes aparecer {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
  }

  .salida-etiqueta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
