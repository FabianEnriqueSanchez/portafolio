  }

  .salida-datos {
    margin: 0.4rem 0 0;
    display: grid;
    gap: 0.25rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .salida-datos :global(.salida-fila) {
    display: flex;
    gap: 0.6rem;
  }

  .salida-datos :global(dt) {
    flex: none;
    color: var(--accent-hover);
  }

  .salida-datos :global(dt)::after {
