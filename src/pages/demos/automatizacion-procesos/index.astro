  }

  .salida-datos :global(dd) {
    margin: 0;
    color: var(--muted);
    overflow-wrap: anywhere;
  }

  /* Cierre del flujo */
  .flujo-fin {
    margin-top: 1.25rem;
    padding: 1rem 1.1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: var(--muted);
  }

  /* ---------- Paso 3: seguimiento ---------- */
  .seguimiento {
    padding-block: clamp(3rem, 7vw, 5rem);
  }

  .seguimiento-cabecera {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .seguimiento-cabecera .paso-descripcion {
    margin-bottom: 0;
  }

  .metricas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .metrica {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.2rem;
  }

  .metrica-valor {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    line-height: 1.1;
  }

  .metrica-nombre {
    color: var(--muted);
    font-size: var(--text-xs);
    margin-top: 0.3rem;
  }

  .tabla-envoltura {
    overflow-x: auto;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .tabla-envoltura table {
    width: 100%;
    min-width: 680px;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  /* :global(): las filas de la tabla se crean por JS y no llevan
     la clase de ámbito que Astro añade al marcado del componente */
  .tabla-envoltura :global(th),
  .tabla-envoltura :global(td) {
    text-align: left;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--border);
  }

  .tabla-envoltura thead th {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--faint);
    background: var(--bg-soft);
    font-weight: 600;
  }

  .tabla-envoltura tbody :global(th[scope="row"]) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--muted);
  }

  .tabla-envoltura tbody :global(tr:last-child th),
  .tabla-envoltura tbody :global(tr:last-child td) {
    border-bottom: none;
  }

  .fila-vacia td {
    text-align: center;
    color: var(--faint);
    padding-block: 2.2rem;
  }

  :global(.badge) {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.65rem;
    border-radius: 999px;
    font-size: var(--text-xs);
    font-weight: 600;
    white-space: nowrap;
  }

  :global(.badge[data-decision="aprobada"]) {
    background: var(--accent-soft);
    color: var(--accent-hover);
  }

  :global(.badge[data-decision="rechazada"]) {
    background: var(--peligro-suave);
    color: var(--peligro);
  }

  :global(.celda-duracion) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    white-space: nowrap;
  }
</style>

<script>
  // ============================================================
  //  Simulación del flujo de aprobación (100 % en el navegador)
  // ============================================================
  type Categoria = "Hardware" | "Software" | "Accesos" | "Otro";
  type Prioridad = "Baja" | "Media" | "Alta";
  type Decision = "aprobada" | "rechazada";
  type EstadoNodo = "pendiente" | "en-curso" | "completado" | "omitido";
  type Fase = "reposo" | "ejecutando" | "esperando" | "completado";

  interface Solicitud {
    id: string;
    hora: string;
    solicitante: string;
    categoria: Categoria;
    prioridad: Prioridad;
    descripcion: string;
  }

  interface Resolucion {
    decision: Decision;
    comentario: string;
  }

  const RESPONSABLES: Record<Categoria, string> = {
    Hardware: "Soporte técnico",
    Software: "Desarrollo",
    Accesos: "Infraestructura",
    Otro: "Mesa de ayuda",
  };

  const TEXTO_ESTADO: Record<EstadoNodo, string> = {
    pendiente: "Pendiente",
    "en-curso": "En curso",
    completado: "Completado",
    omitido: "Omitido",
  };

  const TEXTO_FASE: Record<Fase, string> = {
    reposo: "En espera de una solicitud",
    ejecutando: "Ejecutando flujo…",
    esperando: "Esperando la decisión del responsable",
    completado: "Flujo completado",
  };

  const NODOS = [
    "recepcion",
    "condicion",
    "notificar-jefe",
    "asignar",
    "aprobacion",
    "correo",
    "registro",
  ] as const;

  const NOMBRE_APROBACION = "Esperando aprobación del responsable";
  const NOMBRE_CORREO = "Correo enviado al solicitante";

  function q<T extends Element>(
    selector: string,
    raiz: ParentNode = document,
  ): T {
    const elemento = raiz.querySelector<T>(selector);
    if (!elemento) throw new Error(`Elemento no encontrado: ${selector}`);
    return elemento;
  }

  // ---------- Referencias ----------
  const formulario = q<HTMLFormElement>("#form-solicitud");
  const campos = q<HTMLFieldSetElement>("[data-campos]");
  const campoSolicitante = q<HTMLInputElement>("#campo-solicitante");
  const campoCategoria = q<HTMLSelectElement>("#campo-categoria");
  const campoDescripcion = q<HTMLTextAreaElement>("#campo-descripcion");
  const grupoPrioridad = q<HTMLFieldSetElement>("#grupo-prioridad");
  const errorSolicitante = q<HTMLElement>("#error-solicitante");
  const errorCategoria = q<HTMLElement>("#error-categoria");
  const errorPrioridad = q<HTMLElement>("#error-prioridad");
  const errorDescripcion = q<HTMLElement>("#error-descripcion");
  const panel = q<HTMLElement>("#panel-flujo");
  const textoFase = q<HTMLElement>("[data-texto-fase]");
  const zonaAprobacion = q<HTMLElement>("[data-zona-aprobacion]");
  const campoComentario = q<HTMLInputElement>("#campo-comentario");
  const btnAprobar = q<HTMLButtonElement>("[data-aprobar]");
  const btnRechazar = q<HTMLButtonElement>("[data-rechazar]");
  const finFlujo = q<HTMLElement>("[data-fin]");
  const cuerpoTabla = q<HTMLTableSectionElement>("#cuerpo-seguimiento");
  const filaVacia = q<HTMLTableRowElement>("#fila-vacia");
  const zonaAnuncios = q<HTMLElement>("[data-anuncios]");
  const metricaTotal = q<HTMLElement>('[data-metrica="total"]');
  const metricaAprobadas = q<HTMLElement>('[data-metrica="aprobadas"]');
  const metricaTiempo = q<HTMLElement>('[data-metrica="tiempo"]');
  const botonesNueva = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".js-nueva-solicitud"),
  );

  // ---------- Estado de la sesión ----------
  let contador = 0;
  let enEjecucion = false;
  let resolverDecision: ((valor: Resolucion) => void) | null = null;
  let totalSolicitudes = 0;
  let totalAprobadas = 0;
  let sumaDuraciones = 0;

  // ---------- Utilidades ----------
  const reducirMovimiento = (): boolean =>
    window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const pausa = (ms: number): Promise<void> =>
    new Promise((resolver) => {
      window.setTimeout(resolver, reducirMovimiento() ? 0 : ms);
    });

  const horaActual = (): string =>
    new Date().toLocaleTimeString("es-CO", {
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false,
    });

  const formatearSegundos = (valor: number): string =>
    valor.toLocaleString("es-CO", {
      minimumFractionDigits: 1,
      maximumFractionDigits: 1,
    });

  const truncar = (texto: string, maximo: number): string =>
    texto.length > maximo ? `${texto.slice(0, maximo - 1)}…` : texto;

  function anunciar(mensaje: string): void {
    zonaAnuncios.textContent = mensaje;
  }

  function fijarFase(fase: Fase): void {
    panel.dataset.fase = fase;
    textoFase.textContent = TEXTO_FASE[fase];
  }

  // ---------- Nodos del diagrama ----------
  function fijarEstado(nombre: string, estado: EstadoNodo): void {
    const nodo = q<HTMLElement>(`[data-nodo="${nombre}"]`);
    nodo.dataset.estado = estado;
    q<HTMLElement>("[data-estado-texto]", nodo).textContent =
      TEXTO_ESTADO[estado];
    if (estado !== "pendiente") {
      const hora = q<HTMLElement>("[data-hora]", nodo);
      hora.hidden = false;
      hora.textContent = horaActual();
    }
    if (estado === "en-curso") {
      nodo.scrollIntoView({
        block: "nearest",
        behavior: reducirMovimiento() ? "auto" : "smooth",
      });
    }
  }

  function fijarSalida(
    nombre: string,
    pares: ReadonlyArray<readonly [string, string]>,
  ): void {
    const nodo = q<HTMLElement>(`[data-nodo="${nombre}"]`);
    const salida = q<HTMLElement>("[data-salida]", nodo);
    const datos = q<HTMLElement>("[data-salida-datos]", nodo);
    datos.replaceChildren(
      ...pares.map(([clave, valor]) => {
        const fila = document.createElement("div");
        fila.className = "salida-fila";
        const dt = document.createElement("dt");
        dt.textContent = clave;
        const dd = document.createElement("dd");
        dd.textContent = valor;
        fila.append(dt, dd);
        return fila;
      }),
    );
    salida.hidden = false;
  }

  function marcarRama(esAlta: boolean): void {
    q<HTMLElement>(`[data-rama="${esAlta ? "si" : "no"}"]`).dataset.activa =
      "true";
  }

  function reiniciarDiagrama(): void {
    NODOS.forEach((nombre) => {
      const nodo = q<HTMLElement>(`[data-nodo="${nombre}"]`);
      nodo.dataset.estado = "pendiente";
      q<HTMLElement>("[data-estado-texto]", nodo).textContent =
        TEXTO_ESTADO.pendiente;
      const hora = q<HTMLElement>("[data-hora]", nodo);
      hora.hidden = true;
      hora.textContent = "";
      q<HTMLElement>("[data-salida]", nodo).hidden = true;
      q<HTMLElement>("[data-salida-datos]", nodo).replaceChildren();
    });
    q<HTMLElement>('[data-nodo="aprobacion"] [data-nombre]').textContent =
      NOMBRE_APROBACION;
    q<HTMLElement>('[data-nodo="correo"] [data-nombre]').textContent =
      NOMBRE_CORREO;
    document
      .querySelectorAll<HTMLElement>("[data-rama]")
      .forEach((rama) => rama.removeAttribute("data-activa"));
    document
      .querySelectorAll<HTMLElement>("[data-mapa] li")
      .forEach((fila) => fila.removeAttribute("data-activa"));
    zonaAprobacion.hidden = true;
    finFlujo.hidden = true;
  }

  // ---------- Aprobación interactiva ----------
  function esperarDecision(): Promise<Resolucion> {
    return new Promise((resolver) => {
      resolverDecision = resolver;
    });
  }

  function decidir(decision: Decision): void {
    if (!resolverDecision) return;
    const entregar = resolverDecision;
    resolverDecision = null;
    const comentario = campoComentario.value.trim();
    campoComentario.value = "";
    entregar({ decision, comentario });
  }

  btnAprobar.addEventListener("click", () => decidir("aprobada"));
  btnRechazar.addEventListener("click", () => decidir("rechazada"));

  // ---------- Seguimiento ----------
  function actualizarMetricas(): void {
    metricaTotal.textContent = String(totalSolicitudes);
    if (totalSolicitudes === 0) {
      metricaAprobadas.textContent = "—";
      metricaTiempo.textContent = "—";
      return;
    }
    metricaAprobadas.textContent = `${Math.round(
      (totalAprobadas / totalSolicitudes) * 100,
    )} %`;
    metricaTiempo.textContent = `${formatearSegundos(
      sumaDuraciones / totalSolicitudes,
    )} s`;
  }

  function agregarRegistro(
    datos: Solicitud,
    responsable: string,
    decision: Decision,
    duracion: number,
  ): void {
    filaVacia.hidden = true;
    const fila = document.createElement("tr");

    const celdaId = document.createElement("th");
    celdaId.scope = "row";
    celdaId.textContent = datos.id;
    fila.append(celdaId);

    [datos.solicitante, datos.categoria, datos.prioridad, responsable].forEach(
      (texto) => {
        const celda = document.createElement("td");
        celda.textContent = texto;
        fila.append(celda);
      },
    );

    const celdaEstado = document.createElement("td");
    const insignia = document.createElement("span");
    insignia.className = "badge";
    insignia.dataset.decision = decision;
    insignia.textContent = decision === "aprobada" ? "Aprobada" : "Rechazada";
    celdaEstado.append(insignia);
    fila.append(celdaEstado);

    const celdaDuracion = document.createElement("td");
    celdaDuracion.className = "celda-duracion";
    celdaDuracion.textContent = `${formatearSegundos(duracion)} s`;
    fila.append(celdaDuracion);

    cuerpoTabla.append(fila);

    totalSolicitudes += 1;
    if (decision === "aprobada") totalAprobadas += 1;
    sumaDuraciones += duracion;
    actualizarMetricas();
  }

  // ---------- Ejecución del flujo ----------
  function bloquearFormulario(bloquear: boolean): void {
    campos.disabled = bloquear;
    botonesNueva.forEach((boton) => {
      boton.disabled = bloquear;
    });
  }

  async function ejecutarFlujo(datos: Solicitud): Promise<void> {
    enEjecucion = true;
    bloquearFormulario(true);
    reiniciarDiagrama();
    fijarFase("ejecutando");

    const rect = panel.getBoundingClientRect();
    if (rect.top < 0 || rect.top > window.innerHeight * 0.6) {
      panel.scrollIntoView({
        block: "start",
        behavior: reducirMovimiento() ? "auto" : "smooth",
      });
    }
    panel.focus({ preventScroll: true });

    const inicio = performance.now();

    // 1. Desencadenador
    fijarEstado("recepcion", "en-curso");
    await pausa(700);
    fijarEstado("recepcion", "completado");
    fijarSalida("recepcion", [
      ["id", datos.id],
      ["hora", datos.hora],
      ["solicitante", datos.solicitante],
      ["descripción", truncar(datos.descripcion, 60)],
    ]);
    anunciar(`Solicitud ${datos.id} recibida.`);

    // 2. Condición
    fijarEstado("condicion", "en-curso");
    await pausa(800);
    const esAlta = datos.prioridad === "Alta";
    marcarRama(esAlta);
    fijarEstado("condicion", "completado");
    fijarSalida("condicion", [
      ["expresión", 'prioridad es "Alta"'],
      ["resultado", esAlta ? "SÍ" : "NO"],
    ]);

    // 3. Rama SÍ: notificar al jefe de área
    if (esAlta) {
      fijarEstado("notificar-jefe", "en-curso");
      await pausa(650);
      fijarEstado("notificar-jefe", "completado");
      fijarSalida("notificar-jefe", [
        ["destinatario", "Jefe de área"],
        ["canal", "Correo y Teams"],
      ]);
    } else {
      fijarEstado("notificar-jefe", "omitido");
    }

    // 4. Asignar responsable según categoría
    fijarEstado("asignar", "en-curso");
    await pausa(900);
    const responsable = RESPONSABLES[datos.categoria];
    q<HTMLElement>(
      `[data-mapa] li[data-categoria="${datos.categoria}"]`,
    ).dataset.activa = "true";
    fijarEstado("asignar", "completado");
    fijarSalida("asignar", [
      ["categoría", datos.categoria],
      ["responsable", responsable],
    ]);

    // 5. Aprobación interactiva: el flujo se detiene aquí
    q<HTMLElement>('[data-nodo="aprobacion"] [data-nombre]').textContent =
      `Esperando aprobación de ${responsable}`;
    fijarEstado("aprobacion", "en-curso");
    fijarFase("esperando");
    zonaAprobacion.hidden = false;
    btnAprobar.focus();
    anunciar(
      `Esperando aprobación de ${responsable}. Decide como responsable: aprobar o rechazar.`,
    );
    const { decision, comentario } = await esperarDecision();
    // El foco suele estar en Aprobar/Rechazar: se mueve al panel del flujo
    // (tabindex="-1") antes de ocultar la zona para que no caiga en <body>.
    if (zonaAprobacion.contains(document.activeElement)) {
      panel.focus({ preventScroll: true });
    }
    zonaAprobacion.hidden = true;
    fijarFase("ejecutando");
    fijarEstado("aprobacion", "completado");
    const salidaAprobacion: Array<[string, string]> = [
      ["decisión", decision === "aprobada" ? "Aprobada" : "Rechazada"],
      ["responsable", responsable],
    ];
    if (comentario) salidaAprobacion.push(["comentario", comentario]);
    fijarSalida("aprobacion", salidaAprobacion);
    anunciar(`Solicitud ${datos.id} ${decision} por ${responsable}.`);

    // 6. Notificación al solicitante
    fijarEstado("correo", "en-curso");
    await pausa(800);
    fijarEstado("correo", "completado");
    q<HTMLElement>('[data-nodo="correo"] [data-nombre]').textContent =
      `Correo enviado al solicitante: ${decision}`;
    fijarSalida("correo", [
      ["para", datos.solicitante],
      ["asunto", `Tu solicitud ${datos.id} fue ${decision}`],
    ]);

    // 7. Registro en la lista de seguimiento
    fijarEstado("registro", "en-curso");
    await pausa(650);
    const duracion = (performance.now() - inicio) / 1000;
    fijarEstado("registro", "completado");
    fijarSalida("registro", [
      ["lista", "Seguimiento de solicitudes"],
      ["duración", `${formatearSegundos(duracion)} s`],
    ]);

    agregarRegistro(datos, responsable, decision, duracion);
    fijarFase("completado");
    finFlujo.hidden = false;
    anunciar(
      `Flujo completado. Solicitud ${datos.id} registrada en la lista de seguimiento.`,
    );

    enEjecucion = false;
    bloquearFormulario(false);
  }

  // ---------- Validación del formulario ----------
  function mostrarError(
    campo: HTMLElement,
    error: HTMLElement,
    mensaje: string,
  ): void {
    error.textContent = mensaje;
    error.hidden = false;
    campo.setAttribute("aria-invalid", "true");
  }

  function limpiarError(campo: HTMLElement, error: HTMLElement): void {
    error.hidden = true;
    error.textContent = "";
    campo.removeAttribute("aria-invalid");
  }

  function limpiarErrores(): void {
    limpiarError(campoSolicitante, errorSolicitante);
    limpiarError(campoCategoria, errorCategoria);
    limpiarError(campoDescripcion, errorDescripcion);
    errorPrioridad.hidden = true;
    errorPrioridad.textContent = "";
    grupoPrioridad.removeAttribute("data-invalido");
  }

  campoSolicitante.addEventListener("input", () => {
    if (campoSolicitante.value.trim())
      limpiarError(campoSolicitante, errorSolicitante);
  });
  campoCategoria.addEventListener("change", () => {
    if (campoCategoria.value) limpiarError(campoCategoria, errorCategoria);
  });
  campoDescripcion.addEventListener("input", () => {
    if (campoDescripcion.value.trim().length >= 10) {
      limpiarError(campoDescripcion, errorDescripcion);
    }
  });
  formulario
    .querySelectorAll<HTMLInputElement>('input[name="prioridad"]')
    .forEach((radio) => {
      radio.addEventListener("change", () => {
        errorPrioridad.hidden = true;
        errorPrioridad.textContent = "";
        grupoPrioridad.removeAttribute("data-invalido");
      });
    });

  formulario.addEventListener("submit", (evento) => {
    evento.preventDefault();
    if (enEjecucion) return;

    let primerFoco: HTMLElement | null = null;

    const solicitante = campoSolicitante.value.trim();
    if (!solicitante) {
      mostrarError(
        campoSolicitante,
        errorSolicitante,
        "Escribe el nombre de quien solicita.",
      );
      primerFoco = campoSolicitante;
    } else {
      limpiarError(campoSolicitante, errorSolicitante);
    }

    const categoria = campoCategoria.value;
    if (!categoria) {
      mostrarError(campoCategoria, errorCategoria, "Selecciona una categoría.");
      if (!primerFoco) primerFoco = campoCategoria;
    } else {
      limpiarError(campoCategoria, errorCategoria);
    }

    const radio = formulario.querySelector<HTMLInputElement>(
      'input[name="prioridad"]:checked',
    );
    if (!radio) {
      errorPrioridad.textContent = "Selecciona una prioridad.";
      errorPrioridad.hidden = false;
      grupoPrioridad.dataset.invalido = "true";
      if (!primerFoco) {
        primerFoco = q<HTMLInputElement>('input[name="prioridad"]', formulario);
      }
    } else {
      errorPrioridad.hidden = true;
      errorPrioridad.textContent = "";
      grupoPrioridad.removeAttribute("data-invalido");
    }

    const descripcion = campoDescripcion.value.trim();
    if (descripcion.length < 10) {
      mostrarError(
        campoDescripcion,
        errorDescripcion,
        "Describe el caso con al menos 10 caracteres.",
      );
      if (!primerFoco) primerFoco = campoDescripcion;
    } else {
      limpiarError(campoDescripcion, errorDescripcion);
    }

    if (
      primerFoco ||
      !solicitante ||
      !categoria ||
      !radio ||
      descripcion.length < 10
    ) {
      primerFoco?.focus();
      return;
    }

    contador += 1;
    const solicitud: Solicitud = {
      id: `SOL-${String(contador).padStart(3, "0")}`,
      hora: horaActual(),
      solicitante,
      categoria: categoria as Categoria,
      prioridad: radio.value as Prioridad,
      descripcion,
    };
    void ejecutarFlujo(solicitud);
  });

  // ---------- Nueva solicitud (conserva la tabla) ----------
  botonesNueva.forEach((boton) => {
    boton.addEventListener("click", () => {
      if (enEjecucion) return;
      formulario.reset();
      limpiarErrores();
      reiniciarDiagrama();
      fijarFase("reposo");
      anunciar("Formulario reiniciado. La lista de seguimiento se conserva.");
      campoSolicitante.focus();
    });
  });
</script>
