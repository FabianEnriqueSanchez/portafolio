---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { withBase } from "../../../lib/utils";

// Datos de presentación de las tarjetas (la física de la simulación vive en el <script>).
const sensores = [
  {
    id: "temperatura",
    tag: "TT-101",
    nombre: "Temperatura",
    unidad: "°C",
    inicial: "24.0",
    condicion: "salta al superar el umbral",
    rango: { min: 20, max: 40, paso: 0.5 },
    umbralInicial: "30.0",
    ariaGrafica:
      "Tendencia de la temperatura: gráfica de las últimas 40 lecturas frente al umbral de alarma",
  },
  {
    id: "nivel",
    tag: "LT-201",
    nombre: "Nivel de tanque",
    unidad: "%",
    inicial: "62",
    condicion: "salta al caer bajo el umbral",
    rango: { min: 10, max: 90, paso: 1 },
    umbralInicial: "35",
    ariaGrafica:
      "Tendencia del nivel de tanque: gráfica de las últimas 40 lecturas frente al umbral de alarma",
  },
  {
    id: "vibracion",
    tag: "VT-301",
    nombre: "Vibración",
    unidad: "mm/s",
    inicial: "3.2",
    condicion: "salta al superar el umbral",
    rango: { min: 2, max: 11, paso: 0.5 },
    umbralInicial: "7.5",
    ariaGrafica:
      "Tendencia de la vibración: gráfica de las últimas 40 lecturas frente al umbral de alarma",
  },
];

const actuadores = [
  {
    id: "bomba",
    nombre: "Bomba de recirculación",
    regla: "En automático arranca si el nivel cae bajo el umbral.",
  },
  {
    id: "ventilacion",
    nombre: "Ventilación",
    regla: "En automático arranca si la temperatura supera el umbral.",
  },
  {
    id: "sirena",
    nombre: "Alarma sonora",
    regla:
      "En automático se activa con cualquier alarma. Indicación solo visual.",
  },
];
---

<BaseLayout
  titulo="Demo: Sistema de control — simulación"
  descripcion="Simulación en el navegador del sistema de control industrial desarrollado con Java y Arduino: sensores con umbrales, actuadores por relé, modo automático y monitor serie."
>
  <Header />

  <main id="contenido" tabindex="-1">
    <!-- ======================= Hero ======================= -->
    <section class="hero">
      <div class="container reveal">
        <p class="eyebrow">Demo interactiva</p>
        <h1 class="hero-titulo">Sistema de control — simulación</h1>
        <p class="hero-intro">
          Panel de control estilo SCADA que replica el comportamiento del
          sistema real en Java + Arduino: telemetría de sensores, actuadores por
          relé y reglas de control automático.
        </p>
        <p class="aviso" role="note">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 8v5M12 16.5v.5"></path>
          </svg>
          Simulación en el navegador: no hay hardware conectado.
        </p>
        <div class="hero-enlaces">
          <a class="enlace-volver" href={withBase("/") + "#proyectos"}>
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <path d="M19 12H5M11 18l-6-6 6-6"></path>
            </svg>
            Volver a proyectos
          </a>
          <a class="btn btn-ghost" href={withBase("docs/sistema-control/")}>
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
              <path
                d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"
              ></path>
            </svg>
            Documentación
          </a>
        </div>
      </div>
    </section>

    <!-- ======================= Panel de control ======================= -->
    <section class="panel-seccion" aria-labelledby="titulo-panel">
      <div class="container">
        <h2 id="titulo-panel" class="sr-solo">Panel de control</h2>

        <!-- Barra de estado: texto visible (sin aria-live) + nodo role=status reservado
             a transiciones de alarma + pausa y reinicio -->
        <div class="barra-estado" data-rol="barra-estado" data-alarma="false">
          <span class="resumen-led" aria-hidden="true"></span>
          <p class="resumen-texto" data-rol="resumen-visible">
            Sistema estable: sin alarmas activas.
          </p>
          <p class="sr-solo" data-rol="resumen" role="status"></p>
          <button
            type="button"
            class="btn btn-ghost btn-pausar"
            data-rol="pausar"
            aria-pressed="false"
          >
            <svg
              data-icono="pausa"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <path d="M10 5v14M14 5v14"></path>
            </svg>
            <svg
              data-icono="reanudar"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M7 5l12 7-12 7z"></path>
            </svg>
            <span data-rol="pausar-texto">Pausar simulación</span>
          </button>
          <button
            type="button"
            class="btn btn-ghost btn-reiniciar"
            data-rol="reiniciar"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 12a9 9 0 1 1-2.64-6.36"></path>
              <path d="M21 3v6h-6"></path>
            </svg>
            Reiniciar simulación
          </button>
        </div>

        <!-- Sensores -->
        <div class="fila-sensores">
          {
            sensores.map((s) => (
              <article
                class="tarjeta sensor"
                data-sensor={s.id}
                data-alarma="false"
                aria-labelledby={`titulo-${s.id}`}
              >
                <header class="tarjeta-cab">
                  <span class="tag" aria-hidden="true">
                    {s.tag}
                  </span>
                  <h3 id={`titulo-${s.id}`}>{s.nombre}</h3>
                  <span class="badge-estado">
                    <span class="led" aria-hidden="true" />
                    <span data-rol="estado">OK</span>
                  </span>
                </header>
                <div class="sensor-cuerpo">
                  <p class="valor">
                    <span data-rol="valor">{s.inicial}</span>
                    <span class="unidad">{s.unidad}</span>
                  </p>
                  <canvas
                    width="300"
                    height="64"
                    role="img"
                    aria-label={s.ariaGrafica}
                  />
                  <div class="umbral">
                    <div class="umbral-fila">
                      <label for={`umbral-${s.id}`}>
                        Umbral de alarma{" "}
                        <span class="umbral-cond">· {s.condicion}</span>
                      </label>
                      <output for={`umbral-${s.id}`} data-rol="umbral-valor">
                        {s.umbralInicial} {s.unidad}
                      </output>
                    </div>
                    <input
                      type="range"
                      id={`umbral-${s.id}`}
                      min={s.rango.min}
                      max={s.rango.max}
                      step={s.rango.paso}
                      value={s.umbralInicial}
                    />
                  </div>
                </div>
              </article>
            ))
          }
        </div>

        <div class="fila-control">
          <div class="columna-control">
            <!-- Modo de operación -->
            <section class="tarjeta" aria-labelledby="titulo-modo">
              <header class="tarjeta-cab">
                <span class="tag" aria-hidden="true">CTRL</span>
                <h3 id="titulo-modo">Modo de operación</h3>
              </header>
              <div class="tarjeta-cuerpo">
                <fieldset class="modo">
                  <legend class="sr-solo">Modo de operación</legend>
                  <div class="segmentado">
                    <label class="segmento">
                      <input type="radio" name="modo" value="manual" checked />
                      <span>Manual</span>
                    </label>
                    <label class="segmento">
                      <input type="radio" name="modo" value="auto" />
                      <span>Automático</span>
                    </label>
                  </div>
                </fieldset>
                <p class="nota-modo" data-rol="nota-modo" hidden>
                  En automático, los actuadores obedecen las reglas de control y
                  los interruptores quedan deshabilitados.
                </p>
              </div>
            </section>

            <!-- Actuadores -->
            <section class="tarjeta" aria-labelledby="titulo-actuadores">
              <header class="tarjeta-cab">
                <span class="tag" aria-hidden="true">RLY</span>
                <h3 id="titulo-actuadores">Actuadores</h3>
              </header>
              <ul class="lista-actuadores">
                {
                  actuadores.map((a) => (
                    <li>
                      <span class="actuador-info">
                        <span class="actuador-nombre" id={`lbl-${a.id}`}>
                          {a.nombre}
                        </span>
                        <span class="actuador-regla" id={`regla-${a.id}`}>
                          {a.regla}
                        </span>
                      </span>
                      <button
                        type="button"
                        class="interruptor"
                        role="switch"
                        aria-checked="false"
                        aria-labelledby={`lbl-${a.id}`}
                        aria-describedby={`regla-${a.id}`}
                        data-actuador={a.id}
                      >
                        <span class="interruptor-pista" aria-hidden="true">
                          <span class="interruptor-bola" />
                        </span>
                        <span
                          class="interruptor-onoff"
                          data-rol="onoff"
                          aria-hidden="true"
                        >
                          OFF
                        </span>
                      </button>
                    </li>
                  ))
                }
              </ul>
            </section>
          </div>

          <!-- Monitor serie -->
          <section class="tarjeta consola" aria-labelledby="titulo-consola">
            <header class="tarjeta-cab">
              <span class="tag" aria-hidden="true">TTY</span>
              <h3 id="titulo-consola">Monitor serie</h3>
              <span class="cab-extra" aria-hidden="true">9600 baudios</span>
            </header>
            <div
              class="consola-salida"
              data-rol="salida"
              role="log"
              aria-live="off"
              tabindex="0"
              aria-label="Salida del monitor serie: registro de eventos de la simulación"
            >
            </div>
            <footer class="consola-pie">
              <button
                type="button"
                class="btn-mini"
                data-rol="autoscroll"
                aria-pressed="true"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M12 5v14M6 13l6 6 6-6"></path>
                </svg>
                Autodesplazamiento
              </button>
              <button type="button" class="btn-mini" data-rol="limpiar">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  aria-hidden="true"
                >
                  <path
                    d="M3 6h18M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"
                  ></path>
                </svg>
                Limpiar
              </button>
            </footer>
          </section>
        </div>
      </div>
    </section>

    <!-- ======================= Contexto ======================= -->
    <section class="section section-alt" aria-labelledby="titulo-relacion">
      <div class="container reveal">
        <p class="eyebrow">Contexto</p>
        <h2 id="titulo-relacion" class="section-title">
          Cómo se relaciona con el sistema real
        </h2>
        <ul class="relacion-lista">
          <li>
            <strong>La aplicación Java</strong> orquesta la lógica de control: lee
            la telemetría por puerto serie, evalúa los umbrales configurados y persiste
            el histórico de lecturas y eventos.
          </li>
          <li>
            <strong>El Arduino</strong> muestrea los sensores físicos (temperatura,
            nivel y vibración) y conmuta los relés de bomba, ventilación y alarma
            según las órdenes que recibe.
          </li>
          <li>
            <strong>Esta simulación</strong> replica ese lazo de control en el navegador:
            genera lecturas sintéticas, aplica las mismas reglas automáticas y muestra
            el tráfico en un monitor serie virtual.
          </li>
        </ul>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ---------- Tokens locales: color de alerta accesible en ambos temas ---------- */
  .panel-seccion {
    --alerta: #b42318;
    --alerta-suave: #faeae7;
    padding-block: clamp(1.5rem, 3vw, 2.5rem) clamp(4rem, 8vw, 6rem);
  }

  :global(html[data-theme="dark"]) .panel-seccion {
    --alerta: #f97066;
    --alerta-suave: rgba(249, 112, 102, 0.14);
  }

  .sr-solo {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ---------- Hero ---------- */
  .hero {
    padding-block: clamp(3.5rem, 7vw, 5rem) clamp(1.5rem, 3vw, 2.5rem);
  }

  .hero-titulo {
    font-size: clamp(2rem, 5.5vw, var(--text-3xl));
    margin-top: 0.6rem;
    max-width: 24ch;
  }

  .hero-intro {
    color: var(--muted);
    max-width: 62ch;
    margin-top: 1rem;
    font-size: var(--text-lg);
  }

  .aviso {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    border: 1px dashed var(--border-strong);
    background: var(--bg-soft);
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
  }

  .hero-enlaces {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.6rem;
  }

  .enlace-volver {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 40px;
    font-size: var(--text-sm);
    color: var(--muted);
    transition: color var(--dur) var(--ease);
  }

  .enlace-volver:hover {
    color: var(--accent);
  }

  /* ---------- Barra de estado ---------- */
  .barra-estado {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
    padding: 0.6rem 0.6rem 0.6rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    margin-bottom: 1.1rem;
  }

  .resumen-led {
    flex: none;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
  }

  .barra-estado[data-alarma="true"] .resumen-led {
    background: var(--alerta);
  }

  .resumen-texto {
    flex: 1;
    min-width: 220px;
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .barra-estado[data-alarma="true"] .resumen-texto {
    color: var(--alerta);
    font-weight: 560;
  }

  .btn-pausar {
    margin-left: auto;
  }

  /* El estado del botón (aria-pressed) decide qué icono se ve */
  .btn-pausar[aria-pressed="false"] [data-icono="reanudar"],
  .btn-pausar[aria-pressed="true"] [data-icono="pausa"] {
    display: none;
  }

  /* ---------- Tarjetas tipo instrumento ---------- */
  .tarjeta {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    transition: border-color var(--dur) var(--ease);
  }

  .tarjeta-cab {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.9rem;
    background: var(--bg-soft);
    border-bottom: 1px solid var(--border);
  }

  .tarjeta-cab h3 {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 620;
    letter-spacing: 0;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--faint);
    background: var(--surface);
    border: 1px solid var(--border-strong);
    padding: 0.1rem 0.45rem;
    border-radius: 6px;
    white-space: nowrap;
  }

  .cab-extra {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--faint);
    white-space: nowrap;
  }

  .tarjeta-cuerpo {
    padding: 1rem;
  }

  /* ---------- Sensores ---------- */
  .fila-sensores {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(232px, 1fr));
    gap: 1.1rem;
  }

  .badge-estado {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--accent);
    background: var(--accent-soft);
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
  }

  .led {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: currentColor;
  }

  .sensor[data-alarma="true"] {
    border-color: var(--alerta);
  }

  .sensor[data-alarma="true"] .badge-estado {
    color: var(--alerta);
    background: var(--alerta-suave);
  }

  /* Parpadeo sobrio del led en alarma, solo si el usuario acepta movimiento */
  @media (prefers-reduced-motion: no-preference) {
    .sensor[data-alarma="true"] .led {
      animation: parpadeo 1.6s var(--ease) infinite;
    }
  }

  @keyframes parpadeo {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.35;
    }
  }

  .sensor-cuerpo {
    display: grid;
    gap: 0.8rem;
    padding: 1rem 1rem 0.85rem;
  }

  .valor {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: clamp(2rem, 5vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .sensor[data-alarma="true"] .valor {
    color: var(--alerta);
  }

  .unidad {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0;
  }

  .sensor canvas {
    display: block;
    width: 100%;
    height: 64px;
  }

  .umbral {
    border-top: 1px dashed var(--border);
    padding-top: 0.65rem;
  }

  .umbral-fila {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.6rem;
    font-size: var(--text-xs);
  }

  .umbral-fila label {
    color: var(--muted);
  }

  .umbral-cond {
    color: var(--faint);
  }

  .umbral-fila output {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    color: var(--text);
    white-space: nowrap;
  }

  .umbral input[type="range"] {
    width: 100%;
    height: 2.5rem;
    margin: 0;
    accent-color: var(--accent);
    cursor: pointer;
  }

  /* ---------- Fila de control ---------- */
  .fila-control {
    display: grid;
    grid-template-columns: minmax(290px, 370px) 1fr;
    gap: 1.1rem;
    margin-top: 1.1rem;
    align-items: stretch;
  }

  .columna-control {
    display: grid;
    gap: 1.1rem;
    align-content: start;
  }

  @media (max-width: 900px) {
    .fila-control {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- Modo ---------- */
  .modo {
    border: none;
    padding: 0;
    margin: 0;
  }

  .segmentado {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 4px;
  }

  .segmento {
    position: relative;
  }

  .segmento input {
    position: absolute;
    inset: 0;
    opacity: 0;
    margin: 0;
    cursor: pointer;
  }

  .segmento span {
    display: grid;
    place-items: center;
    min-height: 40px;
    border-radius: calc(var(--radius-sm) - 3px);
    font-size: var(--text-sm);
    font-weight: 560;
    color: var(--muted);
    transition:
      background var(--dur) var(--ease),
      color var(--dur) var(--ease);
  }

  .segmento input:checked + span {
    background: var(--surface);
    color: var(--text);
    box-shadow: var(--shadow);
  }

  .segmento input:focus-visible + span {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .nota-modo {
    margin-top: 0.8rem;
    font-size: var(--text-xs);
    color: var(--muted);
    background: var(--accent-soft);
    border-left: 3px solid var(--accent);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: 0.55rem 0.8rem;
  }

  /* ---------- Actuadores ---------- */
  .lista-actuadores {
    list-style: none;
    margin: 0;
    padding: 0.2rem 0;
  }

  .lista-actuadores li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.65rem 1rem;
  }

  .lista-actuadores li + li {
    border-top: 1px solid var(--border);
  }

  .actuador-nombre {
    display: block;
    font-size: var(--text-sm);
    font-weight: 560;
  }

  .actuador-regla {
    display: block;
    font-size: var(--text-xs);
