  /* ---------- Relación con el sistema real ---------- */
  .relacion-lista {
    list-style: none;
    counter-reset: paso;
    padding: 0;
    margin-top: 2rem;
    display: grid;
    gap: 1rem;
    max-width: 820px;
  }

  .relacion-lista li {
    position: relative;
    padding: 1.05rem 1.25rem 1.05rem 3.4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--muted);
    font-size: var(--text-sm);
    line-height: 1.7;
  }

  .relacion-lista li::before {
    counter-increment: paso;
    content: "0" counter(paso);
    position: absolute;
    left: 1.15rem;
    top: 1.15rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--accent);
  }

  .relacion-lista strong {
    color: var(--text);
    font-weight: 640;
  }
</style>

<script>
  // ============================================================
  //  Simulación del lazo de control (100 % en el navegador).
  //  Random walk con límites por sensor + sesgos que dependen de
  //  los actuadores, para que el modo automático "cierre el lazo":
  //  la ventilación enfría, la bomba rellena el tanque y la bomba
  //  encendida eleva la vibración media.
  // ============================================================

  type ModoOperacion = "manual" | "auto";
  type IdSensor = "temperatura" | "nivel" | "vibracion";
  type IdActuador = "bomba" | "ventilacion" | "sirena";
  type TipoLinea = "info" | "alerta" | "sistema";

  interface ConfigSensor {
    id: IdSensor;
    etiqueta: string; // prefijo en el log: TEMP, NIVEL, VIB
    nombre: string; // nombre legible para el resumen accesible
    unidadLog: string; // sufijo compacto estilo Arduino: C, %, mm/s
    unidadUi: string; // unidad para humanos: °C, %, mm/s
    decimales: number;
    min: number;
    max: number;
    deriva: number; // amplitud del ruido por tick
    inicial: number;
    histeresis: number; // banda muerta de las reglas automáticas
    alarmaSi: "mayor" | "menor";
  }

  interface Sensor {
    cfg: ConfigSensor;
    valor: number;
    umbral: number;
    historial: number[];
    enAlarma: boolean;
    raiz: HTMLElement;
    valorEl: HTMLElement;
    estadoEl: HTMLElement;
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    rango: HTMLInputElement;
    salidaUmbral: HTMLElement;
  }

  interface Actuador {
    id: IdActuador;
    nombre: string;
    boton: HTMLButtonElement;
    estadoEl: HTMLElement;
    encendido: boolean;
  }

  const PERIODO_MS = 800;
  const MAX_HISTORIAL = 40;
  const MAX_LINEAS = 80;
  const TICKS_POR_TELEMETRIA = 4;

  const CONFIGS: ConfigSensor[] = [
    {
      id: "temperatura",
      etiqueta: "TEMP",
      nombre: "temperatura",
      unidadLog: "C",
      unidadUi: "°C",
      decimales: 1,
      min: 15,
      max: 45,
      deriva: 0.45,
      inicial: 24,
      histeresis: 1,
      alarmaSi: "mayor",
    },
    {
      id: "nivel",
      etiqueta: "NIVEL",
      nombre: "nivel de tanque",
      unidadLog: "%",
      unidadUi: "%",
      decimales: 0,
      min: 0,
      max: 100,
      deriva: 1.6,
      inicial: 62,
      histeresis: 5,
      alarmaSi: "menor",
    },
    {
      id: "vibracion",
      etiqueta: "VIB",
      nombre: "vibración",
      unidadLog: "mm/s",
      unidadUi: "mm/s",
      decimales: 1,
      min: 0,
      max: 12,
      deriva: 0.5,
      inicial: 3.2,
      histeresis: 0.5,
      alarmaSi: "mayor",
    },
  ];

  function q<T extends Element>(raiz: ParentNode, selector: string): T {
    const el = raiz.querySelector(selector);
    if (el === null)
      throw new Error(`Demo sistema-control: falta el elemento ${selector}`);
    return el as T;
  }

  // ---------- Referencias al DOM ----------
  const salida = q<HTMLElement>(document, '[data-rol="salida"]');
  const resumenVisible = q<HTMLElement>(
    document,
    '[data-rol="resumen-visible"]',
  );
  const resumenEstado = q<HTMLElement>(document, '[data-rol="resumen"]');
  const barraEstado = q<HTMLElement>(document, '[data-rol="barra-estado"]');
  const notaModo = q<HTMLElement>(document, '[data-rol="nota-modo"]');
  const btnAutoscroll = q<HTMLButtonElement>(
    document,
    '[data-rol="autoscroll"]',
  );
  const btnLimpiar = q<HTMLButtonElement>(document, '[data-rol="limpiar"]');
  const btnReiniciar = q<HTMLButtonElement>(document, '[data-rol="reiniciar"]');
  const btnPausar = q<HTMLButtonElement>(document, '[data-rol="pausar"]');
  const textoPausar = q<HTMLElement>(btnPausar, '[data-rol="pausar-texto"]');
  const radiosModo = Array.from(
    document.querySelectorAll<HTMLInputElement>('input[name="modo"]'),
  );

  const sensores: Sensor[] = CONFIGS.map((cfg) => {
    const raiz = q<HTMLElement>(document, `[data-sensor="${cfg.id}"]`);
    const canvas = q<HTMLCanvasElement>(raiz, "canvas");
    const ctx = canvas.getContext("2d");
    if (ctx === null)
      throw new Error("Demo sistema-control: canvas 2D no disponible");
    const rango = q<HTMLInputElement>(raiz, 'input[type="range"]');
    return {
      cfg,
      valor: cfg.inicial,
      umbral: Number(rango.value),
      historial: [cfg.inicial],
      enAlarma: false,
      raiz,
      valorEl: q<HTMLElement>(raiz, '[data-rol="valor"]'),
      estadoEl: q<HTMLElement>(raiz, '[data-rol="estado"]'),
      canvas,
      ctx,
      rango,
      salidaUmbral: q<HTMLElement>(raiz, "output"),
    };
  });

  const NOMBRES_ACTUADOR: Record<IdActuador, string> = {
    bomba: "bomba",
    ventilacion: "ventilación",
    sirena: "alarma sonora",
  };

  const actuadores: Actuador[] = (
    Object.keys(NOMBRES_ACTUADOR) as IdActuador[]
  ).map((id) => {
    const boton = q<HTMLButtonElement>(document, `[data-actuador="${id}"]`);
    return {
      id,
      nombre: NOMBRES_ACTUADOR[id],
      boton,
      estadoEl: q<HTMLElement>(boton, '[data-rol="onoff"]'),
      encendido: false,
    };
  });

  function sensorPorId(id: IdSensor): Sensor {
    const s = sensores.find((x) => x.cfg.id === id);
    if (!s) throw new Error(`Sensor desconocido: ${id}`);
    return s;
  }

  function actuadorPorId(id: IdActuador): Actuador {
    const a = actuadores.find((x) => x.id === id);
    if (!a) throw new Error(`Actuador desconocido: ${id}`);
    return a;
  }

  // ---------- Estado ----------
  let modo: ModoOperacion = "manual";
  let autoScroll = true;
  let contadorTicks = 0;
  let temporizador: number | null = null;
  let pausadoManual = false;

  // ---------- Utilidades ----------
  function marcaTiempo(): string {
    const d = new Date();
    const p = (n: number, largo = 2): string => String(n).padStart(largo, "0");
    return `${p(d.getHours())}:${p(d.getMinutes())}:${p(d.getSeconds())}.${p(d.getMilliseconds(), 3)}`;
  }

  function conUnidad(valor: number, s: Sensor, paraHumanos: boolean): string {
    const num = valor.toFixed(s.cfg.decimales);
    return paraHumanos
      ? `${num} ${s.cfg.unidadUi}`
      : `${num}${s.cfg.unidadLog}`;
  }

  function registrar(texto: string, tipo: TipoLinea = "info"): void {
    const linea = document.createElement("div");
    linea.className = `linea linea-${tipo}`;
    const hora = document.createElement("span");
    hora.className = "linea-hora";
    hora.textContent = `[${marcaTiempo()}]`;
    linea.append(hora, ` ${texto}`);
    salida.append(linea);
    while (salida.childElementCount > MAX_LINEAS) {
      salida.firstElementChild?.remove();
    }
    if (autoScroll) salida.scrollTop = salida.scrollHeight;
  }

  // ---------- Resumen de estado ----------
  // El texto visible (sin aria-live) puede refrescarse en cada tick; el nodo
  // role=status queda reservado a las transiciones de alarma para no saturar
  // al lector de pantalla con re-anuncios.
  function textoResumen(): string {
    const activas = sensores.filter((s) => s.enAlarma);
    return activas.length === 0
      ? "Sistema estable: sin alarmas activas."
      : `Alarma activa: ${activas
          .map(
            (s) =>
              `${s.cfg.nombre} en ${conUnidad(s.valor, s, true)} (umbral ${conUnidad(s.umbral, s, true)})`,
          )
          .join("; ")}.`;
  }

  function actualizarResumenVisible(): void {
    barraEstado.dataset.alarma = String(sensores.some((s) => s.enAlarma));
    resumenVisible.textContent = textoResumen();
  }

  function actualizarResumen(): void {
    actualizarResumenVisible();
    resumenEstado.textContent = textoResumen();
  }

  // ---------- Alarmas ----------
  function comprobarAlarma(s: Sensor): void {
    const activa =
      s.cfg.alarmaSi === "mayor" ? s.valor > s.umbral : s.valor < s.umbral;
    if (activa === s.enAlarma) return;
    s.enAlarma = activa;
    s.raiz.dataset.alarma = String(activa);
    s.estadoEl.textContent = activa ? "ALARMA" : "OK";
    const simbolo =
      s.cfg.alarmaSi === "mayor" ? (activa ? ">" : "<=") : activa ? "<" : ">=";
    registrar(
      `${activa ? "ALARMA" : "NORMAL"} ${s.cfg.etiqueta}: ${conUnidad(s.valor, s, false)} ${simbolo} umbral ${conUnidad(s.umbral, s, false)}`,
      activa ? "alerta" : "info",
    );
    actualizarResumen();
  }

  // ---------- Sparkline en canvas (lee los tokens del tema al pintar) ----------
  function pintar(s: Sensor): void {
    const dpr = Math.max(1, window.devicePixelRatio || 1);
    const ancho = s.canvas.clientWidth;
    const alto = s.canvas.clientHeight;
    if (ancho === 0 || alto === 0) return;
    const px = Math.round(ancho * dpr);
    const py = Math.round(alto * dpr);
    if (s.canvas.width !== px) s.canvas.width = px;
    if (s.canvas.height !== py) s.canvas.height = py;

    const ctx = s.ctx;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.clearRect(0, 0, ancho, alto);

    const estilos = getComputedStyle(s.raiz);
    const colorLinea = (
      s.enAlarma
        ? estilos.getPropertyValue("--alerta")
        : estilos.getPropertyValue("--accent")
    ).trim();
    const colorUmbral = estilos.getPropertyValue("--faint").trim();
    const colorRejilla = estilos.getPropertyValue("--border").trim();

    const aY = (v: number): number => {
      const t = (v - s.cfg.min) / (s.cfg.max - s.cfg.min);
      return alto - 4 - t * (alto - 8);
    };

    // Línea guía central
    ctx.strokeStyle = colorRejilla;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(0, Math.round(alto / 2) + 0.5);
    ctx.lineTo(ancho, Math.round(alto / 2) + 0.5);
    ctx.stroke();

    // Umbral (discontinuo)
    const yUmbral = aY(s.umbral);
    ctx.strokeStyle = colorUmbral;
    ctx.setLineDash([4, 4]);
    ctx.beginPath();
    ctx.moveTo(0, yUmbral);
    ctx.lineTo(ancho, yUmbral);
    ctx.stroke();
    ctx.setLineDash([]);

    // Serie histórica, alineada a la derecha para que "avance"
    const n = s.historial.length;
    const pasoX = ancho / (MAX_HISTORIAL - 1);
    if (n >= 2) {
      const puntos: Array<[number, number]> = [];
      for (let i = 0; i < n; i++) {
        const v = s.historial[i] ?? s.valor;
        puntos.push([ancho - (n - 1 - i) * pasoX, aY(v)]);
      }
      ctx.strokeStyle = colorLinea;
      ctx.lineWidth = 1.8;
      ctx.lineJoin = "round";
      ctx.lineCap = "round";
      ctx.beginPath();
      puntos.forEach(([x, y], i) => {
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      ctx.stroke();

      const primero = puntos[0];
      const ultimo = puntos[puntos.length - 1];
      if (primero && ultimo) {
        ctx.lineTo(ultimo[0], alto);
        ctx.lineTo(primero[0], alto);
        ctx.closePath();
        ctx.globalAlpha = 0.08;
        ctx.fillStyle = colorLinea;
        ctx.fill();
        ctx.globalAlpha = 1;
      }
    } else {
      ctx.fillStyle = colorLinea;
      ctx.beginPath();
      ctx.arc(ancho - 3, aY(s.valor), 2.2, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  // ---------- Física de la simulación ----------
  function sesgoDe(s: Sensor): number {
    if (s.cfg.id === "temperatura") {
      // Sin ventilación el proceso se calienta poco a poco; con ella, enfría.
      return actuadorPorId("ventilacion").encendido ? -0.35 : 0.12;
    }
    if (s.cfg.id === "nivel") {
      // El proceso consume líquido; la bomba lo repone más rápido de lo que baja.
      return (actuadorPorId("bomba").encendido ? 1.5 : 0) - 0.6;
    }
    // Vibración: reversión a la media (más alta con la bomba en marcha) + golpes ocasionales.
    const media = actuadorPorId("bomba").encendido ? 4.4 : 3.0;
    const golpe = Math.random() < 0.02 ? 2 + Math.random() * 2.5 : 0;
    return (media - s.valor) * 0.08 + golpe;
  }

  function actualizarSensor(s: Sensor): void {
    const ruido = (Math.random() * 2 - 1) * s.cfg.deriva;
    s.valor = Math.min(
      s.cfg.max,
      Math.max(s.cfg.min, s.valor + ruido + sesgoDe(s)),
    );
    s.historial.push(s.valor);
    if (s.historial.length > MAX_HISTORIAL) s.historial.shift();
    s.valorEl.textContent = s.valor.toFixed(s.cfg.decimales);
    pintar(s);
    comprobarAlarma(s);
  }

  // ---------- Actuadores ----------
  function fijarActuador(
    a: Actuador,
    encendido: boolean,
    motivo: string,
    silencioso = false,
  ): void {
    if (a.encendido === encendido) return;
    a.encendido = encendido;
    a.boton.setAttribute("aria-checked", String(encendido));
    a.estadoEl.textContent = encendido ? "ON" : "OFF";
    if (!silencioso) {
      registrar(`RELÉ ${a.nombre} ${encendido ? "ON" : "OFF"} (${motivo})`);
    }
  }

  function aplicarReglasAuto(): void {
    const temp = sensorPorId("temperatura");
    const nivel = sensorPorId("nivel");
    const vent = actuadorPorId("ventilacion");
    const bomba = actuadorPorId("bomba");
    const sirena = actuadorPorId("sirena");

    if (!vent.encendido && temp.valor > temp.umbral) {
      fijarActuador(
        vent,
        true,
        `auto: temp ${temp.valor.toFixed(1)} > ${temp.umbral.toFixed(1)}`,
      );
    } else if (
      vent.encendido &&
      temp.valor < temp.umbral - temp.cfg.histeresis
    ) {
      fijarActuador(
        vent,
        false,
        `auto: temp ${temp.valor.toFixed(1)} < ${(temp.umbral - temp.cfg.histeresis).toFixed(1)}`,
      );
    }

    if (!bomba.encendido && nivel.valor < nivel.umbral) {
      fijarActuador(
        bomba,
        true,
        `auto: nivel ${nivel.valor.toFixed(0)} < ${nivel.umbral.toFixed(0)}`,
      );
    } else if (
      bomba.encendido &&
      nivel.valor > nivel.umbral + nivel.cfg.histeresis
    ) {
      fijarActuador(
        bomba,
        false,
        `auto: nivel ${nivel.valor.toFixed(0)} > ${(nivel.umbral + nivel.cfg.histeresis).toFixed(0)}`,
      );
    }

    const hayAlarma = sensores.some((s) => s.enAlarma);
    if (hayAlarma !== sirena.encendido) {
      fijarActuador(
        sirena,
        hayAlarma,
        hayAlarma ? "auto: alarma activa" : "auto: sin alarmas",
      );
    }
  }

  // ---------- Modo de operación ----------
  function fijarModo(nuevo: ModoOperacion, anunciar: boolean): void {
    modo = nuevo;
    radiosModo.forEach((r) => {
      r.checked = r.value === nuevo;
    });
    actuadores.forEach((a) => {
      a.boton.disabled = nuevo === "auto";
    });
    notaModo.hidden = nuevo !== "auto";
    if (anunciar) {
      registrar(
        nuevo === "auto"
          ? "MODO automático — actuadores gobernados por las reglas de control"
          : "MODO manual — actuadores a cargo del operador",
        "sistema",
      );
    }
    if (nuevo === "auto") aplicarReglasAuto();
  }

  // ---------- Bucle principal ----------
  function tick(): void {
    contadorTicks += 1;
    sensores.forEach(actualizarSensor);
    if (modo === "auto") aplicarReglasAuto();
    // Con alarma sostenida, el valor y el umbral visibles se mantienen al día
    // sin re-anunciar nada en el lector de pantalla.
    if (sensores.some((s) => s.enAlarma)) actualizarResumenVisible();
    if (contadorTicks % TICKS_POR_TELEMETRIA === 1) {
      const hayAlarma = sensores.some((s) => s.enAlarma);
      registrar(
        `${sensores.map((s) => `${s.cfg.etiqueta}=${conUnidad(s.valor, s, false)}`).join(" ")} → ${hayAlarma ? "ALARMA" : "OK"}`,
        hayAlarma ? "alerta" : "info",
      );
    }
  }

  function iniciar(): void {
    if (temporizador === null) {
      temporizador = window.setInterval(tick, PERIODO_MS);
    }
  }

  function detener(): void {
    if (temporizador !== null) {
      window.clearInterval(temporizador);
      temporizador = null;
    }
  }

  function registrarArranque(): void {
    registrar(
      "INIT SimControl v1.0 — puente serie virtual listo (9600 baudios)",
      "sistema",
    );
    registrar(
      `CONF ${sensores
        .map((s) => `${s.cfg.etiqueta} umbral=${conUnidad(s.umbral, s, false)}`)
        .join(" · ")}`,
      "sistema",
    );
    registrar("MODO manual — actuadores a cargo del operador", "sistema");
  }

  function reiniciar(): void {
    sensores.forEach((s) => {
      s.valor = s.cfg.inicial;
      s.historial = [s.cfg.inicial];
      s.umbral = Number(s.rango.defaultValue);
      s.rango.value = s.rango.defaultValue;
      s.salidaUmbral.textContent = conUnidad(s.umbral, s, true);
      s.enAlarma = false;
      s.raiz.dataset.alarma = "false";
      s.estadoEl.textContent = "OK";
      s.valorEl.textContent = s.valor.toFixed(s.cfg.decimales);
      pintar(s);
    });
    actuadores.forEach((a) => fijarActuador(a, false, "", true));
    fijarModo("manual", false);
    contadorTicks = 0;
    salida.replaceChildren();
    registrarArranque();
    actualizarResumen();
  }

  // ---------- Eventos de la interfaz ----------
  sensores.forEach((s) => {
    s.rango.addEventListener("input", () => {
      s.umbral = Number(s.rango.value);
      s.salidaUmbral.textContent = conUnidad(s.umbral, s, true);
      pintar(s);
      comprobarAlarma(s);
    });
    s.rango.addEventListener("change", () => {
      registrar(
        `CONF umbral ${s.cfg.etiqueta} = ${conUnidad(s.umbral, s, false)}`,
        "sistema",
      );
    });
  });

  actuadores.forEach((a) => {
    a.boton.addEventListener("click", () => {
      if (modo === "auto") return;
      fijarActuador(a, !a.encendido, "manual");
    });
  });

  radiosModo.forEach((r) => {
    r.addEventListener("change", () => {
      if (!r.checked) return;
      fijarModo(r.value === "auto" ? "auto" : "manual", true);
    });
  });

  btnAutoscroll.addEventListener("click", () => {
    autoScroll = !autoScroll;
    btnAutoscroll.setAttribute("aria-pressed", String(autoScroll));
    if (autoScroll) salida.scrollTop = salida.scrollHeight;
  });

  btnLimpiar.addEventListener("click", () => {
    salida.replaceChildren();
  });

  btnReiniciar.addEventListener("click", reiniciar);

  // Pausa manual (WCAG 2.2.2): el operador puede detener el movimiento continuo.
  function actualizarBotonPausa(): void {
    btnPausar.setAttribute("aria-pressed", String(pausadoManual));
    textoPausar.textContent = pausadoManual
      ? "Reanudar simulación"
      : "Pausar simulación";
  }

  btnPausar.addEventListener("click", () => {
    pausadoManual = !pausadoManual;
    actualizarBotonPausa();
    if (pausadoManual) {
      detener();
      registrar("SIM en pausa — detenida por el operador", "sistema");
    } else {
      registrar("SIM reanudada por el operador", "sistema");
      if (!document.hidden) iniciar();
    }
  });

  // Pausa cuando la pestaña no es visible: no quemamos batería en segundo plano.
  // La pausa manual manda: al volver a la pestaña solo se reanuda si el
  // operador no había pausado.
  document.addEventListener("visibilitychange", () => {
    if (document.hidden) {
      const estabaEnMarcha = temporizador !== null;
      detener();
      if (estabaEnMarcha)
        registrar("SIM en pausa — pestaña en segundo plano", "sistema");
    } else if (!pausadoManual) {
      registrar("SIM reanudada", "sistema");
      iniciar();
    }
  });

  // Repintar las gráficas al cambiar el tema (los tokens cambian de valor).
  new MutationObserver(() => sensores.forEach((s) => pintar(s))).observe(
    document.documentElement,
    { attributes: true, attributeFilter: ["data-theme"] },
  );

  // Repintar al cambiar el tamaño de las tarjetas.
  if ("ResizeObserver" in window) {
    const observador = new ResizeObserver(() =>
      sensores.forEach((s) => pintar(s)),
    );
    sensores.forEach((s) => observador.observe(s.canvas));
  }

  // ---------- Arranque ----------
  sensores.forEach((s) => pintar(s));
  registrarArranque();
  if (!document.hidden) iniciar();
</script>
