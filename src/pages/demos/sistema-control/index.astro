  @media (max-width: 900px) {
    .consola-salida {
      min-height: 240px;
      max-height: 50vh;
    }
  }

  .consola-salida:empty::before {
    content: "— búfer vacío: esperando telemetría —";
    display: block;
    padding-block: 0.4rem;
    color: var(--faint);
