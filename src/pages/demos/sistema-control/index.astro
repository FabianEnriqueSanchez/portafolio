  }

  .interruptor[aria-checked="true"] .interruptor-bola {
    transform: translateX(20px);
    background: #ffffff;
  }

  /* La sirena activa usa el color de alerta: es una señal, no un servicio */
  .interruptor[data-actuador="sirena"][aria-checked="true"] .interruptor-pista {
    background: var(--alerta);
    border-color: var(--alerta);
  }

  .interruptor-onoff {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--faint);
    width: 2.1rem;
    text-align: left;
  }

  .interruptor[aria-checked="true"] .interruptor-onoff {
    color: var(--accent);
  }

  .interruptor[data-actuador="sirena"][aria-checked="true"] .interruptor-onoff {
    color: var(--alerta);
  }

  /* ---------- Monitor serie ---------- */
  .consola {
    display: flex;
    flex-direction: column;
    min-height: 380px;
  }

  .consola-salida {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 0.8rem 1rem;
    font-family: var(--font-mono);
