---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { withBase } from "../../../lib/utils";

// Endpoints que se muestran en el panel izquierdo. La lógica que los
// simula vive en el <script> del final (mismos ids).
const endpoints = [
  {
    id: "listar",
    metodo: "GET",
    ruta: "/datos",
    descripcion:
      "Lista los registros del almacén. Admite el filtro opcional ?tipo=.",
  },
  {
    id: "crear",
    metodo: "POST",
    ruta: "/datos",
    descripcion: "Crea un registro con body JSON { nombre, tipo, valor }.",
  },
  {
    id: "detalle",
    metodo: "GET",
    ruta: "/datos/:id",
    descripcion: "Devuelve el detalle de un registro concreto.",
  },
  {
    id: "eliminar",
    metodo: "DELETE",
    ruta: "/datos/:id",
    descripcion: "Elimina un registro del almacén.",
  },
  {
    id: "integracion",
    metodo: "POST",
    ruta: "/integracion",
    descripcion:
      "Simula la sincronización con otro sistema (tarda ~1,5 s) y devuelve un resumen { enviados, aceptados }.",
  },
];
---

<BaseLayout
  titulo="Explorador de la API de datos — Demo interactiva"
  descripcion="Simulación interactiva de una API REST de gestión de datos empresariales: prueba endpoints, autenticación por token, validaciones y errores consistentes directamente en tu navegador."
>
  <Header />

  <main id="contenido" class="demo-api" tabindex="-1">
    <!-- Región que anuncia cada respuesta a lectores de pantalla -->
    <div id="anuncio" class="visualmente-oculto" aria-live="polite"></div>

    <section class="demo-hero">
      <div class="container reveal">
        <p class="eyebrow">Demo interactiva</p>
        <h1 class="hero-title">Explorador de la API de datos — simulación</h1>
        <p class="hero-lead">
          Prueba el contrato de una API REST de gestión de datos empresariales:
          endpoints, autenticación por token, validación estricta de entrada y
          errores con estructura consistente. La API real es interna; esta
          simulación reproduce su comportamiento.
        </p>
        <p class="aviso-demo">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 16v-4M12 8h.01"></path>
          </svg>
          <span>
            Servidor simulado en tu navegador: los datos viven solo en esta
            pestaña.
          </span>
        </p>
        <div class="hero-enlaces">
          <a class="btn btn-ghost" href={withBase("/") + "#proyectos"}
            >← Volver a proyectos</a
          >
          <a class="btn btn-primary" href={withBase("docs/apis-datos/")}
            >Documentación</a
          >
        </div>
      </div>
    </section>

    <section class="demo-cuerpo">
      <div class="container">
        <div class="demo-grid reveal">
          <!-- ===== Panel izquierdo: endpoints ===== -->
          <aside
            class="panel panel-endpoints"
            aria-label="Endpoints disponibles"
          >
            <div class="panel-cabecera">
              <h2 class="panel-titulo">Endpoints</h2>
              <span class="chip-version">v1</span>
            </div>
            <ul class="lista-endpoints" role="list">
              {
                endpoints.map((ep) => (
                  <li>
                    <button
                      type="button"
                      class="endpoint-btn"
                      data-endpoint={ep.id}
                      aria-pressed={ep.id === "listar" ? "true" : "false"}
                    >
                      <span class={`met met-${ep.metodo.toLowerCase()}`}>
                        {ep.metodo}
                      </span>
                      <span class="endpoint-info">
                        <code class="endpoint-ruta">{ep.ruta}</code>
                        <span class="endpoint-desc">{ep.descripcion}</span>
                      </span>
                    </button>
                  </li>
                ))
              }
            </ul>
          </aside>

          <!-- ===== Panel derecho: probar la petición ===== -->
          <section class="panel panel-tester" aria-label="Probar la petición">
            <div class="panel-cabecera">
              <h2 class="panel-titulo">Probar la petición</h2>
              <p class="base-url">
                Base: <code>https://api.interna.example</code>
              </p>
            </div>
            <p class="desc-endpoint" id="desc-endpoint">
              Lista los registros del almacén. Admite el filtro opcional ?tipo=.
            </p>

            <noscript>
              <p class="texto-vacio">
                Esta demo necesita JavaScript para simular el servidor. Actívalo
                para probar las peticiones.
              </p>
            </noscript>

            <form id="form-peticion" novalidate>
              <div class="linea-ruta">
                <span class="met met-get" id="metodo-actual">GET</span>
                <span class="ruta-caja">
                  <code id="ruta-texto">/datos</code><span id="grupo-id" hidden>
                    <label class="visualmente-oculto" for="input-id"
                      >Identificador del registro (parámetro :id de la ruta)</label
                    >
                    <input
                      id="input-id"
                      class="input-id"
                      type="text"
                      inputmode="numeric"
                      autocomplete="off"
                      spellcheck="false"
                      placeholder="id"
                      value="3"
                    />
                  </span>
                </span>
              </div>

              <div id="grupo-query" class="campo">
                <label for="input-tipo"
                  >Parámetro de consulta <code>tipo</code> (opcional)</label
                >
                <input
                  id="input-tipo"
                  type="text"
                  list="lista-tipos"
                  placeholder="p. ej. inventario"
                  autocomplete="off"
                  spellcheck="false"
                />
                <datalist id="lista-tipos"></datalist>
              </div>

              <fieldset class="campo auth-fieldset">
                <legend>Cabecera <code>Authorization</code></legend>
                <div class="segmentos">
                  <label class="segmento">
                    <input
                      type="radio"
                      name="modo-auth"
                      value="valido"
                      checked
                    />
                    <span>Token válido</span>
                  </label>
                  <label class="segmento">
                    <input type="radio" name="modo-auth" value="invalido" />
                    <span>Token inválido</span>
                  </label>
                  <label class="segmento">
                    <input type="radio" name="modo-auth" value="sin" />
                    <span>Sin token</span>
                  </label>
                </div>
                <p class="auth-vista">
                  <code id="auth-vista"
                    >Authorization: Bearer tok_demo_2026</code
                  >
                </p>
              </fieldset>

              <div id="grupo-body" class="campo" hidden>
                <label for="input-body">Body JSON de la petición</label>
                <textarea
                  id="input-body"
                  rows="6"
                  spellcheck="false"
                  autocomplete="off"
                  placeholder={'{ "nombre": "…", "tipo": "…", "valor": 0 }'}
                ></textarea>
              </div>

              <div class="campo curl-campo">
                <div class="curl-cabecera">
                  <span class="etiqueta-mono" id="curl-etiqueta"
                    >Equivalente en cURL</span
                  >
                  <button
                    type="button"
                    id="btn-copiar-curl"
                    class="btn-copiar"
                    aria-label="Copiar comando cURL"
                  >
                    Copiar
                  </button>
                </div>
                <pre
                  class="curl-pre"
                  tabindex="0"
                  role="region"
                  aria-labelledby="curl-etiqueta"><code id="curl-codigo" /></pre>
              </div>

              <div class="fila-envio">
                <button
                  type="submit"
                  class="btn btn-primary btn-enviar"
                  id="btn-enviar"
                >
                  <span id="btn-enviar-texto">Enviar petición</span>
                  <span class="spinner" id="spinner" hidden aria-hidden="true"
                  ></span>
                </button>
                <p class="atajo">
                  También puedes enviar con <kbd>Ctrl</kbd> + <kbd>Enter</kbd>
                </p>
              </div>
            </form>

            <div class="respuesta" id="panel-respuesta" aria-busy="false">
              <h3 class="etiqueta-mono">Respuesta</h3>
              <div id="respuesta-vacia" class="respuesta-vacia">
                <p>
                  Aún no has enviado ninguna petición. Elige un endpoint, ajusta
                  los parámetros y pulsa «Enviar petición».
                </p>
              </div>
              <div id="respuesta-contenido" hidden>
                <div class="respuesta-meta">
                  <span class="estado-pill estado-ok" id="estado-pill"
                    >200 OK</span
                  >
                  <code class="respuesta-peticion" id="respuesta-peticion"
                    >GET /datos</code
                  >
                  <span class="respuesta-tiempo" id="respuesta-tiempo"
                    >0 ms</span
                  >
                </div>
                <pre
                  class="respuesta-pre"
                  tabindex="0"
                  role="region"
                  aria-label="Cuerpo JSON de la respuesta"><code id="respuesta-cuerpo" /></pre>
              </div>
            </div>
          </section>

          <!-- ===== Historial ===== -->
          <section
            class="panel panel-historial"
            aria-label="Historial de peticiones"
          >
            <div class="panel-cabecera">
              <h2 class="panel-titulo">Historial</h2>
              <button type="button" id="btn-limpiar" class="btn-texto" disabled
                >Limpiar</button
              >
            </div>
            <p id="historial-vacio" class="texto-vacio">
              Aún no has enviado peticiones. Cada respuesta se registra aquí y
              puedes repetirla con un clic.
            </p>
            <ul id="lista-historial" class="lista-historial" role="list"></ul>
          </section>
        </div>

        <!-- ===== Estado del almacén ===== -->
        <section
          class="panel panel-almacen reveal"
          aria-label="Estado del almacén"
        >
          <div class="panel-cabecera">
            <h2 class="panel-titulo">Estado del almacén</h2>
            <span class="contador" id="contador-almacen">0 registros</span>
          </div>
          <div
            class="tabla-scroll"
            role="region"
            aria-label="Registros actuales del almacén"
            tabindex="0"
          >
            <table class="tabla-almacen">
              <thead>
                <tr>
                  <th scope="col">ID</th>
                  <th scope="col">Nombre</th>
                  <th scope="col">Tipo</th>
                  <th scope="col" class="celda-num">Valor</th>
                  <th scope="col">Creado</th>
                </tr>
              </thead>
              <tbody id="tabla-cuerpo"></tbody>
            </table>
          </div>
        </section>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* ============================================================
     Demo: explorador de API. Todo el CSS va espaciado bajo
     .demo-api porque parte del DOM se genera desde JS y no
     recibiría las clases de ámbito de Astro.
     ============================================================ */

  /* ---------- Hero ---------- */
  .demo-api .demo-hero {
    padding-block: clamp(3.25rem, 7vw, 5rem) clamp(1.75rem, 3vw, 2.5rem);
  }

  .demo-api .hero-title {
    font-size: clamp(1.85rem, 4.5vw, 2.75rem);
    margin-top: 0.6rem;
    text-wrap: balance;
  }

  .demo-api .hero-lead {
    color: var(--muted);
    font-size: var(--text-lg);
    max-width: 62ch;
    margin-top: 1rem;
  }

  .demo-api .aviso-demo {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.55rem;
    margin-top: 1.2rem;
    padding: 0.6rem 0.9rem;
    background: var(--accent-soft);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    max-width: 62ch;
  }

  .demo-api .aviso-demo svg {
    flex: none;
    margin-top: 0.2rem;
    color: var(--accent);
  }

  .demo-api .hero-enlaces {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.6rem;
  }

  /* ---------- Rejilla principal ---------- */
  .demo-api .demo-cuerpo {
    padding-block: clamp(1rem, 2vw, 1.5rem) clamp(4rem, 8vw, 6rem);
  }

  .demo-api .demo-grid {
    display: grid;
    grid-template-columns: minmax(0, 350px) minmax(0, 1fr);
    grid-template-areas:
      "endpoints tester"
      "historial tester";
    grid-template-rows: auto 1fr;
    gap: 1.4rem;
    align-items: start;
  }

  .demo-api .panel-endpoints {
    grid-area: endpoints;
  }
  .demo-api .panel-tester {
    grid-area: tester;
  }
  .demo-api .panel-historial {
    grid-area: historial;
  }

  @media (max-width: 900px) {
    .demo-api .demo-grid {
      grid-template-columns: minmax(0, 1fr);
      grid-template-areas: "endpoints" "tester" "historial";
      grid-template-rows: none;
    }
  }

  /* ---------- Paneles ---------- */
  .demo-api .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: clamp(1.1rem, 2.5vw, 1.5rem);
    box-shadow: var(--shadow);
  }

  .demo-api .panel-cabecera {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.9rem;
  }

  .demo-api .panel-titulo {
    font-size: var(--text-lg);
  }

  .demo-api .etiqueta-mono {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--faint);
    font-weight: 600;
  }

  .demo-api .chip-version,
  .demo-api .contador {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
    white-space: nowrap;
  }

  .demo-api .base-url {
    font-size: var(--text-xs);
    color: var(--faint);
    font-family: var(--font-mono);
    overflow-wrap: anywhere;
  }

  .demo-api .desc-endpoint {
    color: var(--muted);
    font-size: var(--text-sm);
    margin-bottom: 1.1rem;
  }

  .demo-api .texto-vacio {
    color: var(--faint);
    font-size: var(--text-sm);
  }

  /* ---------- Badges de método ---------- */
  .demo-api .met {
    flex: none;
    display: inline-block;
    min-width: 3.9rem;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
  }

  .demo-api .met-get {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .demo-api .met-post {
    background: #fef3c7;
    color: #92400e;
  }

  html[data-theme="dark"] .demo-api .met-post {
    background: #3a2b12;
    color: #fbbf24;
  }

  .demo-api .met-delete {
    background: #ffe4e6;
    color: #9f1239;
  }

  html[data-theme="dark"] .demo-api .met-delete {
    background: #42161f;
    color: #fda4af;
  }

  /* ---------- Lista de endpoints ---------- */
  .demo-api .lista-endpoints {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .demo-api .endpoint-btn {
    width: 100%;
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    min-height: 44px;
    padding: 0.7rem 0.75rem;
    border: 1px solid transparent;
    border-radius: var(--radius);
    background: transparent;
    color: var(--text);
    text-align: left;
    cursor: pointer;
    font: inherit;
    transition:
      background var(--dur) var(--ease),
      border-color var(--dur) var(--ease);
  }

  .demo-api .endpoint-btn:hover {
    background: var(--bg-soft);
  }

  .demo-api .endpoint-btn[aria-pressed="true"] {
    background: var(--accent-soft);
    border-color: var(--accent);
  }

  .demo-api .endpoint-btn .met {
    margin-top: 0.1rem;
  }

  .demo-api .endpoint-info {
    min-width: 0;
  }

  .demo-api .endpoint-ruta {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    overflow-wrap: anywhere;
  }

  .demo-api .endpoint-desc {
    display: block;
    margin-top: 0.2rem;
    color: var(--muted);
    font-size: var(--text-xs);
    line-height: 1.5;
  }

  /* ---------- Formulario ---------- */
  .demo-api .campo {
    margin-top: 1.1rem;
  }

  .demo-api .campo > label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 560;
    margin-bottom: 0.4rem;
  }

  .demo-api .campo label code,
  .demo-api .auth-fieldset legend code {
    font-family: var(--font-mono);
    font-size: 0.86em;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 0.05rem 0.35rem;
  }

  .demo-api .campo input[type="text"],
  .demo-api .campo textarea {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: 0.6rem 0.75rem;
    color: var(--text);
    font-size: var(--text-sm);
    min-height: 42px;
    font-family: inherit;
    transition: border-color var(--dur) var(--ease);
  }

  .demo-api .campo input[type="text"]:focus,
  .demo-api .campo textarea:focus,
  .demo-api .input-id:focus {
    border-color: var(--accent);
  }

  .demo-api .campo textarea {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.65;
    resize: vertical;
    min-height: 8.5rem;
    tab-size: 2;
  }

  .demo-api ::placeholder {
    color: var(--faint);
    opacity: 1;
  }

  /* Línea método + ruta */
  .demo-api .linea-ruta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.55rem 0.75rem;
  }

  .demo-api .ruta-caja {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    min-width: 0;
  }

  .demo-api .ruta-caja > code {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 600;
    overflow-wrap: anywhere;
  }

  .demo-api .input-id {
    width: 6ch;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 0.3rem 0.45rem;
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    background: var(--surface);
    color: var(--text);
    transition: border-color var(--dur) var(--ease);
  }

  /* Selector de autenticación (segmentos) */
  .demo-api .auth-fieldset {
    border: 0;
    padding: 0;
    margin-inline: 0;
  }

  .demo-api .auth-fieldset legend {
    font-size: var(--text-sm);
    font-weight: 560;
    padding: 0;
    margin-bottom: 0.45rem;
  }

  .demo-api .segmentos {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .demo-api .segmento {
    position: relative;
    display: inline-flex;
  }

  .demo-api .segmento input {
    position: absolute;
    inset: 0;
    opacity: 0;
    margin: 0;
    cursor: pointer;
  }

  .demo-api .segmento span {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0.3rem 0.95rem;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: var(--surface);
    color: var(--muted);
    font-size: var(--text-sm);
    transition:
      background var(--dur) var(--ease),
      color var(--dur) var(--ease),
      border-color var(--dur) var(--ease);
  }

  .demo-api .segmento:hover span {
    border-color: var(--accent);
    color: var(--text);
  }

  .demo-api .segmento input:checked + span {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-contrast);
    font-weight: 600;
  }

  .demo-api .segmento input:focus-visible + span {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .demo-api .auth-vista {
    margin-top: 0.55rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--faint);
    overflow-wrap: anywhere;
  }

  /* Bloque cURL */
  .demo-api .curl-cabecera {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.45rem;
  }

  .demo-api .btn-copiar {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0.25rem 0.85rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 560;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition:
      color var(--dur) var(--ease),
      border-color var(--dur) var(--ease);
  }

  .demo-api .btn-copiar:hover,
  .demo-api .btn-copiar.copiado {
    color: var(--accent);
    border-color: var(--accent);
  }

  .demo-api .curl-pre {
    margin: 0;
    padding: 0.85rem 1rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.65;
    white-space: pre;
  }

  /* Envío */
  .demo-api .fila-envio {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.2rem;
  }

  .demo-api .btn-enviar {
    min-height: 44px;
  }

  .demo-api .btn-enviar:disabled {
