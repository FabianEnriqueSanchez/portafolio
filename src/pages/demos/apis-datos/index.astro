<script>
  // ============================================================
  // Servidor simulado: reproduce el contrato de la API real
  // (interna) por completo en el navegador. Nada sale de la
  // pestaña; el almacén vive en memoria.
  // ============================================================

  type Metodo = "GET" | "POST" | "DELETE";
  type EndpointId = "listar" | "crear" | "detalle" | "eliminar" | "integracion";
  type ModoAuth = "valido" | "invalido" | "sin";

  interface DefEndpoint {
    metodo: Metodo;
    ruta: string;
    usaId: boolean;
    usaQuery: boolean;
    usaBody: boolean;
    bodyEjemplo: string;
  }

  interface Registro {
    id: number;
    nombre: string;
    tipo: string;
    valor: number;
    creado: string;
  }

  interface ConfigPeticion {
    endpoint: EndpointId;
    id: string;
    tipo: string;
    body: string;
    auth: ModoAuth;
  }

  interface RespuestaSim {
    status: number;
    cuerpo: unknown;
    anuncio: string;
    mutacion: boolean;
  }

  interface EntradaHistorial {
    config: ConfigPeticion;
    metodo: Metodo;
    ruta: string;
    status: number;
    ms: number;
  }

  const URL_BASE = "https://api.interna.example";
  const TOKEN_VALIDO = "tok_demo_2026";
  const TOKEN_INVALIDO = "tok_caducado_9f3";
  const MAX_HISTORIAL = 15;

  const TEXTO_ESTADO: Record<number, string> = {
    200: "OK",
    201: "Created",
    400: "Bad Request",
    401: "Unauthorized",
    404: "Not Found",
  };

  const ENDPOINTS: Record<EndpointId, DefEndpoint> = {
    listar: {
      metodo: "GET",
      ruta: "/datos",
      usaId: false,
      usaQuery: true,
      usaBody: false,
      bodyEjemplo: "",
    },
    crear: {
      metodo: "POST",
      ruta: "/datos",
      usaId: false,
      usaQuery: false,
      usaBody: true,
      bodyEjemplo: `{
  "nombre": "Cierre de caja — sede norte",
  "tipo": "ventas",
  "valor": 15300
}`,
    },
    detalle: {
      metodo: "GET",
      ruta: "/datos/:id",
      usaId: true,
      usaQuery: false,
      usaBody: false,
      bodyEjemplo: "",
    },
    eliminar: {
      metodo: "DELETE",
      ruta: "/datos/:id",
      usaId: true,
      usaQuery: false,
      usaBody: false,
      bodyEjemplo: "",
    },
    integracion: {
      metodo: "POST",
      ruta: "/integracion",
      usaId: false,
      usaQuery: false,
      usaBody: true,
      bodyEjemplo: `{
  "destino": "ERP corporativo",
  "tipo": "inventario"
}`,
    },
  };

  // ---------- Almacén en memoria (datos de ejemplo realistas) ----------
  const almacen: Registro[] = [
    {
      id: 1,
      nombre: "Sincronización de inventario — bodega central",
      tipo: "inventario",
      valor: 1248,
      creado: "2026-06-18T08:15:00Z",
    },
    {
      id: 2,
      nombre: "Ventas consolidadas — canal mayorista",
      tipo: "ventas",
      valor: 58230,
      creado: "2026-06-20T17:42:00Z",
    },
    {
      id: 3,
      nombre: "Clientes activos sincronizados desde el CRM",
      tipo: "clientes",
      valor: 342,
      creado: "2026-06-23T09:05:00Z",
    },
    {
      id: 4,
      nombre: "Stock de seguridad — línea eléctrica",
      tipo: "inventario",
      valor: 320,
      creado: "2026-06-25T11:30:00Z",
    },
    {
      id: 5,
      nombre: "Pedidos pendientes de despacho — zona norte",
      tipo: "pedidos",
      valor: 112,
      creado: "2026-06-28T14:20:00Z",
    },
    {
      id: 6,
      nombre: "Recaudos aplicados — semana 27",
      tipo: "cartera",
      valor: 9640,
      creado: "2026-07-01T16:55:00Z",
    },
    {
      id: 7,
      nombre: "Facturas emitidas — corte diario",
      tipo: "ventas",
      valor: 86,
      creado: "2026-07-06T19:10:00Z",
    },
  ];
  let siguienteId = 8;

  // ---------- Estado de la interfaz ----------
  let endpointActual: EndpointId = "listar";
  let enEnvio = false;
  const borradores: Partial<Record<EndpointId, string>> = {};
  const historial: EntradaHistorial[] = [];

  // ---------- Referencias al DOM ----------
  function el<T extends HTMLElement = HTMLElement>(id: string): T {
    const nodo = document.getElementById(id);
    if (!nodo) throw new Error(`No se encontró el elemento #${id}`);
    return nodo as T;
  }

  const form = el<HTMLFormElement>("form-peticion");
  const inputId = el<HTMLInputElement>("input-id");
  const inputTipo = el<HTMLInputElement>("input-tipo");
  const inputBody = el<HTMLTextAreaElement>("input-body");
  const listaTipos = el("lista-tipos");
  const metodoActual = el("metodo-actual");
  const rutaTexto = el("ruta-texto");
  const grupoId = el("grupo-id");
  const grupoQuery = el("grupo-query");
  const grupoBody = el("grupo-body");
  const descEndpoint = el("desc-endpoint");
  const authVista = el("auth-vista");
  const curlCodigo = el("curl-codigo");
  const btnCopiar = el<HTMLButtonElement>("btn-copiar-curl");
  const btnEnviar = el<HTMLButtonElement>("btn-enviar");
  const btnEnviarTexto = el("btn-enviar-texto");
  const spinner = el("spinner");
  const panelRespuesta = el("panel-respuesta");
  const respuestaVacia = el("respuesta-vacia");
  const respuestaContenido = el("respuesta-contenido");
  const estadoPill = el("estado-pill");
  const respuestaPeticion = el("respuesta-peticion");
  const respuestaTiempo = el("respuesta-tiempo");
  const respuestaCuerpo = el("respuesta-cuerpo");
  const anuncio = el("anuncio");
  const listaHistorial = el("lista-historial");
  const historialVacio = el("historial-vacio");
  const btnLimpiar = el<HTMLButtonElement>("btn-limpiar");
  const contador = el("contador-almacen");
  const tablaCuerpo = el("tabla-cuerpo");

  const botonesEndpoint = Array.from(
    document.querySelectorAll<HTMLButtonElement>("button[data-endpoint]"),
  );
  const radiosAuth = Array.from(
    document.querySelectorAll<HTMLInputElement>('input[name="modo-auth"]'),
  );

  // ---------- Utilidades ----------
  function escaparHtml(texto: string): string {
    return texto
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  const esperar = (ms: number) =>
    new Promise<void>((res) => setTimeout(res, ms));

  function latenciaPara(id: EndpointId): number {
    // /integracion "tarda" ~1,5 s; el resto entre 80 y 350 ms.
    if (id === "integracion") return 1480 + Math.floor(Math.random() * 240);
    return 80 + Math.floor(Math.random() * 271);
  }

  function clasePorEstado(status: number): string {
    if (status < 400) return "estado-ok";
    if (status === 400) return "estado-warn";
    return "estado-err";
  }

  /** Pretty-print con resaltado: claves en acento, strings y números con su tono. */
  function resaltarJson(valor: unknown, nivel = 0): string {
    const sangria = "  ".repeat(nivel);
    const sangriaHija = "  ".repeat(nivel + 1);

    if (valor === null) return '<span class="tk-nulo">null</span>';
    if (typeof valor === "string") {
      return `<span class="tk-cadena">${escaparHtml(JSON.stringify(valor))}</span>`;
    }
    if (typeof valor === "number") {
      return `<span class="tk-numero">${String(valor)}</span>`;
    }
    if (typeof valor === "boolean") {
      return `<span class="tk-bool">${String(valor)}</span>`;
    }
    if (Array.isArray(valor)) {
      if (valor.length === 0) return "[]";
      const items = valor
        .map((v) => sangriaHija + resaltarJson(v, nivel + 1))
        .join(",\n");
      return `[\n${items}\n${sangria}]`;
    }
    if (typeof valor === "object") {
      const entradas = Object.entries(valor as Record<string, unknown>);
      if (entradas.length === 0) return "{}";
      const items = entradas
        .map(
          ([clave, v]) =>
            `${sangriaHija}<span class="tk-clave">${escaparHtml(JSON.stringify(clave))}</span>: ${resaltarJson(v, nivel + 1)}`,
        )
        .join(",\n");
      return `{\n${items}\n${sangria}}`;
    }
    return escaparHtml(String(valor));
  }

  // ---------- Lógica del servidor simulado ----------
  function errorSim(
    status: number,
    codigo: string,
    mensaje: string,
    detalle: string,
  ): RespuestaSim {
    return {
      status,
      cuerpo: { error: { codigo, mensaje, detalle } },
      anuncio: `${status} ${TEXTO_ESTADO[status]} — ${detalle}`,
      mutacion: false,
    };
  }

  function procesar(cfg: ConfigPeticion): RespuestaSim {
    // 1. Autenticación: la misma regla para todos los endpoints.
    if (cfg.auth === "sin") {
      return errorSim(
        401,
        "NO_AUTORIZADO",
        "La petición no está autenticada.",
        "Falta la cabecera Authorization.",
      );
    }
    if (cfg.auth === "invalido") {
      return errorSim(
        401,
        "NO_AUTORIZADO",
        "La petición no está autenticada.",
        "El token proporcionado no es válido o ha expirado.",
      );
    }

    const def = ENDPOINTS[cfg.endpoint];

    // 2. Parámetro :id de la ruta.
    let idNum = 0;
    if (def.usaId) {
      const bruto = cfg.id.trim();
      if (!/^\d+$/.test(bruto)) {
        return errorSim(
          400,
          "VALIDACION",
          "La ruta no es válida.",
          "El parámetro :id debe ser un número entero positivo.",
        );
      }
      idNum = Number(bruto);
    }

    // 3. Body JSON.
    let body: Record<string, unknown> = {};
    if (def.usaBody) {
      let interpretado: unknown;
      try {
        interpretado = JSON.parse(cfg.body);
      } catch {
        return errorSim(
          400,
          "JSON_INVALIDO",
          "El cuerpo de la petición no es JSON válido.",
          "Revisa comillas, comas y llaves antes de reenviar.",
        );
      }
      if (
        typeof interpretado !== "object" ||
        interpretado === null ||
        Array.isArray(interpretado)
      ) {
        return errorSim(
          400,
          "VALIDACION",
          "El cuerpo de la petición no es válido.",
          "El cuerpo debe ser un objeto JSON.",
        );
      }
      body = interpretado as Record<string, unknown>;
    }

    // 4. Lógica por endpoint.
    switch (cfg.endpoint) {
      case "listar": {
        const filtro = cfg.tipo.trim().toLowerCase();
        const datos = filtro
          ? almacen.filter((r) => r.tipo.toLowerCase() === filtro)
          : [...almacen];
        const n = datos.length;
        return {
          status: 200,
          cuerpo: { total: n, datos },
          anuncio: `200 OK — ${n} ${n === 1 ? "registro devuelto" : "registros devueltos"}`,
          mutacion: false,
        };
      }

      case "crear": {
        const nombre = body["nombre"];
        if (nombre === undefined) {
          return errorSim(
            400,
            "VALIDACION",
            "El cuerpo de la petición no es válido.",
            "Falta el campo obligatorio «nombre».",
          );
        }
        if (typeof nombre !== "string" || nombre.trim() === "") {
          return errorSim(
            400,
            "VALIDACION",
            "El cuerpo de la petición no es válido.",
            "El campo «nombre» debe ser un texto no vacío.",
          );
        }
        const tipo = body["tipo"];
        if (tipo === undefined) {
          return errorSim(
            400,
            "VALIDACION",
            "El cuerpo de la petición no es válido.",
            "Falta el campo obligatorio «tipo».",
          );
        }
        if (typeof tipo !== "string" || tipo.trim() === "") {
          return errorSim(
            400,
            "VALIDACION",
            "El cuerpo de la petición no es válido.",
            "El campo «tipo» debe ser un texto no vacío.",
          );
        }
        const valor = body["valor"];
        if (valor === undefined) {
          return errorSim(
            400,
            "VALIDACION",
            "El cuerpo de la petición no es válido.",
            "Falta el campo obligatorio «valor».",
          );
        }
        if (typeof valor !== "number" || !Number.isFinite(valor)) {
          return errorSim(
            400,
            "VALIDACION",
            "El cuerpo de la petición no es válido.",
            "El campo «valor» debe ser un número.",
          );
        }
        const registro: Registro = {
          id: siguienteId,
          nombre: nombre.trim(),
          tipo: tipo.trim().toLowerCase(),
          valor,
          creado: new Date().toISOString(),
        };
        siguienteId += 1;
        almacen.push(registro);
        return {
          status: 201,
          cuerpo: registro,
          anuncio: `201 Created — registro #${registro.id} creado`,
          mutacion: true,
        };
      }

      case "detalle": {
        const registro = almacen.find((r) => r.id === idNum);
        if (!registro) {
          return errorSim(
            404,
            "NO_ENCONTRADO",
            "El registro solicitado no existe.",
            `No hay ningún registro con id ${idNum}.`,
          );
        }
        return {
          status: 200,
          cuerpo: registro,
          anuncio: `200 OK — registro #${idNum} devuelto`,
          mutacion: false,
        };
      }

      case "eliminar": {
        const registro = almacen.find((r) => r.id === idNum);
        if (!registro) {
          return errorSim(
            404,
            "NO_ENCONTRADO",
            "El registro solicitado no existe.",
            `No hay ningún registro con id ${idNum}.`,
          );
        }
        almacen.splice(almacen.indexOf(registro), 1);
        return {
          status: 200,
          cuerpo: { mensaje: `Registro #${idNum} eliminado.`, registro },
          anuncio: `200 OK — registro #${idNum} eliminado`,
          mutacion: true,
        };
      }

      case "integracion": {
        const destino = body["destino"];
        if (destino === undefined) {
          return errorSim(
            400,
            "VALIDACION",
            "El cuerpo de la petición no es válido.",
            "Falta el campo obligatorio «destino».",
          );
        }
        if (typeof destino !== "string" || destino.trim() === "") {
          return errorSim(
            400,
            "VALIDACION",
            "El cuerpo de la petición no es válido.",
            "El campo «destino» debe ser un texto no vacío.",
          );
        }
        const tipoFiltro = body["tipo"];
        if (tipoFiltro !== undefined && typeof tipoFiltro !== "string") {
          return errorSim(
            400,
            "VALIDACION",
            "El cuerpo de la petición no es válido.",
            "El campo «tipo» debe ser un texto.",
          );
        }
        const seleccion =
          typeof tipoFiltro === "string" && tipoFiltro.trim() !== ""
            ? almacen.filter(
                (r) => r.tipo.toLowerCase() === tipoFiltro.trim().toLowerCase(),
              )
            : almacen;
        const enviados = seleccion.length;
        const rechazados =
          enviados === 0
            ? 0
            : Math.min(enviados, Math.floor(Math.random() * 2));
        const aceptados = enviados - rechazados;
        return {
          status: 200,
          cuerpo: { destino: destino.trim(), enviados, aceptados },
          anuncio: `200 OK — sincronización completada: ${aceptados} de ${enviados} registros aceptados`,
          mutacion: false,
        };
      }
    }
  }

  // ---------- Lectura y aplicación de la configuración ----------
  function modoAuthActual(): ModoAuth {
    const marcado = radiosAuth.find((r) => r.checked);
    return (marcado?.value as ModoAuth | undefined) ?? "valido";
  }

  function fijarModoAuth(modo: ModoAuth): void {
    radiosAuth.forEach((r) => {
      r.checked = r.value === modo;
    });
    actualizarVistaAuth();
  }

  function configActual(): ConfigPeticion {
    return {
      endpoint: endpointActual,
      id: inputId.value,
      tipo: inputTipo.value,
      body: inputBody.value,
      auth: modoAuthActual(),
    };
  }

  function rutaMostrada(cfg: ConfigPeticion): string {
    const def = ENDPOINTS[cfg.endpoint];
    let ruta = def.ruta;
    if (def.usaId) {
      const bruto = cfg.id.trim();
      // Función como reemplazo para que $&, $', $` o $$ en el input
      // no se interpreten como patrones especiales de String.replace.
      ruta = ruta.replace(":id", () => (bruto === "" ? ":id" : bruto));
    }
    if (def.usaQuery) {
      const filtro = cfg.tipo.trim();
      if (filtro !== "") ruta += `?tipo=${encodeURIComponent(filtro)}`;
    }
    return ruta;
  }

  function seleccionarEndpoint(id: EndpointId): void {
    endpointActual = id;
    const def = ENDPOINTS[id];

    botonesEndpoint.forEach((b) => {
      b.setAttribute("aria-pressed", String(b.dataset.endpoint === id));
    });

    metodoActual.textContent = def.metodo;
    metodoActual.className = `met met-${def.metodo.toLowerCase()}`;
    rutaTexto.textContent = def.usaId ? def.ruta.replace(":id", "") : def.ruta;

    grupoId.hidden = !def.usaId;
    grupoQuery.hidden = !def.usaQuery;
    grupoBody.hidden = !def.usaBody;
    if (def.usaBody) {
      inputBody.value = borradores[id] ?? def.bodyEjemplo;
    }

    const boton = botonesEndpoint.find((b) => b.dataset.endpoint === id);
    descEndpoint.textContent =
      boton?.querySelector(".endpoint-desc")?.textContent?.trim() ?? "";

    actualizarCurl();
  }

  function aplicarConfig(cfg: ConfigPeticion): void {
    seleccionarEndpoint(cfg.endpoint);
    inputId.value = cfg.id;
    inputTipo.value = cfg.tipo;
    if (ENDPOINTS[cfg.endpoint].usaBody) {
      inputBody.value = cfg.body;
      borradores[cfg.endpoint] = cfg.body;
    }
    fijarModoAuth(cfg.auth);
    actualizarCurl();
  }

  // ---------- Render ----------
  function renderRespuesta(
    res: RespuestaSim,
    cfg: ConfigPeticion,
    ms: number,
  ): void {
    respuestaVacia.hidden = true;
    respuestaContenido.hidden = false;
    estadoPill.textContent =
      `${res.status} ${TEXTO_ESTADO[res.status] ?? ""}`.trim();
    estadoPill.className = `estado-pill ${clasePorEstado(res.status)}`;
    respuestaPeticion.textContent = `${ENDPOINTS[cfg.endpoint].metodo} ${rutaMostrada(cfg)}`;
    respuestaTiempo.textContent = `${ms} ms`;
    respuestaCuerpo.innerHTML = resaltarJson(res.cuerpo);
    anuncio.textContent = `${res.anuncio} (${ms} ms)`;
  }

  function renderAlmacen(): void {
    const n = almacen.length;
    contador.textContent = `${n} ${n === 1 ? "registro" : "registros"}`;

    if (n === 0) {
      tablaCuerpo.innerHTML =
        '<tr><td colspan="5" class="celda-vacia">El almacén está vacío. Crea un registro con <code>POST /datos</code>.</td></tr>';
    } else {
      tablaCuerpo.innerHTML = almacen
        .map(
          (r) => `<tr>
            <td class="celda-mono">${r.id}</td>
            <td>${escaparHtml(r.nombre)}</td>
            <td><span class="chip-tipo">${escaparHtml(r.tipo)}</span></td>
            <td class="celda-mono celda-num">${r.valor.toLocaleString("es-CO")}</td>
            <td class="celda-mono">${escaparHtml(r.creado.slice(0, 10))}</td>
          </tr>`,
        )
        .join("");
    }

    // Sugerencias del filtro ?tipo= a partir de los tipos existentes.
    const tipos = Array.from(new Set(almacen.map((r) => r.tipo))).sort();
    listaTipos.innerHTML = tipos
      .map((t) => `<option value="${escaparHtml(t)}"></option>`)
      .join("");
  }

  function renderHistorial(): void {
    btnLimpiar.disabled = historial.length === 0;
    historialVacio.hidden = historial.length > 0;

    const teniaFoco = listaHistorial.contains(document.activeElement);
    listaHistorial.innerHTML = historial
      .map((h, i) => {
        const etiqueta = escaparHtml(
          `Repetir ${h.metodo} ${h.ruta} (respondió ${h.status} en ${h.ms} ms)`,
        );
        return `<li>
          <button type="button" class="hist-btn" data-indice="${i}" aria-label="${etiqueta}">
            <span class="met met-${h.metodo.toLowerCase()}">${h.metodo}</span>
            <span class="hist-ruta">${escaparHtml(h.ruta)}</span>
            <span class="estado-mini ${clasePorEstado(h.status)}">${h.status}</span>
            <span class="hist-ms">${h.ms} ms</span>
          </button>
        </li>`;
      })
      .join("");
    if (teniaFoco) {
      listaHistorial.querySelector<HTMLButtonElement>("button")?.focus();
    }
  }

  function actualizarVistaAuth(): void {
    const modo = modoAuthActual();
    authVista.textContent =
      modo === "valido"
        ? `Authorization: Bearer ${TOKEN_VALIDO}`
        : modo === "invalido"
          ? `Authorization: Bearer ${TOKEN_INVALIDO}`
          : "(sin cabecera Authorization)";
  }

  function compactarBody(bruto: string): string {
    try {
      return JSON.stringify(JSON.parse(bruto));
    } catch {
      return bruto.replace(/\s*\n\s*/g, " ").trim();
    }
  }

  function actualizarCurl(): void {
    const cfg = configActual();
    const def = ENDPOINTS[cfg.endpoint];
    const lineas = [`curl -X ${def.metodo} '${URL_BASE}${rutaMostrada(cfg)}'`];
    if (cfg.auth === "valido") {
      lineas.push(`-H 'Authorization: Bearer ${TOKEN_VALIDO}'`);
    } else if (cfg.auth === "invalido") {
      lineas.push(`-H 'Authorization: Bearer ${TOKEN_INVALIDO}'`);
    }
    if (def.usaBody) {
      lineas.push("-H 'Content-Type: application/json'");
      lineas.push(`-d '${compactarBody(cfg.body).replace(/'/g, "'\\''")}'`);
    }
    curlCodigo.textContent = lineas.join(" \\\n  ");
  }

  // ---------- Envío ----------
  /** Marca los botones del historial como deshabilitados mientras hay una petición en vuelo. */
  function fijarHistorialEnVuelo(enVuelo: boolean): void {
    listaHistorial
      .querySelectorAll<HTMLButtonElement>("button[data-indice]")
      .forEach((b) => {
        if (enVuelo) {
          b.setAttribute("aria-disabled", "true");
        } else {
          b.removeAttribute("aria-disabled");
        }
      });
  }

  async function ejecutar(): Promise<void> {
    if (enEnvio) return;
    enEnvio = true;

    const cfg = configActual();
    const ms = latenciaPara(cfg.endpoint);

    btnEnviar.disabled = true;
    btnEnviarTexto.textContent = "Enviando…";
    spinner.hidden = false;
    panelRespuesta.setAttribute("aria-busy", "true");
    fijarHistorialEnVuelo(true);

    try {
      await esperar(ms);
      const res = procesar(cfg);
      renderRespuesta(res, cfg, ms);
      historial.unshift({
        config: { ...cfg },
        metodo: ENDPOINTS[cfg.endpoint].metodo,
        ruta: rutaMostrada(cfg),
        status: res.status,
        ms,
      });
      if (historial.length > MAX_HISTORIAL) historial.length = MAX_HISTORIAL;
      renderHistorial();
      if (res.mutacion) renderAlmacen();
    } finally {
      enEnvio = false;
      btnEnviar.disabled = false;
      btnEnviarTexto.textContent = "Enviar petición";
      spinner.hidden = true;
      panelRespuesta.setAttribute("aria-busy", "false");
      fijarHistorialEnVuelo(false);
    }
  }

  // ---------- Eventos ----------
  botonesEndpoint.forEach((b) => {
    b.addEventListener("click", () => {
      const id = b.dataset.endpoint as EndpointId | undefined;
      if (id && id in ENDPOINTS) seleccionarEndpoint(id);
    });
  });

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    void ejecutar();
  });

  // Ctrl+Enter (o Cmd+Enter) envía desde cualquier campo del formulario.
  form.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && (e.ctrlKey || e.metaKey)) {
      e.preventDefault();
      void ejecutar();
    }
  });

  [inputId, inputTipo].forEach((campo) => {
    campo.addEventListener("input", actualizarCurl);
  });

  inputBody.addEventListener("input", () => {
    borradores[endpointActual] = inputBody.value;
    actualizarCurl();
  });

  radiosAuth.forEach((r) => {
    r.addEventListener("change", () => {
      actualizarVistaAuth();
      actualizarCurl();
    });
  });

  listaHistorial.addEventListener("click", (e) => {
    const boton = (e.target as HTMLElement).closest<HTMLButtonElement>(
      "button[data-indice]",
    );
    if (!boton) return;
    // Guarda temprana: con una petición en vuelo no se toca el formulario
    // y se avisa por la región aria-live en vez de fallar en silencio.
    if (enEnvio) {
      anuncio.textContent = "Espera a que termine la petición en curso.";
      return;
    }
    const entrada = historial[Number(boton.dataset.indice)];
    if (!entrada) return;
    aplicarConfig(entrada.config);
    void ejecutar();
  });

  btnLimpiar.addEventListener("click", () => {
    historial.length = 0;
    renderHistorial();
    anuncio.textContent = "Historial de peticiones vaciado.";
  });

  let temporizadorCopiar: number | undefined;
  btnCopiar.addEventListener("click", async () => {
    const texto = curlCodigo.textContent ?? "";
    try {
      await navigator.clipboard.writeText(texto);
      btnCopiar.textContent = "Copiado ✓";
      btnCopiar.classList.add("copiado");
      anuncio.textContent = "Comando cURL copiado al portapapeles.";
    } catch {
      btnCopiar.textContent = "No disponible";
    }
    window.clearTimeout(temporizadorCopiar);
    temporizadorCopiar = window.setTimeout(() => {
      btnCopiar.textContent = "Copiar";
      btnCopiar.classList.remove("copiado");
    }, 1600);
  });

  // ---------- Estado inicial ----------
  renderAlmacen();
  renderHistorial();
  seleccionarEndpoint("listar");
  actualizarVistaAuth();
</script>
