  function pintarBreadcrumb(vistaId: string) {
    const partes = RUTAS[vistaId] ?? ["Inicio"];
    breadcrumb.innerHTML = partes
      .map((p, i) => (i === partes.length - 1 ? `<span class="bc-actual">${p}</span>` : `<span>${p}</span><span class="bc-sep">/</span>`))
      .join("");
  }

  function irA(vistaId: string) {
    vistas.forEach((v) => {
      const activa = v.dataset.vista === vistaId;
      v.hidden = !activa;
      v.classList.toggle("es-activa", activa);
    });
    raiz.querySelectorAll<HTMLButtonElement>(".nav-item").forEach((b) => {
      const activo = b.dataset.nav === vistaId;
      b.classList.toggle("es-activo", activo);
      b.setAttribute("aria-current", activo ? "page" : "false");
    });
    pintarBreadcrumb(vistaId);
    const vistaActiva = vistas.find((v) => v.dataset.vista === vistaId);
    if (vistaActiva) vistaActiva.focus();
    if (vistaId === "dashboard") requestAnimationFrame(pintarGrafico);
  }

  // -------- Toast para secciones no incluidas --------
  let toastTimer: number | undefined;
  function mostrarToast(msg: string) {
    toast.textContent = msg;
    toast.classList.add("es-visible");
    anuncio.textContent = msg;
    window.clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => toast.classList.remove("es-visible"), 2600);
  }

  // Delegación global de navegación y acciones no funcionales.
  raiz.addEventListener("click", (ev) => {
    const target = ev.target as HTMLElement;
    const nav = target.closest<HTMLButtonElement>(".nav-item, [data-seccion], [data-nav]");
    if (!nav) return;
    const destino = nav.dataset.nav;
    if (destino) {
      irA(destino);
      return;
    }
    const seccion = nav.dataset.seccion;
    if (seccion) mostrarToast(`«${seccion}» no está incluido en esta demo interactiva.`);
  });

