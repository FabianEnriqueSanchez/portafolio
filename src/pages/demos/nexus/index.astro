  function ahora(): string {
    const d = new Date();
    return `${String(d.getHours()).padStart(2, "0")}:${String(d.getMinutes()).padStart(2, "0")}`;
  }

  async function ejecutar(id: string) {
    if (ejecutando) return;
    const script = scripts.find((s) => s.id === id);
    if (!script) return;
    ejecutando = true;

    consolaScript.textContent = script.nombre;
    consolaLog.innerHTML = "";
    consolaPie.className = "consola-pie";
    consolaPie.textContent = "";
    overlay.hidden = false;
    consolaCerrar.focus();
    anuncio.textContent = `Ejecutando ${script.nombre}…`;

    linea("l-info", `$ nexus run ${script.nombre} --version ${script.version}`);
    await pausa(400);
    linea("l-info", `[${ahora()}] Autenticando usuario (JWT)…`);
    await pausa(500);
    linea("l-info", `[${ahora()}] Resolviendo entorno virtual y dependencias…`);
    await pausa(650);
    linea("l-info", `[${ahora()}] Inyectando secretos (AES-256) para categoría ${script.categoria}…`);
    await pausa(600);
    linea("l-cmd", `[${ahora()}] Verificando integridad SHA-256… OK`);
    await pausa(500);
    linea("l-cmd", `[${ahora()}] Ejecutando script…`);
    await pausa(900);

    const falla = script.nombre.length % 5 === 0;
    const dur = (1.2 + (script.nombre.length % 7) * 0.8).toFixed(1) + " s";

    if (falla) {
      linea("l-err", `[${ahora()}] ERROR: código de salida 1 — revisar parámetros de entrada.`);
      consolaPie.textContent = "✕ Ejecución finalizada con error";
      consolaPie.classList.add("es-err");
      anuncio.textContent = `La ejecución de ${script.nombre} terminó con error.`;
      erroresHoy += 1;
    } else {
      linea("l-ok", `[${ahora()}] Proceso completado correctamente (código 0).`);
      consolaPie.textContent = `✓ Ejecución completada en ${dur}`;
      consolaPie.classList.add("es-ok");
      anuncio.textContent = `${script.nombre} se ejecutó correctamente.`;
    }

    ejecHoy += 1;
    script.ejecuciones += 1;
    ejecuciones.unshift({
      script: script.nombre,
      usuario: "admin",
      inicio: ahora(),
      duracion: falla ? "—" : dur,
      ok: !falla,
    });
    renderStats();
    renderTop();
    renderEjecuciones();
    pintarGrafico();
    ejecutando = false;
  }

  function cerrarConsola() { overlay.hidden = true; }

  cuerpoScripts.addEventListener("click", (ev) => {
    const btn = (ev.target as HTMLElement).closest<HTMLButtonElement>("[data-ejecutar]");
    if (!btn || btn.disabled) return;
    const id = btn.dataset.ejecutar;
    if (id) void ejecutar(id);
  });

  consolaCerrar.addEventListener("click", cerrarConsola);
  overlay.addEventListener("click", (ev) => {
    if (ev.target === overlay) cerrarConsola();
  });
  document.addEventListener("keydown", (ev) => {
    if (ev.key === "Escape" && !overlay.hidden) cerrarConsola();
  });

  // Colapsar sidebar / cerrar sesión (simulado)
  btnColapsar.addEventListener("click", () => appShell.classList.toggle("compacta"));
  const btnSalir = q<HTMLButtonElement>(raiz, '[data-rol="salir"]');
  btnSalir.addEventListener("click", () => mostrarToast("Sesión cerrada (simulado). Recarga para reiniciar la demo."));

  // ============================================================
  //  Reiniciar datos
  // ============================================================
  function reiniciar() {
    usuarios = USUARIOS_SEMILLA.map((u) => ({ ...u }));
    scripts = SCRIPTS_SEMILLA.map((s) => ({ ...s }));
    ejecuciones = EJEC_SEMILLA.map((e) => ({ ...e }));
    ejecHoy = EJEC_HOY_INICIAL;
    erroresHoy = ERRORES_HOY_INICIAL;
    filtroCat = "todas";
    filtroScriptTexto = "";
    filtroUsuTexto = "";
    filtroRol = "todos";
    filtroEstado = "todos";
    inputBuscarScript.value = "";
    inputBuscarUsu.value = "";
    selectRol.value = "todos";
    selectEstado.value = "todos";
    renderStats();
    renderTop();
    renderUsuarios();
    renderChips();
    renderScripts();
    renderEjecuciones();
    pintarGrafico();
    anuncio.textContent = "Datos de la demo reiniciados.";
  }

  btnReiniciar.addEventListener("click", () => {
    reiniciar();
    irA("dashboard");
    mostrarToast("Datos de la demo reiniciados.");
  });

  // ============================================================
  //  Reactividad del gráfico ante tema y tamaño
  // ============================================================
  new ResizeObserver(() => pintarGrafico()).observe(graficoWrap);
  new MutationObserver(() => pintarGrafico()).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });

  // -------- Arranque --------
  reiniciar();
  irA("dashboard");
</script>
