---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { withBase } from "../../../lib/utils";

// Ítems de navegación del panel. Los tres primeros son funcionales; el
// resto se muestran atenuados (no incluidos en la simulación). La lógica
// vive en el <script> del final (mismos ids en data-vista / data-nav).
const navegacion = [
  { id: "dashboard", texto: "Panel", activo: true, funcional: true },
  { id: "scripts", texto: "Scripts", activo: false, funcional: true },
  { id: "ejecuciones", texto: "Ejecuciones", activo: false, funcional: true },
  { id: "usuarios", texto: "Usuarios", activo: false, funcional: false },
  { id: "secretos", texto: "Secretos", activo: false, funcional: false },
  { id: "config", texto: "Configuración", activo: false, funcional: false },
];
---

<BaseLayout
  titulo="Panel administrativo de Nexus — Demo interactiva"
  descripcion="Simulación interactiva del panel administrativo de Nexus: dashboard con métricas, gestión de scripts empresariales y ejecución simulada con registro de logs, directamente en tu navegador."
>
  <Header />

  <main id="contenido" class="demo-nexus" tabindex="-1">
    <!-- Región que anuncia acciones a lectores de pantalla -->
    <div id="anuncio" class="visualmente-oculto" aria-live="polite"></div>

    <section class="demo-hero">
      <div class="container reveal">
        <p class="eyebrow">Demo interactiva</p>
        <h1 class="hero-title">Panel administrativo de Nexus — simulación</h1>
        <p class="hero-lead">
          Así se ve la gestión del sistema desde el lado del equipo de TI:
          métricas, catálogo de scripts empresariales por categoría y ejecución
          con registro de logs. El panel real (Vue.js + FastAPI) es interno;
          esta simulación reproduce su interfaz y su flujo.
        </p>
        <p class="aviso-demo">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 16v-4M12 8h.01"></path>
          </svg>
          <span>
            Datos de muestra: todo vive solo en esta pestaña y se reinicia al
            recargar. No se ejecuta ningún script real.
          </span>
        </p>
        <div class="hero-enlaces">
          <a class="btn btn-ghost" href={withBase("/") + "#proyectos"}
            >← Volver a proyectos</a
          >
          <a class="btn btn-primary" href={withBase("docs/nexus/")}
            >Documentación</a
          >
        </div>
      </div>
    </section>

    <section class="demo-cuerpo">
      <div class="container">
        <div class="app-shell reveal" role="application" aria-label="Panel administrativo simulado de Nexus">
          <!-- ===== Sidebar ===== -->
          <aside class="app-sidebar" aria-label="Navegación del panel">
            <div class="marca">
              <span class="marca-punto" aria-hidden="true"></span>
              <span class="marca-nombre">Nexus</span>
            </div>
            <nav class="nav" aria-label="Secciones">
              <ul role="list">
                {
                  navegacion.map((item) => (
                    <li>
                      {item.funcional ? (
                        <button
                          type="button"
                          class={`nav-item ${item.activo ? "es-activo" : ""}`}
                          data-nav={item.id}
                          aria-current={item.activo ? "page" : "false"}
                        >
                          <span class="nav-icono" aria-hidden="true" data-ico={item.id} />
                          {item.texto}
                        </button>
                      ) : (
                        <span
                          class="nav-item es-inactivo"
                          aria-disabled="true"
                          title="No incluido en la demo"
                        >
                          <span class="nav-icono" aria-hidden="true" data-ico={item.id} />
                          {item.texto}
                          <span class="nav-pill">demo</span>
                        </span>
                      )}
                    </li>
                  ))
                }
              </ul>
            </nav>
            <div class="sidebar-pie">
              <button type="button" class="btn-reiniciar" data-rol="reiniciar">
                ↻ Reiniciar datos
              </button>
            </div>
          </aside>

          <!-- ===== Zona principal ===== -->
          <div class="app-main">
            <!-- Topbar -->
            <header class="app-topbar">
              <div class="buscador" data-rol="buscador-topbar">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                  <circle cx="11" cy="11" r="7"></circle>
                  <path d="m21 21-4.3-4.3"></path>
                </svg>
                <label class="visualmente-oculto" for="buscar-topbar">Buscar scripts</label>
                <input
                  type="search"
                  id="buscar-topbar"
                  placeholder="Buscar scripts…"
                  autocomplete="off"
                  data-rol="buscar"
                />
              </div>
              <div class="usuario">
                <span class="usuario-avatar" aria-hidden="true">A</span>
                <span class="usuario-datos">
                  <span class="usuario-nombre">Administrador</span>
                  <span class="usuario-rol">admin</span>
                </span>
              </div>
            </header>

            <!-- ===== Vista: Dashboard ===== -->
            <section class="vista es-activa" data-vista="dashboard" tabindex="-1" aria-label="Panel de control">
              <h2 class="vista-titulo">Panel de control</h2>

              <div class="stats">
                <article class="stat">
                  <span class="stat-icono" data-tono="azul" aria-hidden="true">▤</span>
                  <span class="stat-valor" data-rol="stat-scripts">0</span>
                  <span class="stat-label">Scripts publicados</span>
                </article>
                <article class="stat">
                  <span class="stat-icono" data-tono="verde" aria-hidden="true">◑</span>
                  <span class="stat-valor" data-rol="stat-usuarios">8</span>
                  <span class="stat-label">Usuarios activos</span>
                </article>
                <article class="stat">
                  <span class="stat-icono" data-tono="cian" aria-hidden="true">▶</span>
                  <span class="stat-valor" data-rol="stat-ejec">0</span>
                  <span class="stat-label">Ejecuciones hoy</span>
                </article>
              </div>

              <div class="panel grafico-panel">
                <div class="panel-cabecera">
                  <h3 class="panel-titulo">Ejecuciones · últimos 7 días</h3>
                  <span class="chip-version">simulado</span>
                </div>
                <div class="grafico-wrap" data-rol="grafico-wrap">
                  <canvas data-rol="grafico" role="img" aria-label="Gráfico de barras de ejecuciones diarias de la última semana"></canvas>
                </div>
              </div>

              <div class="panel">
                <div class="panel-cabecera">
                  <h3 class="panel-titulo">Scripts recientes</h3>
                  <button type="button" class="enlace-vista" data-nav="scripts">Ver todos →</button>
                </div>
                <div class="tabla-scroll">
                  <table class="tabla" data-rol="tabla-recientes">
                    <thead>
                      <tr><th scope="col">Script</th><th scope="col">Categoría</th><th scope="col">Versión</th><th scope="col">Estado</th></tr>
                    </thead>
                    <tbody data-rol="cuerpo-recientes"></tbody>
                  </table>
                </div>
              </div>
            </section>

            <!-- ===== Vista: Scripts ===== -->
            <section class="vista" data-vista="scripts" tabindex="-1" aria-label="Catálogo de scripts" hidden>
              <h2 class="vista-titulo">Scripts</h2>

              <div class="filtros">
                <div class="chips-cat" role="group" aria-label="Filtrar por categoría" data-rol="chips-cat"></div>
              </div>

              <div class="panel">
                <div class="tabla-scroll">
                  <table class="tabla tabla-scripts">
                    <thead>
                      <tr>
                        <th scope="col">Script</th>
                        <th scope="col">Categoría</th>
                        <th scope="col">Versión</th>
                        <th scope="col">Estado</th>
                        <th scope="col" class="col-accion">Acción</th>
                      </tr>
                    </thead>
                    <tbody data-rol="cuerpo-scripts"></tbody>
                  </table>
                  <p class="sin-resultados" data-rol="sin-resultados" hidden>
                    No hay scripts que coincidan con el filtro.
                  </p>
                </div>
              </div>
            </section>

            <!-- ===== Vista: Ejecuciones ===== -->
            <section class="vista" data-vista="ejecuciones" tabindex="-1" aria-label="Registro de ejecuciones" hidden>
              <h2 class="vista-titulo">Ejecuciones</h2>
              <div class="panel">
                <div class="tabla-scroll">
                  <table class="tabla">
                    <thead>
                      <tr>
                        <th scope="col">Script</th>
                        <th scope="col">Usuario</th>
                        <th scope="col">Inicio</th>
                        <th scope="col">Duración</th>
                        <th scope="col">Resultado</th>
                      </tr>
                    </thead>
                    <tbody data-rol="cuerpo-ejec"></tbody>
                  </table>
                </div>
              </div>
            </section>
          </div>
        </div>

        <!-- ===== Consola de ejecución (modal ligero) ===== -->
        <div class="consola-overlay" data-rol="consola-overlay" hidden>
          <div
            class="consola"
            role="dialog"
            aria-modal="true"
            aria-labelledby="consola-titulo"
            data-rol="consola"
          >
            <div class="consola-cabecera">
              <h3 id="consola-titulo" class="consola-titulo">
                Ejecutando <span data-rol="consola-script">script</span>
              </h3>
              <button type="button" class="consola-cerrar" data-rol="consola-cerrar" aria-label="Cerrar consola">✕</button>
            </div>
            <pre class="consola-salida" data-rol="consola-log" role="log" aria-live="polite" tabindex="0"></pre>
            <div class="consola-pie" data-rol="consola-pie"></div>
          </div>
        </div>

        <noscript>
          <p class="aviso-nojs">
            Esta demo necesita JavaScript para simular el panel. Puedes revisar
            la <a href={withBase("docs/nexus/")}>documentación de Nexus</a> para
            conocer su arquitectura.
          </p>
        </noscript>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>

<style is:global>
  /* ============================================================
     Demo Nexus — panel administrativo simulado.
     Todo el CSS va prefijado por .demo-nexus porque parte del DOM
     (tablas, logs, chips) se genera desde el <script> y Astro solo
     aplica el hash de scope al markup estático.
     Tokens de marca locales sobre los tokens globales del sitio.
     ============================================================ */
  .demo-nexus {
    --nx-azul: #1b3a5c;
    --nx-azul-claro: #4a90d9;
    --nx-panel-bg: #f5f7fa;
    --nx-side-bg: #14304c;
    --nx-side-text: #cdd9e5;
    --nx-side-activo: #4a90d9;
    --nx-ok: #2ecc71;
    --nx-warn: #f39c12;
    --nx-err: #e74c3c;
  }
  :root[data-theme="dark"] .demo-nexus {
    --nx-azul: #4a90d9;
    --nx-azul-claro: #6ba8e5;
    --nx-panel-bg: #12100e;
    --nx-side-bg: #101f30;
    --nx-side-text: #b9c6d4;
  }

  .demo-nexus .demo-hero {
    padding-block: clamp(2.5rem, 6vw, 4rem) clamp(1.5rem, 3vw, 2rem);
  }
  .demo-nexus .hero-title {
    font-size: var(--text-3xl);
    max-width: 20ch;
    margin-top: 0.6rem;
  }
  .demo-nexus .hero-lead {
    color: var(--muted);
    max-width: 60ch;
    margin-top: 1rem;
    font-size: var(--text-lg);
  }
  .demo-nexus .aviso-demo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1.4rem;
    padding: 0.7rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-soft);
    color: var(--muted);
    font-size: var(--text-sm);
    max-width: 60ch;
  }
  .demo-nexus .aviso-demo svg {
    flex-shrink: 0;
    color: var(--accent);
  }
  .demo-nexus .hero-enlaces {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.6rem;
  }

  .demo-nexus .demo-cuerpo {
    padding-bottom: clamp(4rem, 8vw, 6rem);
  }

  /* ---------- Shell ---------- */
  .demo-nexus .app-shell {
    display: grid;
    grid-template-columns: 240px 1fr;
    min-height: 620px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    background: var(--surface);
  }

  /* ---------- Sidebar ---------- */
  .demo-nexus .app-sidebar {
    display: flex;
    flex-direction: column;
    background: var(--nx-side-bg);
    color: var(--nx-side-text);
    padding: 1.2rem 0.9rem;
  }
  .demo-nexus .marca {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 0.6rem 1.2rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.35rem;
    color: #fff;
    letter-spacing: -0.02em;
  }
  .demo-nexus .marca-punto {
    width: 12px;
    height: 12px;
    border-radius: 3px;
    background: var(--nx-azul-claro);
    box-shadow: 0 0 0 4px rgba(74, 144, 217, 0.25);
  }
  .demo-nexus .nav ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .demo-nexus .nav-item {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    width: 100%;
    text-align: left;
    padding: 0.6rem 0.7rem;
    border-radius: var(--radius-sm);
    border: none;
    background: transparent;
    color: var(--nx-side-text);
    font-size: var(--text-sm);
    font-family: inherit;
    cursor: pointer;
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .demo-nexus button.nav-item:hover {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }
  .demo-nexus .nav-item.es-activo {
    background: var(--nx-side-activo);
    color: #fff;
    font-weight: 560;
  }
  .demo-nexus .nav-item.es-inactivo {
    cursor: not-allowed;
    opacity: 0.45;
  }
  .demo-nexus .nav-icono {
    width: 18px;
    height: 18px;
    border-radius: 5px;
    background: currentColor;
    opacity: 0.55;
    flex-shrink: 0;
  }
  .demo-nexus .nav-item.es-activo .nav-icono {
    opacity: 0.9;
  }
  .demo-nexus .nav-pill {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.1rem 0.4rem;
    border: 1px solid currentColor;
    border-radius: 999px;
  }
  .demo-nexus .sidebar-pie {
    margin-top: auto;
    padding-top: 1rem;
  }
  .demo-nexus .btn-reiniciar {
    width: 100%;
    padding: 0.55rem 0.7rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: var(--nx-side-text);
    font-size: var(--text-xs);
    font-family: inherit;
    cursor: pointer;
    transition: background var(--dur) var(--ease);
  }
  .demo-nexus .btn-reiniciar:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  /* ---------- Main ---------- */
  .demo-nexus .app-main {
    display: flex;
    flex-direction: column;
    background: var(--nx-panel-bg);
    min-width: 0;
  }
  :root[data-theme="dark"] .demo-nexus .app-main {
    background: var(--bg);
  }
  .demo-nexus .app-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1.4rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .demo-nexus .buscador {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1;
    max-width: 360px;
    padding: 0.5rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-soft);
    color: var(--muted);
  }
  .demo-nexus .buscador input {
    border: none;
    background: transparent;
    color: var(--text);
    font-size: var(--text-sm);
    width: 100%;
    outline: none;
  }
  .demo-nexus .usuario {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .demo-nexus .usuario-avatar {
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--nx-azul);
    color: #fff;
    font-weight: 600;
    font-size: var(--text-sm);
  }
  .demo-nexus .usuario-datos {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .demo-nexus .usuario-nombre {
    font-size: var(--text-sm);
    font-weight: 560;
    color: var(--text);
  }
  .demo-nexus .usuario-rol {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--faint);
  }

  /* ---------- Vistas ---------- */
  .demo-nexus .vista {
    padding: 1.5rem 1.4rem 2rem;
    overflow: auto;
  }
  .demo-nexus .vista[hidden] {
    display: none;
  }
  .demo-nexus .vista-titulo {
    font-size: var(--text-xl);
    margin-bottom: 1.2rem;
  }

  /* Stat cards */
  .demo-nexus .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.4rem;
  }
  .demo-nexus .stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1.1rem 1.2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }
  .demo-nexus .stat-icono {
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-sm);
    font-size: 1rem;
    margin-bottom: 0.3rem;
  }
  .demo-nexus .stat-icono[data-tono="azul"] { background: rgba(27, 58, 92, 0.12); color: var(--nx-azul); }
  .demo-nexus .stat-icono[data-tono="verde"] { background: rgba(46, 204, 113, 0.14); color: #1e8b4d; }
  .demo-nexus .stat-icono[data-tono="cian"] { background: rgba(74, 144, 217, 0.16); color: var(--nx-azul-claro); }
  .demo-nexus .stat-valor {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text);
    line-height: 1;
  }
  .demo-nexus .stat-label {
    font-size: var(--text-sm);
    color: var(--muted);
  }

  /* Paneles */
  .demo-nexus .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    margin-bottom: 1.4rem;
    overflow: hidden;
  }
  .demo-nexus .panel-cabecera {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 1.1rem;
    border-bottom: 1px solid var(--border);
  }
  .demo-nexus .panel-titulo {
    font-size: var(--text-base);
    font-weight: 560;
  }
  .demo-nexus .chip-version {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--faint);
    border: 1px solid var(--border);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
  }
  .demo-nexus .enlace-vista {
    border: none;
    background: transparent;
    color: var(--accent);
    font-size: var(--text-sm);
    font-family: inherit;
    cursor: pointer;
  }
  .demo-nexus .enlace-vista:hover { text-decoration: underline; }

  /* Gráfico */
  .demo-nexus .grafico-wrap {
    height: 200px;
    padding: 1rem 1.1rem 1.2rem;
  }
  .demo-nexus .grafico-wrap canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Tablas */
  .demo-nexus .tabla-scroll { overflow-x: auto; }
  .demo-nexus .tabla {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }
  .demo-nexus .tabla th {
    text-align: left;
    padding: 0.7rem 1.1rem;
    color: var(--faint);
    font-weight: 560;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1px solid var(--border);
    background: var(--bg-soft);
    white-space: nowrap;
  }
  .demo-nexus .tabla td {
    padding: 0.75rem 1.1rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    vertical-align: middle;
  }
  .demo-nexus .tabla tbody tr:last-child td { border-bottom: none; }
  .demo-nexus .tabla tbody tr:hover td { background: var(--bg-soft); }
  .demo-nexus .script-nombre {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text);
  }
  .demo-nexus .col-accion { text-align: right; }

  /* Badge de categoría */
  .demo-nexus .cat {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-xs);
    white-space: nowrap;
  }
  .demo-nexus .cat-punto {
    width: 9px;
    height: 9px;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .demo-nexus .badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 560;
    padding: 0.18rem 0.55rem;
    border-radius: 999px;
    text-transform: capitalize;
  }
  .demo-nexus .badge-activo { background: rgba(46, 204, 113, 0.15); color: #1e8b4d; }
  .demo-nexus .badge-borrador { background: rgba(243, 156, 18, 0.16); color: #b9770a; }
  :root[data-theme="dark"] .demo-nexus .badge-activo { color: #4ade80; }
