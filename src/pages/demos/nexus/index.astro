  // -------- Gráfico de barras (lee tokens del tema) --------
  function pintarGrafico() {
    const dpr = window.devicePixelRatio || 1;
    const w = canvas.clientWidth;
    const totalH = canvas.clientHeight;
    if (w <= 0 || totalH <= 0) return;
    const h = totalH - 22;
    canvas.width = Math.round(w * dpr);
    canvas.height = Math.round(totalH * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.clearRect(0, 0, w, totalH);

    const estilos = getComputedStyle(raiz);
    const colBarra = estilos.getPropertyValue("--nx-blue").trim() || "#4a90d9";
    const colTexto = estilos.getPropertyValue("--faint").trim() || "#888";
    const colRejilla = estilos.getPropertyValue("--border").trim() || "#ddd";

    const datos = HIST_SEMILLA.concat([ejecHoy]);
    const etiquetas = ["Lun", "Mar", "Mié", "Jue", "Vie", "Sáb", "Hoy"];
    const max = Math.max(...datos, 1) * 1.15;
    const n = datos.length;
    const gap = 16;
    const bw = (w - gap * (n - 1)) / n;

    ctx.strokeStyle = colRejilla;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(0, h);
    ctx.lineTo(w, h);
    ctx.stroke();

    ctx.font = "11px ui-monospace, monospace";
    ctx.textAlign = "center";

    datos.forEach((v, i) => {
      const x = i * (bw + gap);
      const bh = Math.max((v / max) * h, 2);
      const y = h - bh;
      const esHoy = i === n - 1;
      ctx.fillStyle = colBarra;
      ctx.globalAlpha = esHoy ? 1 : 0.5;
      const r = Math.min(6, bw / 2);
      ctx.beginPath();
      ctx.moveTo(x, h);
      ctx.lineTo(x, y + r);
      ctx.arcTo(x, y, x + r, y, r);
      ctx.lineTo(x + bw - r, y);
      ctx.arcTo(x + bw, y, x + bw, y + r, r);
      ctx.lineTo(x + bw, h);
      ctx.closePath();
      ctx.fill();
      ctx.globalAlpha = 1;
      ctx.fillStyle = colTexto;
      ctx.fillText(String(v), x + bw / 2, y - 6);
      ctx.fillText(etiquetas[i], x + bw / 2, h + 18);
    });
  }

  // ============================================================
