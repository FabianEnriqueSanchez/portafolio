---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { withBase } from "../../../lib/utils";

// Íconos (Lucide, líneas). Se inyectan con set:html dentro de un <svg> común.
const ICO = {
  home: `<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
  user: `<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
  users: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  script: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="m7 9 3 3-3 3"/><line x1="13" y1="15" x2="17" y2="15"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/>`,
  list: `<line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>`,
  play: `<polygon points="5 3 19 12 5 21 5 3"/>`,
  info: `<circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>`,
  lock: `<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
  book: `<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>`,
  monitor: `<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
  settings: `<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>`,
  alert: `<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
};

// Navegación fiel al panel real (dos grupos). funcional=true conmuta de vista;
// el resto muestran un aviso "no incluido en la demo" sin romper el aspecto.
interface ItemNav {
  id: string;
  texto: string;
  icono: string;
  funcional: boolean;
  tono?: string;
}
const NAV_PRINCIPAL: ItemNav[] = [
  { id: "dashboard", texto: "Dashboard", icono: ICO.home, funcional: true },
  { id: "usuarios", texto: "Usuarios", icono: ICO.user, funcional: true },
  { id: "grupos", texto: "Grupos", icono: ICO.users, funcional: false },
  { id: "scripts", texto: "Scripts", icono: ICO.script, funcional: true },
  { id: "permisos", texto: "Permisos", icono: ICO.shield, funcional: false },
  { id: "categorias", texto: "Categorías", icono: ICO.list, funcional: false },
  { id: "logs-ejecucion", texto: "Logs Ejecución", icono: ICO.play, funcional: true },
  { id: "logs-acceso", texto: "Logs Acceso", icono: ICO.info, funcional: false },
];
const NAV_ADMIN: ItemNav[] = [
  { id: "secretos", texto: "Secretos", icono: ICO.lock, funcional: false, tono: "amber" },
  { id: "librerias", texto: "Librerías", icono: ICO.book, funcional: false },
  { id: "sesiones", texto: "Sesiones", icono: ICO.monitor, funcional: false },
  { id: "config", texto: "Configuración", icono: ICO.settings, funcional: false },
  { id: "crash", texto: "Crash Reports", icono: ICO.alert, funcional: false },
];
---

<BaseLayout
  titulo="Panel administrativo de Nexus — Demo interactiva"
  descripcion="Simulación interactiva del panel administrativo de Nexus: dashboard con métricas, gestión de usuarios y scripts empresariales, y ejecución simulada con registro de logs, directamente en tu navegador."
>
  <Header />

  <main id="contenido" class="demo-nexus" tabindex="-1">
    <div id="anuncio" class="visualmente-oculto" aria-live="polite"></div>

    <section class="demo-hero">
      <div class="container reveal">
        <p class="eyebrow">Demo interactiva</p>
        <h1 class="hero-title">Panel administrativo de Nexus</h1>
        <p class="hero-lead">
          Reproducción de la interfaz real del panel (Vue.js + FastAPI) con la
          que el equipo de TI gestiona el sistema: métricas en tiempo real,
          usuarios y roles, catálogo de scripts empresariales por categoría y
          ejecución con registro de logs. El backend real es interno; esta
          simulación reproduce su interfaz y su flujo.
        </p>
        <p class="aviso-demo">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 16v-4M12 8h.01"></path>
          </svg>
          <span>
            Datos de muestra: todo vive solo en esta pestaña y se reinicia al
            recargar. No se ejecuta ningún script real ni se toca ningún dato de la empresa.
          </span>
        </p>
        <div class="hero-enlaces">
          <a class="btn btn-ghost" href={withBase("/") + "#proyectos"}>← Volver a proyectos</a>
          <a class="btn btn-primary" href={withBase("docs/nexus/")}>Documentación</a>
          <button type="button" class="btn btn-ghost btn-reiniciar" data-rol="reiniciar">↻ Reiniciar datos</button>
        </div>
      </div>
    </section>

    <section class="demo-cuerpo">
      <div class="container">
        <div class="app-shell reveal" role="application" aria-label="Panel administrativo simulado de Nexus">
          <!-- ===== Sidebar ===== -->
          <aside class="app-sidebar" aria-label="Navegación del panel">
            <div class="sb-marca">
              <span class="sb-logo" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="18" cy="5" r="3"></circle>
                  <circle cx="6" cy="12" r="3"></circle>
                  <circle cx="18" cy="19" r="3"></circle>
                  <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                  <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                </svg>
              </span>
              <span class="sb-marca-texto">
                <strong>Nexus</strong>
                <small>Admin Panel</small>
              </span>
              <button type="button" class="sb-colapsar" data-rol="colapsar" aria-label="Contraer o expandir el menú">«</button>
            </div>

            <nav class="sb-nav" aria-label="Secciones">
              <ul role="list">
                {
                  NAV_PRINCIPAL.map((item) => (
                    <li>
                      <button
                        type="button"
                        class={`nav-item ${item.id === "dashboard" ? "es-activo" : ""}`}
                        data-nav={item.funcional ? item.id : null}
                        data-seccion={item.funcional ? null : item.texto}
                        aria-current={item.id === "dashboard" ? "page" : "false"}
                      >
                        <span class="nav-ico" data-tono={item.tono ?? null} aria-hidden="true">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={item.icono} />
                        </span>
                        <span class="nav-texto">{item.texto}</span>
                      </button>
                    </li>
                  ))
                }
              </ul>

              <p class="sb-grupo-label">Administración</p>
              <ul role="list">
                {
                  NAV_ADMIN.map((item) => (
                    <li>
                      <button
                        type="button"
                        class="nav-item"
                        data-seccion={item.texto}
                      >
                        <span class="nav-ico" data-tono={item.tono ?? null} aria-hidden="true">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={item.icono} />
                        </span>
                        <span class="nav-texto">{item.texto}</span>
                      </button>
                    </li>
                  ))
                }
              </ul>
            </nav>

            <div class="sb-user">
              <span class="sb-avatar" aria-hidden="true">A</span>
              <span class="sb-user-datos">
                <strong>Administrador Local</strong>
                <small>Admin</small>
              </span>
              <button type="button" class="sb-salir" data-rol="salir">Salir</button>
            </div>
          </aside>

          <!-- ===== Zona principal ===== -->
          <div class="app-main">
            <header class="app-topbar">
              <nav class="breadcrumb" data-rol="breadcrumb" aria-label="Ruta"><span class="bc-actual">Inicio</span></nav>
              <div class="tb-user">
                <span class="tb-user-nombre">Administrador Local</span>
                <span class="tb-badge">admin</span>
              </div>
            </header>

            <div class="app-scroll">
              <!-- ===== Vista: Dashboard ===== -->
              <section class="vista es-activa" data-vista="dashboard" tabindex="-1" aria-label="Dashboard">
                <h2 class="vista-titulo">Dashboard</h2>

                <div class="stats">
                  <article class="stat">
                    <span class="stat-icono" data-tono="navy" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICO.user} />
                    </span>
                    <span class="stat-cont">
                      <span class="stat-label">Usuarios Totales</span>
                      <span class="stat-valor" data-rol="stat-usuarios">0</span>
                    </span>
                  </article>
                  <article class="stat">
                    <span class="stat-icono" data-tono="green" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICO.script} />
                    </span>
                    <span class="stat-cont">
                      <span class="stat-label">Scripts Activos</span>
                      <span class="stat-valor" data-rol="stat-scripts">0</span>
                    </span>
                  </article>
                  <article class="stat">
                    <span class="stat-icono" data-tono="blue" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICO.play} />
                    </span>
                    <span class="stat-cont">
                      <span class="stat-label">Ejecuciones Hoy</span>
                      <span class="stat-valor" data-rol="stat-ejec">0</span>
                    </span>
                  </article>
                  <article class="stat">
                    <span class="stat-icono" data-tono="red" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICO.alert} />
                    </span>
                    <span class="stat-cont">
                      <span class="stat-label">Errores Hoy</span>
                      <span class="stat-valor" data-rol="stat-errores">0</span>
                    </span>
                  </article>
                </div>

                <div class="panel grafico-panel">
                  <div class="panel-cabecera">
                    <h3 class="panel-titulo">Ejecuciones — Últimos 7 Días</h3>
                  </div>
                  <div class="grafico-wrap" data-rol="grafico-wrap">
                    <canvas data-rol="grafico" role="img" aria-label="Gráfico de barras de ejecuciones diarias de la última semana"></canvas>
                  </div>
                </div>

                <div class="grid-2">
                  <div class="panel">
                    <div class="panel-cabecera"><h3 class="panel-titulo">Top Scripts</h3></div>
                    <div class="tabla-scroll">
                      <table class="tabla">
                        <thead>
                          <tr>
                            <th scope="col">Script</th>
                            <th scope="col">Categoría</th>
                            <th scope="col">Ejecuciones</th>
                            <th scope="col">Tasa de Éxito</th>
                          </tr>
                        </thead>
                        <tbody data-rol="cuerpo-top-scripts"></tbody>
                      </table>
                    </div>
                  </div>
                  <div class="panel">
                    <div class="panel-cabecera"><h3 class="panel-titulo">Top Usuarios</h3></div>
                    <div class="tabla-scroll">
                      <table class="tabla">
                        <thead>
                          <tr>
                            <th scope="col">Usuario</th>
                            <th scope="col">Nombre</th>
                            <th scope="col">Ejecuciones</th>
                            <th scope="col">Última Ejecución</th>
                          </tr>
                        </thead>
                        <tbody data-rol="cuerpo-top-usuarios"></tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </section>

              <!-- ===== Vista: Usuarios ===== -->
              <section class="vista" data-vista="usuarios" tabindex="-1" aria-label="Usuarios" hidden>
                <div class="vista-cabecera">
                  <h2 class="vista-titulo">Usuarios</h2>
                  <button type="button" class="btn-principal" data-seccion="Nuevo Usuario">+ Nuevo Usuario</button>
                </div>

                <div class="filtros-fila">
                  <div class="input-busca">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                      <circle cx="11" cy="11" r="7"></circle>
                      <path d="m21 21-4.3-4.3"></path>
                    </svg>
                    <label class="visualmente-oculto" for="buscar-usuario">Buscar usuario</label>
                    <input type="search" id="buscar-usuario" placeholder="Buscar usuario…" autocomplete="off" data-rol="buscar-usuario" />
                  </div>
                  <label class="visualmente-oculto" for="filtro-rol">Filtrar por rol</label>
                  <select class="select" id="filtro-rol" data-rol="filtro-rol">
                    <option value="todos">Todos los roles</option>
                    <option value="Admin">Admin</option>
                    <option value="Operador">Operador</option>
                    <option value="Desarrollador">Desarrollador</option>
                    <option value="Auditor">Auditor</option>
                  </select>
                  <label class="visualmente-oculto" for="filtro-estado">Filtrar por estado</label>
                  <select class="select" id="filtro-estado" data-rol="filtro-estado">
                    <option value="todos">Todos los estados</option>
                    <option value="Activo">Activo</option>
                    <option value="Inactivo">Inactivo</option>
                  </select>
                </div>

                <div class="panel">
                  <div class="tabla-scroll">
                    <table class="tabla tabla-usuarios">
                      <thead>
                        <tr>
                          <th scope="col">Usuario</th>
                          <th scope="col">Nombre Completo</th>
                          <th scope="col">Email</th>
                          <th scope="col">Rol</th>
                          <th scope="col">Departamento</th>
                          <th scope="col">Estado</th>
                          <th scope="col">Último Login</th>
                          <th scope="col" class="col-accion">Acciones</th>
                        </tr>
                      </thead>
                      <tbody data-rol="cuerpo-usuarios"></tbody>
                    </table>
                    <p class="sin-resultados" data-rol="sin-usuarios" hidden>No hay usuarios que coincidan con el filtro.</p>
                  </div>
                  <div class="paginacion">
                    <span class="pag-info" data-rol="pag-info">Mostrando 0 de 0</span>
                    <div class="pag-botones">
                      <button type="button" class="pag-btn" disabled>Anterior</button>
                      <button type="button" class="pag-btn es-activo">1</button>
                      <button type="button" class="pag-btn" disabled>Siguiente</button>
                    </div>
                    <span class="pag-tam"><span class="pag-tam-num">20</span> por página</span>
                  </div>
                </div>
              </section>

              <!-- ===== Vista: Scripts ===== -->
              <section class="vista" data-vista="scripts" tabindex="-1" aria-label="Scripts" hidden>
                <div class="vista-cabecera">
                  <h2 class="vista-titulo">Scripts</h2>
                </div>

                <div class="filtros-fila">
                  <div class="input-busca">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                      <circle cx="11" cy="11" r="7"></circle>
                      <path d="m21 21-4.3-4.3"></path>
                    </svg>
                    <label class="visualmente-oculto" for="buscar-script">Buscar script</label>
                    <input type="search" id="buscar-script" placeholder="Buscar script…" autocomplete="off" data-rol="buscar-script" />
                  </div>
                </div>

                <div class="chips-cat" role="group" aria-label="Filtrar por categoría" data-rol="chips-cat"></div>

                <div class="panel">
                  <div class="tabla-scroll">
                    <table class="tabla tabla-scripts">
                      <thead>
                        <tr>
                          <th scope="col">Script</th>
                          <th scope="col">Categoría</th>
                          <th scope="col">Versión</th>
                          <th scope="col">Estado</th>
                          <th scope="col" class="col-accion">Acción</th>
                        </tr>
                      </thead>
                      <tbody data-rol="cuerpo-scripts"></tbody>
                    </table>
                    <p class="sin-resultados" data-rol="sin-scripts" hidden>No hay scripts que coincidan con el filtro.</p>
                  </div>
                </div>
              </section>

              <!-- ===== Vista: Logs Ejecución ===== -->
              <section class="vista" data-vista="logs-ejecucion" tabindex="-1" aria-label="Logs de ejecución" hidden>
                <div class="vista-cabecera">
                  <h2 class="vista-titulo">Logs Ejecución</h2>
                </div>
                <div class="panel">
                  <div class="tabla-scroll">
                    <table class="tabla">
                      <thead>
                        <tr>
                          <th scope="col">Script</th>
                          <th scope="col">Usuario</th>
                          <th scope="col">Inicio</th>
                          <th scope="col">Duración</th>
                          <th scope="col">Resultado</th>
                        </tr>
                      </thead>
                      <tbody data-rol="cuerpo-ejec"></tbody>
                    </table>
                  </div>
                </div>
              </section>
            </div>
          </div>
        </div>

        <!-- ===== Consola de ejecución ===== -->
        <div class="consola-overlay" data-rol="consola-overlay" hidden>
          <div class="consola" role="dialog" aria-modal="true" aria-labelledby="consola-titulo" data-rol="consola">
            <div class="consola-cabecera">
              <h3 id="consola-titulo" class="consola-titulo">
                Ejecutando <span data-rol="consola-script">script</span>
              </h3>
              <button type="button" class="consola-cerrar" data-rol="consola-cerrar" aria-label="Cerrar consola">✕</button>
            </div>
            <pre class="consola-salida" data-rol="consola-log" role="log" aria-live="polite" tabindex="0"></pre>
            <div class="consola-pie" data-rol="consola-pie"></div>
          </div>
        </div>

        <div class="demo-toast" data-rol="toast" role="status" aria-live="polite" hidden></div>

        <noscript>
          <p class="aviso-nojs">
            Esta demo necesita JavaScript para simular el panel. Puedes revisar
            la <a href={withBase("docs/nexus/")}>documentación de Nexus</a> para
            conocer su arquitectura.
          </p>
        </noscript>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>

<style is:global>
  /* ============================================================
     Demo Nexus — panel administrativo simulado, fiel a la app real.
     Todo el CSS va prefijado por .demo-nexus porque parte del DOM
     (tablas, chips, logs) se genera desde el <script>.
     El sidebar mantiene su paleta navy fija (como la app real);
     el área de contenido se adapta al tema del portafolio.
     ============================================================ */
  .demo-nexus {
    --nx-side-bg: #1e2a3d;
    --nx-side-activo: #2c4a6e;
    --nx-side-hover: rgba(255, 255, 255, 0.06);
    --nx-side-text: #c3cfe0;
    --nx-side-icono: #8ea1bb;
    --nx-side-label: #61728c;
    --nx-navy: #1e3a5c;
    --nx-blue: #4a90d9;
    --nx-green: #22a565;
    --nx-red: #e0544f;
    --nx-amber: #eab308;
    --nx-content-bg: #f5f7fa;
    --nx-badge-admin-bg: #ece7fb;
    --nx-badge-admin-tx: #7c4ddb;
    --nx-badge-ok-bg: #dcfce7;
    --nx-badge-ok-tx: #15803d;
    --nx-badge-off-bg: #f1f5f9;
    --nx-badge-off-tx: #64748b;
  }
  :root[data-theme="dark"] .demo-nexus {
    --nx-side-bg: #141f30;
    --nx-content-bg: var(--bg);
    --nx-badge-admin-bg: rgba(124, 77, 219, 0.2);
    --nx-badge-admin-tx: #c4b5fd;
    --nx-badge-ok-bg: rgba(34, 165, 101, 0.18);
    --nx-badge-ok-tx: #4ade80;
    --nx-badge-off-bg: rgba(148, 163, 184, 0.16);
    --nx-badge-off-tx: #94a3b8;
  }

  /* ---------- Hero ---------- */
  .demo-nexus .demo-hero {
    padding-block: clamp(2.5rem, 6vw, 4rem) clamp(1.5rem, 3vw, 2rem);
  }
  .demo-nexus .hero-title { font-size: var(--text-3xl); margin-top: 0.6rem; }
  .demo-nexus .hero-lead {
    color: var(--muted);
    max-width: 64ch;
    margin-top: 1rem;
    font-size: var(--text-lg);
  }
  .demo-nexus .aviso-demo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
