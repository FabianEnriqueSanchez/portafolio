</style>

<script>
  // ============================================================
  //  Demo del panel administrativo de Nexus.
  //  Simulación 100% en el navegador: datos ficticios en memoria,
  //  ejecución de scripts fingida con retardos. Nada real corre.
  // ============================================================

  type EstadoScript = "activo" | "borrador";

  interface Categoria {
    nombre: string;
    color: string;
  }

  interface ScriptDemo {
    id: string;
    nombre: string;
    categoria: string;
    version: string;
    estado: EstadoScript;
  }

  interface Ejecucion {
    script: string;
    usuario: string;
    inicio: string;
    duracion: string;
    ok: boolean;
  }

  // Categorías reales del sistema (db/init.sql) con sus colores.
  const CATEGORIAS: Record<string, Categoria> = {
    TI: { nombre: "TI", color: "#1B3A5C" },
    Cartera: { nombre: "Cartera", color: "#2E7D32" },
    Compras: { nombre: "Compras", color: "#C62828" },
    Ventas: { nombre: "Ventas", color: "#F57F17" },
    Mercadeo: { nombre: "Mercadeo", color: "#6A1B9A" },
    Transporte: { nombre: "Transporte", color: "#00838F" },
    Contabilidad: { nombre: "Contabilidad", color: "#37474F" },
    Nomina: { nombre: "Nómina", color: "#1565C0" },
    Magento: { nombre: "Magento", color: "#E91E63" },
  };

  const SCRIPTS_SEMILLA: ScriptDemo[] = [
    { id: "s1", nombre: "backup_sap", categoria: "TI", version: "1.4.0", estado: "activo" },
    { id: "s2", nombre: "aging_cartera", categoria: "Cartera", version: "2.0.1", estado: "activo" },
    { id: "s3", nombre: "sync_magento", categoria: "Magento", version: "1.2.3", estado: "activo" },
    { id: "s4", nombre: "reporte_ventas", categoria: "Ventas", version: "1.0.5", estado: "activo" },
    { id: "s5", nombre: "cierre_contable", categoria: "Contabilidad", version: "3.1.0", estado: "activo" },
    { id: "s6", nombre: "orden_compra", categoria: "Compras", version: "1.1.2", estado: "borrador" },
    { id: "s7", nombre: "despacho_transporte", categoria: "Transporte", version: "1.0.0", estado: "activo" },
    { id: "s8", nombre: "nomina_quincenal", categoria: "Nomina", version: "2.2.0", estado: "activo" },
    { id: "s9", nombre: "campania_mailing", categoria: "Mercadeo", version: "1.3.1", estado: "borrador" },
  ];

  const EJEC_SEMILLA: Ejecucion[] = [
    { script: "aging_cartera", usuario: "j.perez", inicio: "08:12", duracion: "4.2 s", ok: true },
    { script: "reporte_ventas", usuario: "m.gomez", inicio: "08:47", duracion: "2.8 s", ok: true },
    { script: "sync_magento", usuario: "c.ruiz", inicio: "09:03", duracion: "11.5 s", ok: true },
    { script: "orden_compra", usuario: "l.torres", inicio: "09:31", duracion: "1.1 s", ok: false },
  ];

  const HIST_SEMILLA = [9, 14, 11, 18, 22, 7]; // 6 días previos; el 7º (hoy) es dinámico

  // Helper: querySelector que falla ruidosamente si el nodo no existe.
  function q<T extends Element>(raiz: ParentNode, sel: string): T {
    const el = raiz.querySelector<T>(sel);
    if (el === null) throw new Error(`Demo Nexus: no se encontró "${sel}"`);
    return el;
  }

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const pausa = (ms: number) =>
    new Promise<void>((r) => setTimeout(r, reduce ? 0 : ms));

  // -------- Estado --------
  let scripts: ScriptDemo[] = [];
  let ejecuciones: Ejecucion[] = [];
  let ejecHoy = 0;
  let filtroCat = "todas";
  let filtroTexto = "";
  let ejecutando = false;

  // -------- Referencias DOM --------
  const raiz = q<HTMLElement>(document, ".demo-nexus");
  const anuncio = q<HTMLElement>(raiz, "#anuncio");

  const navBtns = Array.from(raiz.querySelectorAll<HTMLButtonElement>("[data-nav]"));
  const vistas = Array.from(raiz.querySelectorAll<HTMLElement>("[data-vista]"));

  const statScripts = q<HTMLElement>(raiz, '[data-rol="stat-scripts"]');
  const statEjec = q<HTMLElement>(raiz, '[data-rol="stat-ejec"]');
  const cuerpoRecientes = q<HTMLElement>(raiz, '[data-rol="cuerpo-recientes"]');
  const cuerpoScripts = q<HTMLElement>(raiz, '[data-rol="cuerpo-scripts"]');
  const cuerpoEjec = q<HTMLElement>(raiz, '[data-rol="cuerpo-ejec"]');
  const chipsCat = q<HTMLElement>(raiz, '[data-rol="chips-cat"]');
  const sinResultados = q<HTMLElement>(raiz, '[data-rol="sin-resultados"]');
  const inputBuscar = q<HTMLInputElement>(raiz, '[data-rol="buscar"]');

  const canvas = q<HTMLCanvasElement>(raiz, '[data-rol="grafico"]');
  const ctxMaybe = canvas.getContext("2d");
  if (ctxMaybe === null) throw new Error("Demo Nexus: canvas 2D no disponible");
  // Tipo no-null explícito para conservar el estrechado dentro de las closures.
  const ctx: CanvasRenderingContext2D = ctxMaybe;
  const graficoWrap = q<HTMLElement>(raiz, '[data-rol="grafico-wrap"]');

  const overlay = q<HTMLElement>(raiz, '[data-rol="consola-overlay"]');
  const consolaScript = q<HTMLElement>(raiz, '[data-rol="consola-script"]');
  const consolaLog = q<HTMLElement>(raiz, '[data-rol="consola-log"]');
  const consolaPie = q<HTMLElement>(raiz, '[data-rol="consola-pie"]');
  const consolaCerrar = q<HTMLButtonElement>(raiz, '[data-rol="consola-cerrar"]');
  const btnReiniciar = q<HTMLButtonElement>(raiz, '[data-rol="reiniciar"]');

  // ============================================================
  //  Render
  // ============================================================
  function catPunto(cat: string): string {
    const c = CATEGORIAS[cat];
    const color = c ? c.color : "#888";
    const nombre = c ? c.nombre : cat;
    return `<span class="cat"><span class="cat-punto" style="background:${color}"></span>${nombre}</span>`;
  }

  function badgeEstado(estado: EstadoScript): string {
    return `<span class="badge badge-${estado}">${estado}</span>`;
  }

  function filaScript(s: ScriptDemo, conAccion: boolean): string {
    const accion = conAccion
      ? `<td class="col-accion"><button type="button" class="btn-ejecutar" data-ejecutar="${s.id}"${s.estado === "borrador" ? " disabled title=\"Los borradores no se ejecutan\"" : ""}>▶ Ejecutar</button></td>`
      : "";
    return `<tr>
      <td><span class="script-nombre">${s.nombre}</span></td>
      <td>${catPunto(s.categoria)}</td>
      <td><span class="script-nombre">v${s.version}</span></td>
      <td>${badgeEstado(s.estado)}</td>
      ${accion}
    </tr>`;
  }

  function renderStats() {
    statScripts.textContent = String(scripts.filter((s) => s.estado === "activo").length);
    statEjec.textContent = String(ejecHoy);
  }

  function renderRecientes() {
    cuerpoRecientes.innerHTML = scripts
      .slice(0, 5)
      .map((s) => filaScript(s, false))
      .join("");
  }

  function scriptsFiltrados(): ScriptDemo[] {
    return scripts.filter((s) => {
      const okCat = filtroCat === "todas" || s.categoria === filtroCat;
      const okTexto =
        filtroTexto === "" ||
        s.nombre.toLowerCase().includes(filtroTexto.toLowerCase());
      return okCat && okTexto;
    });
  }

  function renderScripts() {
    const lista = scriptsFiltrados();
    cuerpoScripts.innerHTML = lista.map((s) => filaScript(s, true)).join("");
    sinResultados.hidden = lista.length > 0;
  }

  function renderEjecuciones() {
    cuerpoEjec.innerHTML = ejecuciones
      .map(
        (e) => `<tr>
          <td><span class="script-nombre">${e.script}</span></td>
          <td>${e.usuario}</td>
          <td>${e.inicio}</td>
          <td>${e.duracion}</td>
          <td>${e.ok ? '<span class="res res-ok">✓ Éxito</span>' : '<span class="res res-err">✕ Error</span>'}</td>
        </tr>`,
      )
      .join("");
  }

  function renderChips() {
    const cats = Array.from(new Set(scripts.map((s) => s.categoria)));
    const chip = (id: string, etiqueta: string, color: string | null, activo: boolean) =>
      `<button type="button" class="chip-cat ${activo ? "es-activo" : ""}" data-cat="${id}" aria-pressed="${activo}">${
        color ? `<span class="cat-punto" style="background:${color}"></span>` : ""
      }${etiqueta}</button>`;
    const html = [chip("todas", "Todas", null, filtroCat === "todas")]
      .concat(
        cats.map((c) =>
          chip(c, CATEGORIAS[c] ? CATEGORIAS[c].nombre : c, CATEGORIAS[c]?.color ?? "#888", filtroCat === c),
        ),
      )
      .join("");
    chipsCat.innerHTML = html;
  }

  // -------- Gráfico de barras (lee tokens del tema) --------
  function pintarGrafico() {
    const dpr = window.devicePixelRatio || 1;
    const w = canvas.clientWidth;
    const totalH = canvas.clientHeight;
    if (w <= 0 || totalH <= 0) return;
    const h = totalH - 22; // zona de barras; el resto se reserva para etiquetas
    canvas.width = Math.round(w * dpr);
    canvas.height = Math.round(totalH * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.clearRect(0, 0, w, totalH);

    const estilos = getComputedStyle(raiz);
    const colBarra = estilos.getPropertyValue("--nx-azul-claro").trim() || "#4a90d9";
    const colTexto = estilos.getPropertyValue("--faint").trim() || "#888";
    const colRejilla = estilos.getPropertyValue("--border").trim() || "#ddd";

    const datos = HIST_SEMILLA.concat([ejecHoy]);
    const etiquetas = ["Lun", "Mar", "Mié", "Jue", "Vie", "Sáb", "Hoy"];
    const max = Math.max(...datos, 1) * 1.15;
    const n = datos.length;
    const gap = 14;
    const bw = (w - gap * (n - 1)) / n;

    // Rejilla base
    ctx.strokeStyle = colRejilla;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(0, h);
    ctx.lineTo(w, h);
    ctx.stroke();

    ctx.font = "11px ui-monospace, monospace";
    ctx.textAlign = "center";

    datos.forEach((v, i) => {
      const x = i * (bw + gap);
      const bh = Math.max((v / max) * h, 2);
      const y = h - bh;
      const esHoy = i === n - 1;
      ctx.fillStyle = colBarra;
      ctx.globalAlpha = esHoy ? 1 : 0.55;
      const r = Math.min(5, bw / 2);
      // barra con esquinas superiores redondeadas
      ctx.beginPath();
      ctx.moveTo(x, h);
      ctx.lineTo(x, y + r);
      ctx.arcTo(x, y, x + r, y, r);
      ctx.lineTo(x + bw - r, y);
      ctx.arcTo(x + bw, y, x + bw, y + r, r);
      ctx.lineTo(x + bw, h);
      ctx.closePath();
      ctx.fill();
      ctx.globalAlpha = 1;
      // valor
      ctx.fillStyle = colTexto;
      ctx.fillText(String(v), x + bw / 2, y - 6);
      // etiqueta
      ctx.fillText(etiquetas[i], x + bw / 2, h + 18);
    });
  }

  // ============================================================
  //  Navegación entre vistas
  // ============================================================
  function irA(vistaId: string) {
    vistas.forEach((v) => {
      const activa = v.dataset.vista === vistaId;
      v.hidden = !activa;
      v.classList.toggle("es-activa", activa);
    });
    raiz.querySelectorAll<HTMLButtonElement>("[data-nav]").forEach((b) => {
      const esNav = b.classList.contains("nav-item");
      if (!esNav) return;
      const activo = b.dataset.nav === vistaId;
      b.classList.toggle("es-activo", activo);
      b.setAttribute("aria-current", activo ? "page" : "false");
    });
    const vistaActiva = vistas.find((v) => v.dataset.vista === vistaId);
    if (vistaActiva) vistaActiva.focus();
    if (vistaId === "dashboard") requestAnimationFrame(pintarGrafico);
  }

  navBtns.forEach((b) =>
    b.addEventListener("click", () => {
      const destino = b.dataset.nav;
      if (destino) irA(destino);
    }),
  );

  // ============================================================
  //  Filtros de la vista Scripts
  // ============================================================
  chipsCat.addEventListener("click", (ev) => {
    const btn = (ev.target as HTMLElement).closest<HTMLButtonElement>("[data-cat]");
    if (!btn) return;
    filtroCat = btn.dataset.cat ?? "todas";
    renderChips();
    renderScripts();
  });

  inputBuscar.addEventListener("input", () => {
    filtroTexto = inputBuscar.value.trim();
    // El buscador global lleva a la vista Scripts al escribir.
    if (filtroTexto !== "") {
      const scriptsVista = vistas.find((v) => v.dataset.vista === "scripts");
      if (scriptsVista && scriptsVista.hidden) irA("scripts");
    }
    renderScripts();
  });

  // ============================================================
  //  Ejecutar un script (flujo estrella)
  // ============================================================
  function linea(clase: string, texto: string) {
    const span = document.createElement("span");
    span.className = clase;
    span.textContent = texto + "\n";
    consolaLog.appendChild(span);
    consolaLog.scrollTop = consolaLog.scrollHeight;
  }

  function ahora(): string {
    const d = new Date();
    return `${String(d.getHours()).padStart(2, "0")}:${String(d.getMinutes()).padStart(2, "0")}`;
  }

  async function ejecutar(id: string) {
    if (ejecutando) return;
    const script = scripts.find((s) => s.id === id);
    if (!script) return;
    ejecutando = true;

    consolaScript.textContent = script.nombre;
    consolaLog.innerHTML = "";
    consolaPie.className = "consola-pie";
    consolaPie.textContent = "";
    overlay.hidden = false;
    consolaCerrar.focus();
    anuncio.textContent = `Ejecutando ${script.nombre}…`;

    linea("l-info", `$ nexus run ${script.nombre} --version ${script.version}`);
    await pausa(400);
    linea("l-info", `[${ahora()}] Autenticando usuario (JWT)…`);
    await pausa(500);
    linea("l-info", `[${ahora()}] Resolviendo entorno virtual y dependencias…`);
    await pausa(650);
    linea("l-info", `[${ahora()}] Inyectando secretos (AES-256) para categoría ${script.categoria}…`);
    await pausa(600);
    linea("l-cmd", `[${ahora()}] Verificando integridad SHA-256… OK`);
    await pausa(500);
    linea("l-cmd", `[${ahora()}] Ejecutando script…`);
    await pausa(900);

    // Resultado determinista por script (para reproducibilidad), 1 de cada ~5 falla.
    const falla = script.nombre.length % 5 === 0;
    const dur = (1.2 + (script.nombre.length % 7) * 0.8).toFixed(1) + " s";

    if (falla) {
      linea("l-err", `[${ahora()}] ERROR: código de salida 1 — revisar parámetros de entrada.`);
      consolaPie.textContent = "✕ Ejecución finalizada con error";
      consolaPie.classList.add("es-err");
      anuncio.textContent = `La ejecución de ${script.nombre} terminó con error.`;
    } else {
      linea("l-ok", `[${ahora()}] Proceso completado correctamente (código 0).`);
      consolaPie.textContent = `✓ Ejecución completada en ${dur}`;
      consolaPie.classList.add("es-ok");
      anuncio.textContent = `${script.nombre} se ejecutó correctamente.`;
    }

    // Actualiza métricas y registro
    ejecHoy += 1;
    ejecuciones.unshift({
      script: script.nombre,
      usuario: "admin",
      inicio: ahora(),
      duracion: falla ? "—" : dur,
      ok: !falla,
    });
    renderStats();
    renderEjecuciones();
    pintarGrafico();
    ejecutando = false;
  }

  function cerrarConsola() {
    overlay.hidden = true;
  }

  // Delegación: botones "Ejecutar" (se regeneran al filtrar)
  cuerpoScripts.addEventListener("click", (ev) => {
    const btn = (ev.target as HTMLElement).closest<HTMLButtonElement>("[data-ejecutar]");
    if (!btn || btn.disabled) return;
    const id = btn.dataset.ejecutar;
    if (id) void ejecutar(id);
  });

  consolaCerrar.addEventListener("click", cerrarConsola);
  overlay.addEventListener("click", (ev) => {
    if (ev.target === overlay) cerrarConsola();
  });
  document.addEventListener("keydown", (ev) => {
    if (ev.key === "Escape" && !overlay.hidden) cerrarConsola();
  });

  // ============================================================
  //  Reiniciar datos
  // ============================================================
  function reiniciar() {
    scripts = SCRIPTS_SEMILLA.map((s) => ({ ...s }));
    ejecuciones = EJEC_SEMILLA.map((e) => ({ ...e }));
    ejecHoy = 12;
    filtroCat = "todas";
    filtroTexto = "";
    inputBuscar.value = "";
    renderStats();
    renderRecientes();
    renderChips();
    renderScripts();
    renderEjecuciones();
    pintarGrafico();
    anuncio.textContent = "Datos de la demo reiniciados.";
  }

  btnReiniciar.addEventListener("click", () => {
    reiniciar();
    irA("dashboard");
  });

  // ============================================================
  //  Reactividad del gráfico ante tema y tamaño
  // ============================================================
  new ResizeObserver(() => pintarGrafico()).observe(graficoWrap);
  new MutationObserver(() => pintarGrafico()).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });

  // -------- Arranque --------
  reiniciar();
  irA("dashboard");
</script>
