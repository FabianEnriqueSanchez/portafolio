    parrafos.forEach((texto, i) => {
      const fila = el("div", "fila-punto");
      const area = el("textarea");
      area.rows = 4;
      area.value = texto;
      area.setAttribute("aria-label", `Párrafo ${i + 1}`);
      area.addEventListener("input", () => {
        parrafos[i] = area.value;
        marcarCambios();
      });
      const quitar = el("button", "btn-icono");
      quitar.type = "button";
      quitar.setAttribute("aria-label", `Eliminar párrafo ${i + 1}`);
      quitar.title = "Eliminar";
      quitar.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="${ICONO_BORRAR}"></path></svg>`;
