  function pintarExperiencia() {
    const c = cont("experiencia");
    const lista = estado.experiencia;
    const nodos: Node[] = [];
    if (!lista.length)
      nodos.push(estadoVacio("Aún no hay experiencia registrada."));
    lista.forEach((exp, i) => {
      const item = el("div", "item");
      item.dataset.item = String(i);
      item.append(
        barraItem(
          exp.puesto.trim() || `Entrada ${i + 1}`,
          lista,
          i,
          "experiencia",
          pintarExperiencia,
        ),
      );
      const rejilla = el("div", "rejilla-2");
      rejilla.append(
        campoTexto("Puesto", exp.puesto, (v) => (exp.puesto = v)),
        campoTexto("Empresa", exp.empresa, (v) => (exp.empresa = v)),
        campoTexto("Periodo", exp.periodo, (v) => (exp.periodo = v), {
          ayuda: "P. ej. Abril 2022 – Actualidad.",
        }),
      );
      item.append(rejilla, el("p", "campo-etiqueta", "Puntos destacados"));
      exp.puntos.forEach((punto, j) => {
        const fila = el("div", "fila-punto");
        const area = el("textarea");
        area.rows = 2;
        area.value = punto;
        area.setAttribute(
          "aria-label",
          `Punto ${j + 1} de ${exp.puesto || `la entrada ${i + 1}`}`,
        );
        area.addEventListener("input", () => {
          exp.puntos[j] = area.value;
          marcarCambios();
        });
        const quitar = el("button", "btn-icono");
        quitar.type = "button";
        quitar.setAttribute("aria-label", `Eliminar punto ${j + 1}`);
        quitar.title = "Eliminar";
        quitar.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="${ICONO_BORRAR}"></path></svg>`;
        quitar.addEventListener("click", () => {
          exp.puntos.splice(j, 1);
          marcarCambios();
          pintarExperiencia();
          // Mantener el foco: botón de eliminar del punto vecino o, si no
          // queda ninguno, el botón «Añadir punto» de esta entrada
          const entrada = cont("experiencia").querySelector<HTMLElement>(
            `[data-item="${i}"]`,
          );
          const botones = entrada?.querySelectorAll<HTMLButtonElement>(
            ".fila-punto .btn-icono",
          );
          if (botones && botones.length)
            botones[Math.min(j, botones.length - 1)]?.focus();
          else
            entrada
              ?.querySelector<HTMLButtonElement>(".btn.btn-ghost")
              ?.focus();
        });
        fila.append(area, quitar);
        item.append(fila);
      });
      const anadirPunto = el("button", "btn btn-ghost", "+ Añadir punto");
      anadirPunto.type = "button";
      anadirPunto.addEventListener("click", () => {
        exp.puntos.push("");
        marcarCambios();
        pintarExperiencia();
        const areas = cont("experiencia").querySelectorAll(
          `[data-item="${i}"] textarea`,
        );
        (areas[areas.length - 1] as HTMLTextAreaElement | undefined)?.focus();
      });
      item.append(anadirPunto);
      nodos.push(item);
    });
    nodos.push(
      botonAnadir("Añadir experiencia", () => {
        lista.push({ puesto: "", empresa: "", periodo: "", puntos: [] });
        marcarCambios();
        pintarExperiencia();
        cont("experiencia")
          .querySelector<HTMLInputElement>(
            `[data-item="${lista.length - 1}"] input`,
          )
          ?.focus();
      }),
    );
    c.replaceChildren(...nodos);
  }

  /* Listas de objetos planos (formación, certificaciones, idiomas, navegación) */
  type OpcionesListaSencilla = {
    seccion: string;
    lista: Record<string, string>[];
    campos: Array<{ clave: string; etiqueta: string; ayuda?: string }>;
    tituloItem: (item: Record<string, string>, i: number) => string;
    crear: () => Record<string, string>;
    textoAnadir: string;
    textoVacio: string;
  };

  function pintarListaSencilla(opciones: OpcionesListaSencilla) {
    const c = cont(opciones.seccion);
    const repintar = () => pintarListaSencilla(opciones);
    const nodos: Node[] = [];
    if (!opciones.lista.length) nodos.push(estadoVacio(opciones.textoVacio));
    opciones.lista.forEach((item, i) => {
      const tarjeta = el("div", "item");
      tarjeta.dataset.item = String(i);
      tarjeta.append(
        barraItem(
          opciones.tituloItem(item, i),
          opciones.lista,
          i,
          opciones.seccion,
          repintar,
        ),
      );
      const rejilla = el("div", "rejilla-2");
      opciones.campos.forEach((campo) => {
        rejilla.append(
          campoTexto(
            campo.etiqueta,
            item[campo.clave] ?? "",
            (v) => (item[campo.clave] = v),
            {
              ayuda: campo.ayuda,
            },
          ),
        );
      });
      tarjeta.append(rejilla);
      nodos.push(tarjeta);
    });
    nodos.push(
      botonAnadir(opciones.textoAnadir, () => {
        opciones.lista.push(opciones.crear());
        marcarCambios();
        repintar();
        c.querySelector<HTMLInputElement>(
          `[data-item="${opciones.lista.length - 1}"] input`,
        )?.focus();
      }),
    );
    c.replaceChildren(...nodos);
  }

