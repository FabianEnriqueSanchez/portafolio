  function pintarCv() {
    const c = cont("cv");
    const plantillas: Array<[string, string]> = [
      ["moderna", "Moderna"],
      ["clasica", "Clásica"],
      ["compacta", "Compacta"],
    ];
    const previas = el("p", "cv-previas");
    previas.append("Ver vista previa de cada plantilla: ");
    plantillas.forEach(([valor, texto], i) => {
      if (i) previas.append(" · ");
      const enlace = el("a", "", texto);
      enlace.href = withBase(`cv/${valor}/`);
      enlace.target = "_blank";
      enlace.rel = "noopener";
      enlace.setAttribute(
        "aria-label",
        `Ver vista previa de la plantilla ${texto}`,
      );
      previas.append(enlace);
    });
    c.replaceChildren(
      campoSelect(
        "Plantilla de la hoja de vida",
        estado.cv.plantilla,
        plantillas,
        (v) => (estado.cv.plantilla = v),
      ),
      previas,
      campoTexto(
        "Archivo estático (opcional)",
        estado.cv.archivoEstatico,
        (v) => (estado.cv.archivoEstatico = v),
        {
          ayuda:
            "Déjalo vacío para usar la hoja de vida imprimible de /cv; o escribe p. ej. cv.pdf para servir un PDF estático desde /public.",
        },
      ),
      campoArea(
        "Perfil profesional",
        estado.cv.perfilProfesional,
        (v) => (estado.cv.perfilProfesional = v),
        4,
      ),
    );
  }

  function pintarTodo() {
    pintarPerfil();
    pintarSobreMi();
    pintarProyectos();
    pintarExperiencia();
    pintarEducacion();
    pintarCertificaciones();
    pintarIdiomas();
    pintarNavegacion();
    pintarCv();
  }

  /* ============================================================
     Arranque: con token guardado se carga la versión real del
     repositorio; el JSON del build queda solo como respaldo.
     ============================================================ */
  async function cargarInicial() {
    const token = inputToken.value.trim();
    if (token) {
      anunciar("info", ["Cargando datos desde GitHub…"]);
      try {
        const { contenido, sha } = await obtenerArchivo(token);
        estado = JSON.parse(contenido) as DatosSitio;
        shaActual = sha;
        pintarTodo();
        limpiarEstado();
        return;
      } catch {
        /* token inválido o sin red: se cae al JSON del build con aviso */
      }
    }
    pintarTodo();
    anunciar("info", [
      "Datos del último build: pulsa «Recargar desde GitHub» antes de publicar.",
    ]);
  }

  inicializarToken();
  void cargarInicial();
</script>
