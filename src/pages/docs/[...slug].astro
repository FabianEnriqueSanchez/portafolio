---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { withBase } from "../../lib/utils";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
---

<BaseLayout titulo={`${doc.data.titulo} — Documentación`} descripcion={doc.data.descripcion}>
  <Header />
  <main id="contenido" class="section">
    <article class="container doc-article">
      <a href={withBase("docs")} class="doc-back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M19 12H5M11 18l-6-6 6-6"></path>
        </svg>
        Volver a documentación
      </a>

      <header class="doc-header">
        <h1>{doc.data.titulo}</h1>
        <p class="doc-lead">{doc.data.descripcion}</p>
        {
          doc.data.actualizado && (
            <p class="doc-updated">Última actualización: {doc.data.actualizado}</p>
          )
        }
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .doc-article {
    max-width: 760px;
  }

  .doc-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-sm);
    color: var(--muted);
    margin-bottom: 2rem;
    transition: color var(--dur) var(--ease);
  }
  .doc-back:hover {
    color: var(--accent);
  }

  .doc-header {
    padding-bottom: 1.6rem;
    margin-bottom: 2.2rem;
    border-bottom: 1px solid var(--border);
  }
  .doc-header h1 {
    font-size: var(--text-3xl);
  }
  .doc-lead {
    color: var(--muted);
    font-size: var(--text-lg);
    margin-top: 0.8rem;
  }
  .doc-updated {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--faint);
    margin-top: 1rem;
  }

  /* ---------- Estilos de lectura (prose) ---------- */
  .prose {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.75;
  }
  .doc-header h1 {
    font-family: var(--font-display);
  }
  .prose :global(h2) {
    font-size: var(--text-xl);
    margin-top: 2.6rem;
    margin-bottom: 0.9rem;
    padding-top: 0.4rem;
  }
  .prose :global(h3) {
    font-size: var(--text-lg);
    margin-top: 2rem;
    margin-bottom: 0.7rem;
  }
  .prose :global(p) {
    margin-block: 1rem;
    color: var(--text);
  }
  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin-block: 1rem;
    padding-left: 1.4rem;
  }
  .prose :global(li) {
    margin-block: 0.4rem;
  }
  .prose :global(strong) {
    font-weight: 640;
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.86em;
    background: var(--bg-soft);
    padding: 0.15rem 0.4rem;
    border-radius: 5px;
    border: 1px solid var(--border);
  }
  .prose :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.1rem 1.25rem;
    overflow-x: auto;
    margin-block: 1.4rem;
    font-size: 0.86rem;
    line-height: 1.7;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 0.9rem 1.3rem;
    margin-block: 1.4rem;
    color: var(--muted);
    background: var(--accent-soft);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }
  .prose :global(blockquote p) {
    margin-block: 0.4rem;
    color: var(--muted);
  }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-block: 1.5rem;
    font-size: var(--text-sm);
  }
  .prose :global(th),
  .prose :global(td) {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--border);
  }
  .prose :global(th) {
    background: var(--bg-soft);
    font-weight: 600;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin-block: 2.2rem;
  }
</style>
