---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { withBase } from "../lib/utils";
---

<BaseLayout
  titulo="Página no encontrada — 404"
  descripcion="La página que buscas no existe o cambió de dirección."
  noindex
>
  <Header />
  <main id="contenido" class="section" tabindex="-1">
    <div class="container error-wrap">
      <p class="error-codigo" aria-hidden="true">404</p>
      <h1 class="section-title">Esta página no existe</h1>
      <p class="section-intro">
        Puede que el enlace esté mal escrito o que la página haya cambiado de
        dirección.
      </p>
      <div class="error-acciones">
        <a href={withBase("/")} class="btn btn-primary">Ir al inicio</a>
        <a href={withBase("docs")} class="btn btn-ghost">Ver documentación</a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .error-wrap {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-block: clamp(2rem, 8vw, 5rem);
  }

  .error-codigo {
    font-family: var(--font-mono);
    font-size: clamp(4rem, 14vw, 7rem);
    font-weight: 700;
    line-height: 1;
    color: var(--accent);
    opacity: 0.35;
  }

  .error-wrap .section-title {
    margin-top: 1rem;
    max-width: none;
  }

  .error-wrap .section-intro {
    max-width: 42ch;
  }

  .error-acciones {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }
</style>
